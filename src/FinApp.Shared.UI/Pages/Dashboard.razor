    {
        _depCategoryId = State.ContributionCategories.FirstOrDefault()?.Id ?? Guid.Empty;
        _depFundId = fundId;
        _depAmount = 0;
        _depDate = DateOnly.FromDateTime(DateTime.Today);
        _modal = Modal.Deposit;
    }

    private void OpenEditTransfer(Guid id)
    {
        if (State.FindFundTransfer(id) is not { } t) return;
        _editTransferId = id;
        _editTransferFromId = t.FromFundId; _editTransferToId = t.ToFundId;
        _editTransferAmount = t.Amount.Amount; _editTransferNote = t.Note;
        _modal = Modal.EditTransfer;
    }

    private Task SaveEditTransfer() => RunModal(async () =>
    {
        if (_editTransferAmount <= 0 || _editTransferFromId == _editTransferToId) return;
        await State.EditFundTransfer(_editTransferId, _editTransferFromId, _editTransferToId, _editTransferAmount, _editTransferNote);
        CloseModal();
    });

    private void OpenDeleteTransfer(Guid id) { _editTransferId = id; _modal = Modal.DeleteTransfer; }

    private Task ConfirmDeleteTransfer() => RunModal(async () =>
    {
        await State.RemoveFundTransfer(_editTransferId);
        CloseModal();
    });

    private void OpenDeleteExternalTransfer(Guid id) { _extTransferId = id; _modal = Modal.DeleteExternalTransfer; }

    private Task ConfirmDeleteExternalTransfer() => RunModal(async () =>
    {
        await State.RemoveExternalTransfer(_extTransferId);
        CloseModal();
    });

    // --- Modals -----------------------------------------------------------

    private void OpenAdd(Guid? parentId)
    {
        _addParentId = parentId; _fName = null; _fBudget = 0; _fIcon = null; _modal = Modal.AddCat;
    }

    private void OpenAddSub(Guid parentId) => OpenAdd(parentId);

    private void OpenEdit(Guid categoryId)
    {
        _modalCatId = categoryId;
        _fName = State.CategoryName(categoryId);
        _fIcon = State.CategoryStoredIcon(categoryId);
        var b = State.BudgetFor(categoryId);
        _fBudget = b?.Allocated.Amount ?? 0;
        _fThreshold = (b?.AlertThreshold ?? 0.80m) * 100m;
        _fNotify = b?.NotifyOnEveryExpense ?? false;
        _editCatVendors = [];
        _modal = Modal.EditCat;
        _ = LoadCatVendorsAsync(categoryId);
    }

    /// <summary>Load the merchants auto-filed into this category (only if bank sync is on).</summary>
    private async Task LoadCatVendorsAsync(Guid categoryId)
    {
        if (_bankStatus?.Enabled != true) return;
        try
        {
            var mappings = await State.GetBankMappings();
            _editCatVendors = mappings.Where(m => m.Kind == "category" && m.TargetId == categoryId).Select(m => m.MatchKey).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch { /* bank unreachable — just show none */ }
    }

    private async Task UnmapVendorFromCat(string vendor)
    {
        _bankBusy = true;
        try
        {
            await State.RemoveBankMapping(vendor);
            _editCatVendors.Remove(vendor);
            _bankMappings.Remove(vendor);
        }
        catch { /* ignore */ }
        finally { _bankBusy = false; }
    }

    private void OpenDelete(Guid categoryId) { _modalCatId = categoryId; _modal = Modal.DeleteCat; }
    private void OpenCategoryDetail(Guid categoryId) { _modalCatId = categoryId; _modal = Modal.CategoryDetail; }
    private void OpenAddAccount() { _fName = null; _fCurrency = State.Currency; _fSavingsTarget = 20; _modal = Modal.AddAccount; }
    private void OpenEditAccount() { _fName = State.Account.Name; _fSavingsTarget = (int)decimal.Round(State.SavingsRateTarget * 100m); _modal = Modal.EditAccount; }
    private void OpenDeleteAccount() => _modal = Modal.DeleteAccount;
    private void OpenInvite() { _inviteUsername = null; _inviteMessage = null; _modal = Modal.Invite; }

    private Task ExportAccount() => Run(async () =>
    {
        var (bytes, fileName) = await State.ExportCurrentAccountAsync();
        await JS.InvokeVoidAsync("finappDownloadFile", fileName, Convert.ToBase64String(bytes),
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    });
    private void CloseModal() { _modal = Modal.None; _modalError = null; _modalBack.Clear(); _afterCreate = null; }

    // Account-actions cog menu.
    private bool _acctMenuOpen;
    private void RunAcct(Action a) { _acctMenuOpen = false; a(); }
    private Task MenuExport() { _acctMenuOpen = false; return ExportAccount(); }

    // When a create modal is opened from a parent (e.g. "+ new fund" inside the deposit modal), this selects
    // the freshly-created item back in the parent. Set by the inline-create wrappers, consumed by the Save* handlers.
    private Action<Guid>? _afterCreate;

    // Deposit modal → inline-create a contribution category / fund (then return to the deposit, with it selected).
    private void DepositAddCategory() { _afterCreate = id => _depCategoryId = id; _modalBack.Push(() => _modal = Modal.Deposit); OpenAddContribCat(); }
    private void DepositAddFund() { _afterCreate = id => _depFundId = id; _modalBack.Push(() => _modal = Modal.Deposit); OpenAddFund(); }

    // Add-expense modal → inline-create a budget category / fund (then return to the expense, with it selected).
    private void ExpenseAddCategory() { _afterCreate = id => _categoryId = id; _modalBack.Push(() => _modal = Modal.AddExpense); OpenAdd(null); }
    private void ExpenseAddFund() { _afterCreate = id => _fundId = id; _modalBack.Push(() => _modal = Modal.AddExpense); OpenAddFund(); }

    // Modal navigation stack: opening a modal from inside another pushes a "reopen the parent" action,
    // so Cancel/Close steps back to the parent modal instead of closing everything.
    private readonly Stack<Action> _modalBack = new();

    /// <summary>Cancel/close: return to the parent modal if there is one, else close completely.</summary>
    private void Back()
    {
        _modalError = null;
        if (_modalBack.Count > 0) _modalBack.Pop()();
        else CloseModal();
    }

    // Category-detail → child modals (remember to return to the detail view).
    private void DetailEdit() { var c = _modalCatId; _modalBack.Push(() => OpenCategoryDetail(c)); OpenEdit(c); }
    private void DetailAddExpense() { var c = _modalCatId; _modalBack.Push(() => OpenCategoryDetail(c)); OpenAddExpense(c); }
    private void DetailDelete() { var c = _modalCatId; _modalBack.Push(() => OpenCategoryDetail(c)); OpenDelete(c); }
    private void DetailEditExpense(Guid id) { var c = _modalCatId; _modalBack.Push(() => OpenCategoryDetail(c)); OpenEditExpense(id); }
    private void DetailDeleteExpense(Guid id) { var c = _modalCatId; _modalBack.Push(() => OpenCategoryDetail(c)); OpenDeleteExpense(id); }

    // Edit-category → sub-category modals (remember to return to editing the parent).
    private void EditAddSub() { var parent = _modalCatId; _modalBack.Push(() => OpenEdit(parent)); OpenAdd(parent); }
    private void EditDeleteSelf() { var c = _modalCatId; _modalBack.Push(() => OpenEdit(c)); OpenDelete(c); }
    private void EditEditSub(Guid subId) { var parent = _modalCatId; _modalBack.Push(() => OpenEdit(parent)); OpenEdit(subId); }
    private void EditDeleteSub(Guid subId) { var parent = _modalCatId; _modalBack.Push(() => OpenEdit(parent)); OpenDelete(subId); }

    private Task SendInvite() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_inviteUsername)) return;
        await State.InviteToCurrentAccount(_inviteUsername!.Trim());
        _inviteMessage = $"Invitation sent to {_inviteUsername!.Trim()}.";
        _inviteUsername = null;
    });

    private Task SaveEditAccount() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        if (_fName!.Trim() != State.Account.Name)
            await State.RenameAccount(_fName!);
        var target = Math.Clamp(_fSavingsTarget, 0, 100) / 100m;
        if (target != State.SavingsRateTarget)
            await State.SetSavingsRateTarget(target);
        CloseModal();
    });

    private Task ConfirmDeleteAccount() => RunModal(async () =>
    {
        await State.RemoveAccount(State.CurrentAccountId);
        CloseModal();
    });

    // --- Membership: leave / remove / transfer ----------------------------
    private void OpenRemoveMember(Guid memberId, string name) { _removeMemberId = memberId; _removeMemberName = name; _modal = Modal.RemoveMember; }

    private Task ConfirmRemoveMember() => RunModal(async () =>
    {
        await State.RemoveMember(_removeMemberId);
        CloseModal();
    });

    private void OpenLeaveAccount() { _leaveNewOwnerId = Guid.Empty; _modal = Modal.LeaveAccount; }

    private Task ConfirmLeaveAccount() => RunModal(async () =>
    {
        var newOwner = _leaveNewOwnerId == Guid.Empty ? (Guid?)null : _leaveNewOwnerId;
        await State.LeaveCurrentAccount(newOwner);
        CloseModal();
    });

    private Task SaveAddCat() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        var newId = await State.AddCategory(_fName!, _addParentId, _fIcon);
        if (_fBudget > 0)
            await State.SaveBudget(newId, _fBudget, 80, false);
        var after = _afterCreate; _afterCreate = null;
        Back();
        after?.Invoke(newId);
    });

    private Task SaveEditCat() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        await State.EditCategory(_modalCatId, _fName!, _fIcon);
        if (_fBudget > 0)
            await State.SaveBudget(_modalCatId, _fBudget, _fThreshold, _fNotify);
        CloseModal();
    });

    private Task RemoveBudget() => RunModal(async () =>
    {
        await State.RemoveBudget(_modalCatId);
        CloseModal();
    });

    private Task ConfirmDelete() => RunModal(async () =>
    {
        await State.RemoveCategory(_modalCatId);
        CloseModal();
    });

    private Task SaveAddAccount() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        await State.AddAccount(_fName!, string.IsNullOrWhiteSpace(_fCurrency) ? "EUR" : _fCurrency!, Math.Clamp(_fSavingsTarget, 0, 100) / 100m);
        CloseModal();
    });

    private Task CreateFirstAccount() => Run(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        await State.AddAccount(_fName!, string.IsNullOrWhiteSpace(_fCurrency) ? "EUR" : _fCurrency!, Math.Clamp(_fSavingsTarget, 0, 100) / 100m);
    });

    private static string Fmt(Money m)
    {
        var symbol = m.Currency switch { "EUR" => "€", "USD" => "$", "GBP" => "£", _ => m.Currency + " " };
        return $"{symbol}{m.Amount:N2}";
    }

    /// <summary>Indent a category name in a flat &lt;select&gt; so the tree shape reads (sub-categories under parents).</summary>
    private string CatOption(Guid id, string name, int depth) =>
        (depth == 0 ? "" : new string(' ', depth * 3) + "↳ ") + $"{State.CategoryIcon(id)} {name}";

    private static string IndentLabel(string name, int depth) =>
        depth == 0 ? name : new string(' ', depth * 3) + "↳ " + name;

    private static string PctOrDash(decimal? ratio) =>
        ratio is { } r ? $"{decimal.Round(r * 100m, 0, MidpointRounding.AwayFromZero)}%" : "—";

    private static string PctText(decimal ratio) =>
        $"{decimal.Round(ratio * 100m, 0, MidpointRounding.AwayFromZero)}%";

    public void Dispose() { State.Changed -= OnChanged; Loc.Changed -= OnLocChanged; }
}
