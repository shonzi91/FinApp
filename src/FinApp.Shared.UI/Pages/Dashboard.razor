    private async Task Run(Func<Task> action)
    {
        if (_busy) return;                 // ignore re-entrant clicks while a save is already in flight
        _error = null;
        _busy = true;
        StateHasChanged();                 // paint the "Saving…" state before the (networked) round-trip
        await Task.Yield();
        try { await action(); }
        catch (Exception ex) { _error = Describe(ex); }
        finally { _busy = false; }
    }

    /// <summary>Like <see cref="Run"/>, but routes failures to the open modal (<c>_modalError</c>) so the
    /// validation message shows inside the popup and the modal stays open instead of closing.</summary>
    private async Task RunModal(Func<Task> action)
    {
        if (_busy) return;
        _modalError = null;
        _busy = true;
        StateHasChanged();
        await Task.Yield();
        try { await action(); }
        catch (Exception ex) { _modalError = Describe(ex); }
        finally { _busy = false; }
    }

    /// <summary>Turn an exception into a message a person can act on (instead of raw .NET text).</summary>
    private static string Describe(Exception ex) => ex switch
