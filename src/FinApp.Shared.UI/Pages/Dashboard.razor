    private readonly Dictionary<Guid, decimal> _realOpenings = new();
    private decimal GetRealOpening(Guid id) => _realOpenings.GetValueOrDefault(id);
    private void SetRealOpening(Guid id, decimal v) => _realOpenings[id] = v;
    private string RealOpeningText(Guid id) => GetRealOpening(id).ToString(System.Globalization.CultureInfo.InvariantCulture);
    private void SetRealOpeningText(Guid id, string? v) => _realOpenings[id] = EvalSum(v);

    /// <summary>Evaluate a simple "+ / −" expression (e.g. "100+50-20" → 130) so opening-balance fields can sum/subtract.</summary>
    private static decimal EvalSum(string? expr)
    {
        if (string.IsNullOrWhiteSpace(expr)) return 0m;
        var s = expr.Replace(" ", "").Replace(",", ".");
        decimal total = 0m;
        int sign = 1, start = 0;
        if (s[0] is '+' or '-') { sign = s[0] == '-' ? -1 : 1; start = 1; }
        var num = new System.Text.StringBuilder();
        void Flush()
        {
            if (decimal.TryParse(num.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var v)) total += sign * v;
            num.Clear();
        }
        for (int i = start; i < s.Length; i++)
        {
            if (s[i] is '+' or '-') { Flush(); sign = s[i] == '-' ? -1 : 1; }
            else num.Append(s[i]);
        }
        Flush();
        return total;
    }

    // Modal state
    private Modal _modal = Modal.None;
    private Guid _modalCatId;
    private Guid? _addParentId;
