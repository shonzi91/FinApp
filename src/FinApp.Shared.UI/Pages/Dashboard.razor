    private void PrevDay() { if (_dayView is { } d && d > State.Period.From) GoToDay(d.AddDays(-1)); }
    private void NextDay() { if (_dayView is { } d && d < State.Period.To) GoToDay(d.AddDays(1)); }

    // --- Expenses calendar (month grid) ----------------------------------
    /// <summary>Every day shown in the calendar — the period's range padded out to whole Mon–Sun weeks.</summary>
    private IEnumerable<DateOnly> CalendarDays()
    {
        var from = State.Period.From;
        var to = State.Period.To;
        var start = from.AddDays(-(((int)from.DayOfWeek + 6) % 7));      // back to Monday of the first week
        var end = to.AddDays(6 - (((int)to.DayOfWeek + 6) % 7));         // forward to Sunday of the last week
        for (var d = start; d <= end; d = d.AddDays(1)) yield return d;
    }

