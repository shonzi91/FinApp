    private bool CanTransfer =>
        State.IsPeriodOpen && State.RootFunds.Any() && (State.RootFunds.Count > 1 || State.TransferableAccounts.Any());

    /// <summary>This period's fund-to-fund transfers and out-to-account transfers, merged newest-first.</summary>
    private List<(DateOnly Date, string Label, Money Amount, Guid Id, bool IsExternal, string? Note)> MergedTransfers() =>
        State.FundTransfers
            .Select(t => (t.Date, Label: $"{State.FundName(t.FromFundId)} → {State.FundName(t.ToFundId)}", t.Amount, t.Id, IsExternal: false, t.Note))
            .Concat(State.ExternalTransfers
                .Select(t => (t.Date, Label: $"📤 {State.FundName(t.FundId)} → {State.AccountName(t.ToAccountId ?? Guid.Empty)}", t.Amount, t.Id, IsExternal: true, t.Note)))
            .OrderByDescending(t => t.Date)
            .ToList();

    private Task DoTransfer() => Run(async () =>
    {
        if (_transferAmount <= 0 || _transferDestId == Guid.Empty || _transferDestId == _transferFromId) return;
        if (State.TransferableAccounts.Any(a => a.Id == _transferDestId))
            await State.TransferToAccount(_transferDestId, _transferFromId, _transferAmount, _transferNote);
        else
            await State.TransferFunds(_transferFromId, _transferDestId, _transferAmount, _transferNote);
        _transferAmount = 0; _transferNote = null;
    });

