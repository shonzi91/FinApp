@page "/"
@implements IDisposable
@inject BudgetingState State
@inject Localizer Loc

@if (_busy)
{
    <div class="saving-pill">Saving…</div>
}

@if (!State.IsReady)
{
    <p class="loading">Loading…</p>
}
else if (!State.HasAccounts)
{
    <div class="firstrun">
        <h1>@Loc["Welcome to FinApp"]</h1>
        <InvitationsPanel />
        <p>@Loc["Create your first account to get started (e.g. Personal, Shared, Family)."]</p>
        @if (_error is not null)
        {
            <div class="alert warn-bg"><span>@_error</span><button class="alert-x" title="@Loc["Dismiss"]" @onclick="() => _error = null">×</button></div>
        }
        <div class="firstrun-form">
            <label>@Loc["Account name"] <input type="text" placeholder="Personal" @bind="_fName" /></label>
            <label>@Loc["Currency"] <input type="text" maxlength="3" @bind="_fCurrency" /></label>
            <button @onclick="CreateFirstAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Create account"]</button>
        </div>
        <small class="hint">@Loc["It starts with a few starter categories and the current month’s period — you can change everything."]</small>
    </div>
}
else
{
<div class="dash @(_busy ? "is-busy" : "")">
    <header class="dash-head">
        <div class="period-nav">
            <button class="nav" title="Previous period" @onclick="State.GoPrev" disabled="@(!State.CanGoPrev)">◀</button>
            <div>
                <div class="acct-row">
                    <select class="acct-select" value="@State.CurrentAccountId" @onchange="OnAccountChange">
                        @foreach (var a in State.Accounts)
                        {
                            <option value="@a.Id">@a.Name</option>
                        }
                    </select>
                    @if (State.IsOwnerOfCurrent)
                    {
                        <button class="link" title="Rename account" @onclick="OpenEditAccount">✏️</button>
                    }
                    <button class="link" title="Add a new account" @onclick="OpenAddAccount">➕</button>
                    <button class="link" title="Invite a contributor" @onclick="OpenInvite">👥</button>
                    @if (State.IsOwnerOfCurrent)
                    {
                        <button class="link" title="Delete account" @onclick="OpenDeleteAccount">🗑️</button>
                    }
                    else
                    {
                        <span class="chip" title="You were invited to this account">shared</span>
                    }
                </div>
                <div class="period-row">
                    <span class="period">@State.Period.From.ToString("dd MMM") – @State.Period.To.ToString("dd MMM yyyy") (@State.PeriodNumber/@State.PeriodCount)</span>
                    <span class="period-ops">
                        <button class="exp-edit" title="Edit period dates" @onclick="OpenEditPeriod">📅</button>
                        @if (State.IsLatestPeriod && State.PeriodCount > 1)
                        {
                            <button class="exp-edit" title="Remove this period and reopen the previous one" @onclick="OpenRemovePeriod">🗑️</button>
                        }
                        @if (State.IsLatestPeriod)
                        {
                            <button class="exp-edit" title="Start next month" @onclick="OpenNextPeriod">⏭️</button>
                        }
                    </span>
                </div>
            </div>
            <button class="nav" title="Next period" @onclick="State.GoNext" disabled="@(!State.CanGoNext)">▶</button>
        </div>
        <div class="head-right">
            <span class="status">@Loc[State.IsPeriodOpen ? "Active" : "Closed"]</span>
            <div class="balances">
                <span class="bal" title="Sum of the period's opening fund values"><span class="bal-label">@Loc["Opening"]</span> <strong>@Fmt(State.OpeningBalance)</strong></span>
            </div>
        </div>
    </header>

    <InvitationsPanel />

    @if (_error is not null)
    {
        <div class="alert warn-bg"><strong>@Loc["Couldn’t do that."]</strong> <span>@_error</span><button class="alert-x" title="@Loc["Dismiss"]" @onclick="() => _error = null">×</button></div>
    }

    <nav class="tabs">
        <button class="tab @(_tab == Tab.Account ? "active" : "")" @onclick="() => _tab = Tab.Account">@Loc["Account"]</button>
        <button class="tab @(_tab == Tab.Budgets ? "active" : "")" @onclick="() => _tab = Tab.Budgets">@Loc["Budgets"]</button>
        <button class="tab @(_tab == Tab.Expenses ? "active" : "")" @onclick="() => _tab = Tab.Expenses">@Loc["Expenses"]</button>
        <button class="tab @(_tab == Tab.Savings ? "active" : "")" @onclick="() => _tab = Tab.Savings">@Loc["Savings"]</button>
    </nav>

    @switch (_tab)
    {
        case Tab.Account:
            <section class="cards">
                <div class="card"><span class="card-label">@Loc[State.IsPeriodOpen ? "Current" : "Closed on"]</span><span class="card-value">@Fmt(State.TotalContributed)</span></div>
                <div class="card"><span class="card-label">@Loc["Spent"]</span><span class="card-value">@Fmt(State.TotalSpent)</span></div>
                <div class="card"><span class="card-label">@Loc["Budgeted"]</span><span class="card-value">@Fmt(State.TotalBudgeted)</span></div>
                <div class="card savings">
                    <span class="card-label">@Loc["Saved this period"]</span>
                    <span class="card-value">@Fmt(State.SavingsThisPeriod)</span>
                    <span class="card-sub">@PctOrDash(State.PeriodSavingsRate) @Loc["of contributions"]</span>
                </div>
            </section>

            @if (State.Deficit.Amount > 0)
            {
                <div class="alert warn-bg">
                    <strong>Overspent by @Fmt(State.Deficit).</strong>
                    <span>Expenses ate into your savings earmark. This will need to be covered next period (from a savings bucket or fresh contributions).</span>
                </div>
            }

            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Funds"]</h2>
                    <span class="head-actions">
                        <button class="link" title="Add a fund" @onclick="OpenAddFund">➕</button>
                    </span>
                </div>
                <ul class="list">
                    @foreach (var f in State.RootFunds)
                    {
                        <li>
                            <span class="fund-name">@f.Name</span>
                            <span class="row-actions">
                                <span class="amt">@Fmt(State.FundBalance(f.Id))</span>
                                <button class="exp-edit" title="Add sub-fund" @onclick="() => OpenAddSubFund(f.Id)">➕</button>
                                <button class="exp-edit" title="Edit fund / opening balance" @onclick="() => OpenEditFund(f.Id)">✏️</button>
                                <button class="exp-edit" title="Remove fund" @onclick="() => OpenDeleteFund(f.Id)">🗑️</button>
                            </span>
                        </li>
                        @foreach (var sub in State.ChildFundsOf(f.Id))
                        {
                            <li class="subfund">
                                <span class="fund-name">↳ @sub.Name</span>
                                <span class="row-actions">
                                    <span class="amt">@Fmt(State.FundOpeningBalance(sub.Id))</span>
                                    <button class="exp-edit" title="Edit sub-fund" @onclick="() => OpenEditFund(sub.Id)">✏️</button>
                                    <button class="exp-edit" title="Remove sub-fund" @onclick="() => OpenDeleteFund(sub.Id)">🗑️</button>
                                </span>
                            </li>
                        }
                        @if (State.SubFundsMismatch(f.Id))
                        {
                            <li class="subfund-hint"><span class="hint warn-text">Sub-funds total @Fmt(State.SubFundOpeningTotal(f.Id)) — doesn't match @f.Name's @Fmt(State.FundOpeningBalance(f.Id)).</span></li>
                        }
                    }
                    @if (!State.RootFunds.Any())
                    {
                        <li><em>@Loc["No funds yet — add one."]</em></li>
                    }
                </ul>
            </section>

            @if (CanTransfer || MergedTransfers().Count > 0)
            {
                var transfers = MergedTransfers();
                <section class="panel">
                    <h2>@Loc["Transfer money"]</h2>
                    @if (CanTransfer)
                    {
                        <div class="form transfer-form">
                            <select @bind="_transferFromId">
                                @foreach (var f in State.RootFunds)
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                            <span class="arrow">→</span>
                            <select @bind="_transferDestId">
                                <optgroup label="@Loc["Funds"]">
                                    @foreach (var f in State.RootFunds.Where(f => f.Id != _transferFromId))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </optgroup>
                                @if (State.TransferableAccounts.Any())
                                {
                                    <optgroup label="@Loc["Other accounts"]">
                                        @foreach (var a in State.TransferableAccounts)
                                        {
                                            <option value="@a.Id">📤 @a.Name</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_transferAmount" />
                            <input type="text" placeholder="@Loc["Note (optional)"]" @bind="_transferNote" />
                            <button title="@Loc["Transfer money"]" @onclick="DoTransfer" disabled="@(_transferAmount <= 0 || _transferDestId == Guid.Empty || _transferDestId == _transferFromId)">🔁</button>
                        </div>
                        <small class="hint">@Loc["Move money between your funds (the total is unchanged), or send it to another account (it leaves this one as an outflow)."]</small>
                    }
                    @if (transfers.Any())
                    {
                        <ul class="list transfer-log">
                            @foreach (var t in transfers)
                            {
                                <li>
                                    <span>@t.Date.ToString("dd MMM") · @t.Label@(string.IsNullOrEmpty(t.Note) ? "" : $" · {t.Note}")</span>
                                    <span class="row-actions">
                                        <span class="amt">@Fmt(t.Amount)</span>
                                        @if (State.IsPeriodOpen && !t.IsExternal)
                                        {
                                            <button class="exp-edit" title="Edit transfer" @onclick="() => OpenEditTransfer(t.Id)">✏️</button>
                                            <button class="exp-edit" title="Remove transfer" @onclick="() => OpenDeleteTransfer(t.Id)">🗑️</button>
                                        }
                                        else if (State.IsPeriodOpen && t.IsExternal)
                                        {
                                            <button class="exp-edit" title="Remove this transfer (does not reverse the deposit in the other account)" @onclick="() => OpenDeleteExternalTransfer(t.Id)">🗑️</button>
                                        }
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }

            <section class="panel">
                <h2>@Loc["Contributions"]</h2>
                @if (State.CarryoverThisPeriod.Amount != 0)
                {
                    <ul class="list">
                        <li class="contrib">
                            <span class="contrib-name">@Loc["From previous period"]</span>
                            <span class="contrib-state">
                                @if (State.CarryoverThisPeriod.Amount < 0)
                                {
                                    <span class="warn-text">@Fmt(State.CarryoverThisPeriod) shortfall</span>
                                }
                                else
                                {
                                    <span>@Fmt(State.CarryoverThisPeriod) carried in (added to the pool)</span>
                                }
                            </span>
                        </li>
                    </ul>
                    @if (State.IsPeriodOpen && State.HasUnallocatedShortfall)
                    {
                        @if (State.SavingBuckets.Any())
                        {
                            <div class="form">
                                <select @bind="_coverBucketId">
                                    @foreach (var (bucket, _) in State.SavingBuckets)
                                    {
                                        <option value="@bucket.Id">@bucket.Name</option>
                                    }
                                </select>
                                <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_coverAmount" />
                                <button @onclick="CoverShortfall" disabled="@(_coverAmount <= 0 || _coverBucketId == Guid.Empty)">@Loc["Cover shortfall"]</button>
                            </div>
                            <small class="hint">@Fmt(State.UnallocatedShortfall) still to cover — pull it from a savings bucket, or it offsets automatically as you add deposits.</small>
                        }
                        else
                        {
                            <p class="hint warn-text">@Fmt(State.UnallocatedShortfall) still unallocated — add deposits (which offset it automatically).</p>
                        }
                    }
                }

                @if (State.IsPeriodOpen)
                {
                    <div class="form contrib-form">
                        <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_depAmount" />
                        <input type="date" @bind="_depDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" />
                        <button class="link" title="@Loc["Category & fund"]" @onclick="() => _depShowDetails = !_depShowDetails">⋯</button>
                        <button @onclick="RecordDeposit" disabled="@(_depAmount <= 0)">@Loc["Deposit"]</button>
                    </div>
                    @if (_depShowDetails)
                    {
                        <div class="form contrib-form">
                            <select @bind="_depCategoryId">
                                @foreach (var cc in State.ContributionCategories)
                                {
                                    <option value="@cc.Id">@cc.Name</option>
                                }
                            </select>
                            <select @bind="_depFundId">
                                @foreach (var f in State.RootFunds)
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                        </div>
                        <div class="contrib-cats">
                            <span class="hint">@Loc["Categories"]:</span>
                            @foreach (var cc in State.ContributionCategories)
                            {
                                <span class="cat-chip">@cc.Name
                                    <button class="exp-edit" title="@Loc["Rename"]" @onclick="() => OpenEditContribCat(cc.Id)">✏️</button>
                                    <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteContribCat(cc.Id)">🗑️</button>
                                </span>
                            }
                            <button class="link" @onclick="OpenAddContribCat">➕ @Loc["Add category"]</button>
                        </div>
                    }
                }

                <ul class="list">
                    @foreach (var c in State.ContributionsThisPeriod)
                    {
                        <li>
                            <span>@c.Date.ToString("dd MMM") · @State.MemberName(c.MemberId) · @State.ContributionCategoryName(c.CategoryId) · @State.FundName(c.FundId)</span>
                            <span class="row-actions">
                                <span class="amt">@Fmt(c.Paid)</span>
                                @if (State.IsPeriodOpen && State.CanHandleContribution(c))
                                {
                                    <button class="exp-edit" title="Edit deposit" @onclick="() => OpenEditDeposit(c.Id)">✏️</button>
                                    <button class="exp-edit" title="Delete deposit" @onclick="() => OpenDeleteDeposit(c.Id)">🗑️</button>
                                }
                            </span>
                        </li>
                    }
                    @if (!State.ContributionsThisPeriod.Any())
                    {
                        <li><em>@Loc["no deposits yet"]</em></li>
                    }
                </ul>
            </section>

            break;

        case Tab.Budgets:
            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Budgets"]</h2>
                    <span>
                        <button class="link" title="Add a top-level category" @onclick="() => OpenAdd(null)">➕</button>
                    </span>
                </div>

                <div class="tree">
                    @foreach (var root in State.RootCategories)
                    {
                        <BudgetTreeNode Node="root" Depth="0" OnEdit="OpenEdit" OnAddSub="OpenAddSub" OnDelete="OpenDelete" OnAddExpense="OpenAddExpense" OnEditExpense="OpenEditExpense" OnDeleteExpense="OpenDeleteExpense" />
                    }
                </div>
            </section>
            break;

        case Tab.Expenses:
            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Add expense"]</h2>
                    @if (_dayView is { } dv)
                    {
                        <span class="day-nav">
                            <button class="exp-edit" title="@Loc["Previous day"]" @onclick="PrevDay" disabled="@(dv <= State.Period.From)">◀</button>
                            <input type="date" @bind:get="dv" @bind:set="GoToDay" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" />
                            <button class="exp-edit" title="@Loc["Next day"]" @onclick="NextDay" disabled="@(dv >= State.Period.To)">▶</button>
                            <button class="link" @onclick="() => _dayView = null">@Loc["All days"]</button>
                        </span>
                    }
                </div>
                <div class="form">
                    <select @bind="_categoryId">
                        @foreach (var (cat, depth) in State.CategoryOptions)
                        {
                            <option value="@cat.Id">@IndentLabel(cat.Name, depth)</option>
                        }
                    </select>
                    <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_amount" />
                    @if (_dayView is null)
                    {
                        <input type="date" @bind="_expenseDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" />
                    }
                    <select @bind="_fundId">
                        @foreach (var f in State.RootFunds)
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>
                    <input type="text" placeholder="@Loc["Note (optional)"]" @bind="_note" />
                    <button title="@Loc["Add expense"]" @onclick="AddExpense" disabled="@(_amount <= 0)">➕</button>
                </div>
            </section>

            <section class="panel">
                <h2>@(_dayView is { } dh ? dh.ToString("dd MMM yyyy") : Loc["All expenses"])</h2>
                @{
                    RenderFragment<FinApp.Domain.Budgeting.Expense> row = e =>
                        @<li>
                            <span>@State.CategoryName(e.CategoryId)@(e.IsFromSavings ? " · 💰saving" : "")@(string.IsNullOrEmpty(e.Note) ? "" : $" · {e.Note}")</span>
                            <span class="row-actions">
                                <span class="amt">@Fmt(e.Amount)</span>
                                @if (State.IsPeriodOpen)
                                {
                                    <button class="exp-edit" title="Edit expense" @onclick="() => OpenEditExpense(e.Id)">✏️</button>
                                    <button class="exp-edit" title="Remove expense" @onclick="() => OpenDeleteExpense(e.Id)">🗑️</button>
                                }
                            </span>
                        </li>;
                    var shown = _dayView is { } dvf
                        ? State.AllExpenses.Where(e => e.Date == dvf).ToList()
                        : State.AllExpenses.ToList();
                }
                @if (!shown.Any())
                {
                    <ul class="list"><li><em>@Loc["No expenses yet."]</em></li></ul>
                }
                else if (_dayView is not null)
                {
                    <ul class="list">@foreach (var e in shown) { @row(e) }</ul>
                }
                else
                {
                    @foreach (var grp in shown.GroupBy(e => e.Date).OrderByDescending(g => g.Key))
                    {
                        <button class="date-sep" @onclick="() => GoToDay(grp.Key)">@grp.Key.ToString("dddd, dd MMM yyyy")</button>
                        <ul class="list">@foreach (var e in grp) { @row(e) }</ul>
                    }
                }
            </section>
            break;

        case Tab.Savings:
            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Savings buckets"]</h2>
                    <button class="link" title="Add a savings bucket" @onclick="OpenAddBucket">➕</button>
                </div>
                <p class="hint">
                    <strong>@Loc["Total saved:"] @Fmt(State.SavingsAccumulated)</strong> ·
                    @Loc["this period:"] <strong>@PctOrDash(State.PeriodSavingsRate)</strong> @Loc["of contributions"] ·
                    @Loc["all periods:"] <strong>@PctOrDash(State.AccountSavingsRate)</strong>
                </p>
                <ul class="bucket-list">
                    @foreach (var (bucket, total) in State.SavingBuckets)
                    {
                        <li class="bucket">
                            <div class="bucket-head">
                                <span class="bucket-name">@bucket.Name</span>
                                <span class="bucket-actions">
                                    <span class="amt save">@Fmt(total)</span>
                                    <button class="exp-edit" title="Edit bucket / goal" @onclick="() => OpenEditBucket(bucket.Id)">✏️</button>
                                    <button class="exp-edit" title="Remove bucket" @onclick="() => OpenDeleteBucket(bucket.Id)">🗑️</button>
                                </span>
                            </div>
                            @if (bucket.HasGoal)
                            {
                                var g = State.SavingGoal(bucket.Id);
                                var pct = g.Percent ?? 0;
                                var cls = g.GoalReached ? "ok" : g.ThresholdReached ? "warn" : "ok";
                                <div class="bucket-goal">
                                    <span class="tree-bar"><span class="tree-fill @cls" style="width:@(Math.Min(pct,100))%"></span></span>
                                    <span class="bucket-goal-pct">@pct% of @Fmt(g.Goal!.Value)@(g.GoalReached ? " ✓" : "")</span>
                                </div>
                            }
                        </li>
                    }
                    @if (!State.SavingBuckets.Any())
                    {
                        <li><em>@Loc["No buckets yet — add one to start saving."]</em></li>
                    }
                </ul>
            </section>

            @if (State.SavingBuckets.Any())
            {
                <section class="panel">
                    <h2>@Loc["Add to savings"]</h2>
                    <div class="form savings-form">
                        <select @bind="_savingBucketId">
                            @foreach (var (bucket, _) in State.SavingBuckets)
                            {
                                <option value="@bucket.Id">@bucket.Name</option>
                            }
                        </select>
                        <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_savingAmount" />
                        <button title="Add to savings" @onclick="AllocateSaving" disabled="@(_savingAmount <= 0 || _savingAmount > State.MaxAdditionalSavings.Amount)">💰</button>
                    </div>
                    <small class="hint">Available to save: <strong>@Fmt(State.MaxAdditionalSavings)</strong> (current − budgeted).</small>
                    @if (State.SavingDepositsThisPeriod.Any())
                    {
                        <ul class="list">
                            @foreach (var d in State.SavingDepositsThisPeriod)
                            {
                                <li>
                                    <span>@d.Date.ToString("dd MMM") · @State.SavingBucketName(d.SavingCategoryId)</span>
                                    <span class="row-actions">
                                        <span class="amt save">@Fmt(d.Amount)</span>
                                        @if (State.IsPeriodOpen)
                                        {
                                            <button class="exp-edit" title="Edit deposit" @onclick="() => OpenEditSavingDeposit(d.Id)">✏️</button>
                                            <button class="exp-edit" title="Remove deposit" @onclick="() => OpenDeleteSavingDeposit(d.Id)">🗑️</button>
                                        }
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </section>

                <section class="panel">
                    <h2>@Loc["Budget savings"]</h2>
                    <div class="form spend-form">
                        <select @bind="_spendBucketId">
                            @foreach (var (bucket, _) in State.SavingBuckets)
                            {
                                <option value="@bucket.Id">@bucket.Name</option>
                            }
                        </select>
                        <span class="arrow">→</span>
                        <select @bind="_spendDestId">
                            @if (State.HasUnallocatedShortfall)
                            {
                                <optgroup label="Shortfall">
                                    <option value="@BudgetingState.CarryoverCategoryId">From previous period (cover @Fmt(State.UnallocatedShortfall))</option>
                                </optgroup>
                            }
                            <optgroup label="Budgets">
                                @foreach (var (cat, depth) in State.CategoryOptions)
                                {
                                    <option value="@cat.Id">@IndentLabel(cat.Name, depth)</option>
                                }
                            </optgroup>
                            @if (State.SavingBuckets.Count > 1)
                            {
                                <optgroup label="Savings buckets">
                                    @foreach (var (bucket, _) in State.SavingBuckets)
                                    {
                                        @if (bucket.Id != _spendBucketId)
                                        {
                                            <option value="@bucket.Id">@bucket.Name</option>
                                        }
                                    }
                                </optgroup>
                            }
                        </select>
                        <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_spendAmount" />
                        <button title="Move savings" @onclick="MoveSaving" disabled="@(_spendAmount <= 0 || _spendDestId == Guid.Empty || _spendDestId == _spendBucketId)">➡️</button>
                    </div>
                    <small class="hint">Pick a destination: a <strong>budget</strong> matures the saving into this month's plan for that category; another <strong>bucket</strong> shifts it across (totals unchanged). The source bucket drops by the amount either way.</small>
                    @if (State.SavingMovementsThisPeriod.Any())
                    {
                        <ul class="list">
                            @foreach (var m in State.SavingMovementsThisPeriod)
                            {
                                <li>
                                    <span>@m.Date.ToString("dd MMM") · @State.SavingMovementTarget(m)</span>
                                    <span class="row-actions">
                                        <span class="amt save">@Fmt(State.Money(-m.Amount.Amount))</span>
                                        @if (State.IsPeriodOpen)
                                        {
                                            <button class="exp-edit" title="Edit this savings movement" @onclick="() => OpenEditSavingMovement(m.Id)">✏️</button>
                                            <button class="exp-edit" title="Undo this savings movement" @onclick="() => OpenDeleteSavingMovement(m.Id)">🗑️</button>
                                        }
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </section>

                <section class="panel">
                    <h2>@Loc["Spend savings"]</h2>
                    <div class="form spend-form">
                        <select @bind="_spendExpBucketId">
                            @foreach (var (bucket, _) in State.SavingBuckets)
                            {
                                <option value="@bucket.Id">@bucket.Name</option>
                            }
                        </select>
                        <span class="arrow">→</span>
                        <select @bind="_spendExpCategoryId">
                            @foreach (var (cat, depth) in State.CategoryOptions)
                            {
                                <option value="@cat.Id">@IndentLabel(cat.Name, depth)</option>
                            }
                        </select>
                        <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_spendExpAmount" />
                        <button title="@Loc["Spend savings"]" @onclick="SpendBucketAsExpense" disabled="@(_spendExpAmount <= 0 || _spendExpCategoryId == Guid.Empty)">💸</button>
                    </div>
                    <small class="hint">@Loc["Records a real expense paid straight from this bucket (dated today)."]</small>
                </section>
            }
            break;
    }
</div>

@if (_modal != Modal.None)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation="true">
            @switch (_modal)
            {
                case Modal.AddCat:
                    <h3>Add category @(_addParentId is {} p ? $"under {State.CategoryName(p)}" : "(top level)")</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <label>Budget for this period (optional) <input type="number" step="0.01" min="0" @bind="_fBudget" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveAddCat" disabled="@(string.IsNullOrWhiteSpace(_fName))">Add</button>
                    </div>
                    break;

                case Modal.EditCat:
                    <h3>Edit @State.CategoryName(_modalCatId)</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <label>Budget amount <input type="number" step="0.01" min="0" @bind="_fBudget" /></label>
                    <label>Alert at % <input type="number" step="1" min="0" max="100" @bind="_fThreshold" /></label>
                    <label class="check"><input type="checkbox" @bind="_fNotify" /> Notify on every expense</label>
                    <div class="modal-actions">
                        @if (State.BudgetFor(_modalCatId) is not null)
                        {
                            <button class="ghost danger" @onclick="RemoveBudget">Remove budget</button>
                        }
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveEditCat" disabled="@(string.IsNullOrWhiteSpace(_fName))">Save</button>
                    </div>
                    break;

                case Modal.DeleteCat:
                    <h3>Delete @State.CategoryName(_modalCatId)?</h3>
                    @if (State.CategoryRemovalBlocker(_modalCatId) is {} blocker)
                    {
                        <p class="hint">Can’t delete — @blocker. Remove those first.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">Close</button></div>
                    }
                    else
                    {
                        <p class="hint">This removes the category permanently.</p>
                        <div class="modal-actions">
                            <button class="ghost" @onclick="CloseModal">Cancel</button>
                            <button class="danger-btn" @onclick="ConfirmDelete">Delete</button>
                        </div>
                    }
                    break;

                case Modal.AddAccount:
                    <h3>New account</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <label>Currency <input type="text" maxlength="3" @bind="_fCurrency" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveAddAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">Create</button>
                    </div>
                    break;

                case Modal.EditAccount:
                    <h3>Rename account</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <p class="hint">Currency (@State.Currency) can't be changed once an account exists.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveEditAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">Save</button>
                    </div>
                    break;

                case Modal.DeleteAccount:
                    <h3>Delete @State.Account.Name?</h3>
                    <p class="hint">This permanently deletes the account and <strong>all its periods, budgets, expenses and savings</strong>. This can't be undone.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteAccount">Delete account</button>
                    </div>
                    break;

                case Modal.Invite:
                    <h3>Invite to @State.Account.Name</h3>
                    <p class="hint">Enter the username of an existing FinApp user. They'll get a prompt to accept; once they do, they can edit everything except deleting the account.</p>
                    <label>Username <input type="text" @bind="_inviteUsername" @bind:event="oninput" /></label>
                    @if (_inviteMessage is not null)
                    {
                        <div class="alert">@_inviteMessage</div>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Close</button>
                        <button @onclick="SendInvite" disabled="@(string.IsNullOrWhiteSpace(_inviteUsername))">Send invite</button>
                    </div>
                    break;

                case Modal.AddExpense:
                    <h3>Add expense — @State.CategoryName(_categoryId)</h3>
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_amount" /></label>
                    <label>Date <input type="date" @bind="_expenseDate" /></label>
                    <label>Fund
                        <select @bind="_fundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>Note (optional) <input type="text" @bind="_note" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="AddExpenseFromModal" disabled="@(_amount <= 0)">Add</button>
                    </div>
                    break;

                case Modal.RemovePeriod:
                    <h3>Remove this period?</h3>
                    <p class="hint">This deletes period @State.PeriodNumber (@State.Period.From.ToString("dd MMM") – @State.Period.To.ToString("dd MMM yyyy")) and everything in it, then re-opens the previous period as active. This can't be undone.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button class="danger-btn" @onclick="ConfirmRemovePeriod">Remove period</button>
                    </div>
                    break;

                case Modal.NextPeriod:
                    <h3>Start next month</h3>
                    <p class="hint">Enter what each fund really holds now (previous closing balance: <strong>@Fmt(State.Period.ExpectedClosingBalance)</strong>). The leftover carries in as a “From previous period” contribution.</p>
                    @foreach (var f in State.RootFunds)
                    {
                        <label>@f.Name <input type="number" step="0.01" @bind:get="GetRealOpening(f.Id)" @bind:set="v => SetRealOpening(f.Id, v)" /></label>
                    }
                    <label class="check"><input type="checkbox" @bind="_copyBudgets" /> Copy this period’s budgets forward</label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="ConfirmNextPeriod">Start next month →</button>
                    </div>
                    break;

                case Modal.EditExpense:
                    <h3>Edit expense</h3>
                    <label>Category
                        <select @bind="_categoryId">
                            @foreach (var (cat, depth) in State.CategoryOptions)
                            {
                                <option value="@cat.Id">@IndentLabel(cat.Name, depth)</option>
                            }
                        </select>
                    </label>
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_amount" /></label>
                    <label>Date <input type="date" @bind="_expenseDate" /></label>
                    <label>Fund
                        <select @bind="_fundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>Note (optional) <input type="text" @bind="_note" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveEditExpense" disabled="@(_amount <= 0)">Save</button>
                    </div>
                    break;

                case Modal.DeleteExpense:
                    <h3>Remove this expense?</h3>
                    @if (State.FindExpense(_editExpenseId) is { } ex)
                    {
                        <p class="hint">@ex.Date.ToString("dd MMM") · @State.CategoryName(ex.CategoryId) · @Fmt(ex.Amount)@(ex.IsFromSavings ? " — the savings drawdown will be restored." : "")</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteExpense">Remove</button>
                    </div>
                    break;

                case Modal.AddBucket:
                case Modal.EditBucket:
                    <h3>@(_modal == Modal.AddBucket ? "New savings bucket" : $"Edit {State.FindSavingBucket(_modalBucketId)?.Name}")</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <label>Goal amount (optional) <input type="number" step="0.01" min="0" @bind="_goalAmount" /></label>
                    <label>Alert at % <input type="number" step="1" min="0" max="100" @bind="_fThreshold" /></label>
                    <label class="check"><input type="checkbox" @bind="_fNotify" /> Notify on milestone</label>
                    @if (State.CanSetInitialSavings)
                    {
                        <label>Already saved (starting balance) <input type="number" step="0.01" min="0" @bind="_initialSavings" /></label>
                        <small class="hint">Money you already had in this bucket before using FinApp. It counts toward the balance and goal, but not toward your savings rate.</small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveBucket" disabled="@(string.IsNullOrWhiteSpace(_fName))">@(_modal == Modal.AddBucket ? "Add" : "Save")</button>
                    </div>
                    break;

                case Modal.EditDeposit:
                    <h3>@Loc["Edit deposit"]</h3>
                    <label>@Loc["Category"]
                        <select @bind="_editContribCategoryId">
                            @foreach (var cc in State.ContributionCategories)
                            {
                                <option value="@cc.Id">@cc.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Fund"]
                        <select @bind="_editContribFundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_editContribAmount" /></label>
                    <label>@Loc["Date"] <input type="date" @bind="_editContribDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditDeposit" disabled="@(_editContribAmount <= 0)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteDeposit:
                    <h3>@Loc["Delete deposit?"]</h3>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteDeposit">@Loc["Delete"]</button>
                    </div>
                    break;

                case Modal.ContribCat:
                    <h3>@(_contribCatId == Guid.Empty ? Loc["New contribution category"] : Loc["Rename category"])</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_contribCatName" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveContribCat" disabled="@(string.IsNullOrWhiteSpace(_contribCatName))">@(_contribCatId == Guid.Empty ? Loc["Add"] : Loc["Save"])</button>
                    </div>
                    break;

                case Modal.DeleteContribCat:
                    <h3>@Loc["Remove category?"]</h3>
                    @if (State.ContributionCategoryRemovalBlocker(_contribCatId) is { } ccBlocker)
                    {
                        <p class="hint">Can’t remove — @ccBlocker.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        <p class="hint">@Loc["This removes the category permanently."]</p>
                        <div class="modal-actions">
                            <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                            <button class="danger-btn" @onclick="ConfirmDeleteContribCat">@Loc["Remove"]</button>
                        </div>
                    }
                    break;

                case Modal.EditSavingDeposit:
                    <h3>Edit savings deposit — @State.SavingBucketName(_savingDepositBucketId)</h3>
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_savingDepositAmount" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveEditSavingDeposit" disabled="@(_savingDepositAmount <= 0)">Save</button>
                    </div>
                    break;

                case Modal.DeleteSavingDeposit:
                    <h3>Remove this savings deposit?</h3>
                    @if (State.FindSavingDeposit(_savingDepositId) is { } sd)
                    {
                        <p class="hint">@sd.Date.ToString("dd MMM") · @State.SavingBucketName(sd.SavingCategoryId) · @Fmt(sd.Amount)</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteSavingDeposit">Remove</button>
                    </div>
                    break;

                case Modal.DeleteBucket:
                    <h3>Remove @State.FindSavingBucket(_modalBucketId)?.Name?</h3>
                    @if (State.SavingBucketRemovalBlocker(_modalBucketId) is {} bucketBlocker)
                    {
                        <p class="hint">Can’t remove — @bucketBlocker. Spend or move its savings first.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">Close</button></div>
                    }
                    else
                    {
                        <p class="hint">This removes the empty bucket permanently.</p>
                        <div class="modal-actions">
                            <button class="ghost" @onclick="CloseModal">Cancel</button>
                            <button class="danger-btn" @onclick="ConfirmDeleteBucket">Remove</button>
                        </div>
                    }
                    break;

                case Modal.AddFund:
                    <h3>@(_fundParentId is { } pp ? $"New sub-fund under {State.FundName(pp)}" : "New fund")</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    @if (_fundParentId is null)
                    {
                        <label>Opening balance this period (optional) <input type="number" step="0.01" min="0" @bind="_openingAmount" /></label>
                    }
                    else
                    {
                        <label>Initial value (informational, optional) <input type="number" step="0.01" min="0" @bind="_openingAmount" /></label>
                        <small class="hint">Sub-fund values are informational only — they should add up to the parent but never affect totals.</small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveFund" disabled="@(string.IsNullOrWhiteSpace(_fName))">Add</button>
                    </div>
                    break;

                case Modal.EditFund:
                    <h3>Edit @State.FundName(_modalFundId)</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    @if (State.FindFund(_modalFundId)?.IsRoot == true)
                    {
                        <label>Opening balance this period <input type="number" step="0.01" min="0" @bind="_openingAmount" /></label>
                        <p class="hint">Changing the opening balance affects this period's reconciliation with the previous one.</p>
                    }
                    else
                    {
                        <label>Initial value (informational) <input type="number" step="0.01" min="0" @bind="_openingAmount" /></label>
                        <small class="hint">Informational only — should add up to the parent fund.</small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveFund" disabled="@(string.IsNullOrWhiteSpace(_fName))">Save</button>
                    </div>
                    break;

                case Modal.DeleteFund:
                    <h3>Remove @State.FundName(_modalFundId)?</h3>
                    @if (State.FundRemovalBlocker(_modalFundId) is {} fundBlocker)
                    {
                        <p class="hint">Can’t remove — @fundBlocker.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">Close</button></div>
                    }
                    else
                    {
                        @if (State.FundHasOpeningBalance(_modalFundId))
                        {
                            <p class="hint">This fund has an opening balance. Move it to another fund, or remove it as-is (the balance is dropped).</p>
                            <label>Move balance to
                                <select @bind="_moveBalanceToId">
                                    <option value="@Guid.Empty">— don't move —</option>
                                    @foreach (var f in State.RootFunds.Where(f => f.Id != _modalFundId))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </select>
                            </label>
                        }
                        else
                        {
                            <p class="hint">This removes the fund permanently.</p>
                        }
                        <div class="modal-actions">
                            <button class="ghost" @onclick="CloseModal">Cancel</button>
                            <button class="danger-btn" @onclick="ConfirmDeleteFund">Remove</button>
                        </div>
                    }
                    break;

                case Modal.EditTransfer:
                    <h3>Edit transfer</h3>
                    <label>From
                        <select @bind="_editTransferFromId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>To
                        <select @bind="_editTransferToId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_editTransferAmount" /></label>
                    <label>Note (optional) <input type="text" @bind="_editTransferNote" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveEditTransfer" disabled="@(_editTransferAmount <= 0 || _editTransferFromId == _editTransferToId)">Save</button>
                    </div>
                    break;

                case Modal.DeleteTransfer:
                    <h3>Remove this transfer?</h3>
                    @if (State.FindFundTransfer(_editTransferId) is { } tr)
                    {
                        <p class="hint">@tr.Date.ToString("dd MMM") · @State.FundName(tr.FromFundId) → @State.FundName(tr.ToFundId) · @Fmt(tr.Amount)</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteTransfer">Remove</button>
                    </div>
                    break;

                case Modal.EditPeriod:
                    <h3>Edit period dates</h3>
                    <label>From <input type="date" @bind="_periodFrom" /></label>
                    <label>To <input type="date" @bind="_periodTo" /></label>
                    <p class="hint">Later periods shift to stay contiguous, keeping their own lengths.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveEditPeriod" disabled="@(_periodTo < _periodFrom)">Save</button>
                    </div>
                    break;

                case Modal.EditSavingMovement:
                    <h3>Edit savings movement</h3>
                    @if (State.FindSavingMovement(_savingMovementId) is { } mv)
                    {
                        <p class="hint">@State.SavingMovementTarget(mv)</p>
                    }
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_savingMovementAmount" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button @onclick="SaveEditSavingMovement" disabled="@(_savingMovementAmount <= 0)">Save</button>
                    </div>
                    break;

                case Modal.DeleteSavingMovement:
                    <h3>Undo this savings movement?</h3>
                    @if (State.FindSavingMovement(_savingMovementId) is { } mvd)
                    {
                        <p class="hint">@mvd.Date.ToString("dd MMM") · @State.SavingMovementTarget(mvd) · @Fmt(State.Money(-mvd.Amount.Amount)). @(mvd.BudgetCategoryId is not null ? "The funded budget is reduced by this amount." : "Both buckets are restored.")</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteSavingMovement">Undo</button>
                    </div>
                    break;

                case Modal.DeleteExternalTransfer:
                    <h3>Remove this outgoing transfer?</h3>
                    @if (State.FindExternalTransfer(_extTransferId) is { } et)
                    {
                        <p class="hint">@et.Date.ToString("dd MMM") · @State.FundName(et.FundId) → @State.AccountName(et.ToAccountId ?? Guid.Empty) · @Fmt(et.Amount)</p>
                    }
                    <p class="hint warn-text">This only removes the outflow on this side. It does not reverse the deposit already recorded in the other account.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">Cancel</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteExternalTransfer">Remove</button>
                    </div>
                    break;
            }
        </div>
    </div>
}
}

@code {
    private enum Modal { None, AddCat, EditCat, DeleteCat, AddAccount, EditAccount, DeleteAccount, AddExpense, NextPeriod, RemovePeriod, EditExpense, DeleteExpense, AddBucket, EditBucket, DeleteBucket, AddFund, EditFund, DeleteFund, Invite, EditDeposit, DeleteDeposit, ContribCat, DeleteContribCat, EditSavingDeposit, DeleteSavingDeposit, EditTransfer, DeleteTransfer, EditPeriod, EditSavingMovement, DeleteSavingMovement, DeleteExternalTransfer }
    private enum Tab { Account, Budgets, Expenses, Savings }

    private Tab _tab = Tab.Account;

    private Guid _categoryId;
    private decimal _amount;
    private Guid _fundId;
    private string? _note;
    private DateOnly _expenseDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _dayView;   // when set, the Expenses tab focuses a single day

    private Guid _transferFromId;
    private Guid _transferDestId;   // a fund or another account
    private decimal _transferAmount;
    private string? _transferNote;

    private Guid _editTransferId;
    private Guid _editTransferFromId;
    private Guid _editTransferToId;
    private decimal _editTransferAmount;
    private string? _editTransferNote;
    private Guid _modalFundId;
    private Guid? _fundParentId;
    private decimal _openingAmount;
    private Guid _moveBalanceToId;

    private Guid _depCategoryId;
    private Guid _depFundId;
    private decimal _depAmount;
    private DateOnly _depDate = DateOnly.FromDateTime(DateTime.Today);
    private bool _depShowDetails;

    private Guid _coverBucketId;
    private decimal _coverAmount;

    private Guid _editContribId;
    private Guid _editContribCategoryId;
    private Guid _editContribFundId;
    private decimal _editContribAmount;
    private DateOnly _editContribDate;

    private Guid _contribCatId;
    private string? _contribCatName;

    private Guid _savingDepositId;
    private Guid _savingDepositBucketId;
    private decimal _savingDepositAmount;

    private DateOnly _periodFrom;
    private DateOnly _periodTo;

    private Guid _extTransferId;

    private Guid _savingMovementId;
    private decimal _savingMovementAmount;

    private Guid _savingBucketId;
    private decimal _savingAmount;
    private bool _copyBudgets = true;

    private Guid _spendBucketId;
    private Guid _spendDestId;
    private decimal _spendAmount;

    private Guid _spendExpBucketId;
    private Guid _spendExpCategoryId;
    private decimal _spendExpAmount;

    private Guid _editExpenseId;
    private Guid _modalBucketId;
    private decimal _goalAmount;
    private decimal _initialSavings;

    private string? _inviteUsername;
    private string? _inviteMessage;

    // Per-fund real opening balances entered on "Start next month".
    private readonly Dictionary<Guid, decimal> _realOpenings = new();
    private decimal GetRealOpening(Guid id) => _realOpenings.GetValueOrDefault(id);
    private void SetRealOpening(Guid id, decimal v) => _realOpenings[id] = v;

    // Modal state
    private Modal _modal = Modal.None;
    private Guid _modalCatId;
    private Guid? _addParentId;
    private string? _fName;
    private decimal _fBudget;
    private decimal _fThreshold = 80;
    private bool _fNotify;
    private string? _fCurrency = "EUR";

    private string? _error;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnChanged;
        Loc.Changed += OnLocChanged;
        await State.InitializeAsync();
        ResetPickers();
    }

    private void OnChanged() { ResetPickers(); InvokeAsync(StateHasChanged); }
    private void OnLocChanged() => InvokeAsync(StateHasChanged);

    // --- Expenses day view -----------------------------------------------
    private void GoToDay(DateOnly d)
    {
        if (d < State.Period.From) d = State.Period.From;
        else if (d > State.Period.To) d = State.Period.To;
        _dayView = d;
        _expenseDate = d;
    }

    private void PrevDay() { if (_dayView is { } d && d > State.Period.From) GoToDay(d.AddDays(-1)); }
    private void NextDay() { if (_dayView is { } d && d < State.Period.To) GoToDay(d.AddDays(1)); }

    private void ResetPickers()
    {
        if (!State.IsReady || !State.HasAccounts) return;
        _dayView = null;
        _categoryId = State.AllCategories.FirstOrDefault()?.Id ?? Guid.Empty;
        _savingBucketId = State.SavingBuckets.FirstOrDefault().Bucket?.Id ?? Guid.Empty;
        _spendBucketId = _savingBucketId;
        _spendDestId = _categoryId;
        _spendExpBucketId = _savingBucketId;
        _spendExpCategoryId = _categoryId;
        _fundId = State.RootFunds.FirstOrDefault()?.Id ?? Guid.Empty;
        _depCategoryId = State.ContributionCategories.FirstOrDefault()?.Id ?? Guid.Empty;
        _depFundId = _fundId;
        _depDate = DateOnly.FromDateTime(DateTime.Today);
        _transferFromId = _fundId;
        _transferDestId = State.RootFunds.Skip(1).FirstOrDefault()?.Id
            ?? State.TransferableAccounts.FirstOrDefault()?.Id ?? Guid.Empty;
        _coverBucketId = _savingBucketId;
        _coverAmount = State.HasUnallocatedShortfall ? State.UnallocatedShortfall.Amount : 0m;
    }

    private async Task Run(Func<Task> action)
    {
        if (_busy) return;                 // ignore re-entrant clicks while a save is already in flight
        _error = null;
        _busy = true;
        StateHasChanged();                 // paint the "Saving…" state before the (networked) round-trip
        await Task.Yield();
        try { await action(); }
        catch (Exception ex) { _error = Describe(ex); }
        finally { _busy = false; }
    }

    /// <summary>Turn an exception into a message a person can act on (instead of raw .NET text).</summary>
    private static string Describe(Exception ex) => ex switch
    {
        ApiException { Status: System.Net.HttpStatusCode.Conflict } =>
            "Someone else updated this account just now. Reload and try again.",
        ApiException { Status: System.Net.HttpStatusCode.Unauthorized } =>
            "Your session has expired — please sign out and back in.",
        ApiException api => api.Message,
        HttpRequestException => "Couldn’t reach the server. Check your connection and try again.",
        _ => ex.Message,
    };

