    private Task MoveSaving() => Run(async () =>
    {
        if (_spendAmount <= 0 || _spendDestId == Guid.Empty || _spendDestId == _spendBucketId) return;
        if (_spendDestId == BudgetingState.CarryoverCategoryId)
            await State.CoverCarryoverFromSavings(_spendBucketId, _spendAmount);
        else if (State.SavingBuckets.Any(b => b.Bucket.Id == _spendDestId))
            await State.MoveSavingToBucket(_spendBucketId, _spendDestId, _spendAmount, null);
        else
            await State.ConvertSavingToBudget(_spendBucketId, _spendDestId, _spendAmount, "From savings");
        _spendAmount = 0;
    });

