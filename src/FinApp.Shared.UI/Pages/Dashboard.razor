    // Merchant rules + per-row picks (feature 2.3). Rules keyed by normalized merchant; picks keyed by transaction id.
    private Dictionary<string, (string Kind, Guid TargetId)> _bankMappings = new();
    private readonly Dictionary<string, Guid> _bankRowCat = new();      // debit → category
