    private void OpenAddFund()
    {
        _modalFundId = Guid.Empty; _fName = null; _fundNote = null; _openingAmount = 0; _modal = Modal.AddFund;
    }

    private void OpenEditFund(Guid fundId)
    {
        _modalFundId = fundId;
        _fName = State.FundName(fundId);
        _fundNote = State.FundNote(fundId);
        _openingAmount = State.FundOpeningBalance(fundId).Amount;
        _modal = Modal.EditFund;
    }

    private Task SaveFund() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        if (_modal == Modal.AddFund)
        {
            var id = await State.AddFund(_fName!, _fundNote);
            if (_openingAmount > 0)
                await State.SetFundOpeningBalance(id, _openingAmount);
        }
        else
        {
            await State.RenameFund(_modalFundId, _fName!);
            await State.SetFundNote(_modalFundId, _fundNote);
            await State.SetFundOpeningBalance(_modalFundId, _openingAmount);
        }
        CloseModal();
    });

    private void OpenDeleteFund(Guid fundId)
    {
        _modalFundId = fundId;
        _moveBalanceToId = Guid.Empty; // default: don't move (transfer is opt-in)
        _modal = Modal.DeleteFund;
    }

    private Task ConfirmDeleteFund() => RunModal(async () =>
    {
        Guid? moveTo = _moveBalanceToId == Guid.Empty ? null : _moveBalanceToId;
        await State.RemoveFund(_modalFundId, moveTo);
        CloseModal();
    });

    private bool CanTransfer =>
        State.IsPeriodOpen && State.RootFunds.Any() && (State.RootFunds.Count > 1 || State.TransferableAccounts.Any());

    /// <summary>True when the transfer destination is another account (an outflow), not one of this account's funds.</summary>
    private bool TransferDestIsAccount => State.TransferableAccounts.Any(a => a.Id == _transferDestId);

    /// <summary>Hard cap for the inline transfer form: the fund's physical balance (you can't move money that isn't there).
    /// Dipping into the savings earmark is allowed — surfaced as a warning, not a block.</summary>
    private decimal InlineTransferMax => State.FundBalance(_transferFromId).Amount;

    /// <summary>True when an account send would draw on money earmarked for savings (allowed, but warned).</summary>
    private bool InlineTransferDipsSavings => TransferDestIsAccount
        && _transferAmount > State.AvailableToTransferOutFromFund(_transferFromId).Amount
        && _transferAmount <= InlineTransferMax;

    /// <summary>This period's fund-to-fund transfers and out-to-account transfers, merged newest-first.</summary>
    private List<(DateOnly Date, string Label, Money Amount, Guid Id, bool IsExternal, string? Note)> MergedTransfers() =>
        State.FundTransfers
            .Select(t => (t.Date, Label: $"{State.FundName(t.FromFundId)} → {State.FundName(t.ToFundId)}", t.Amount, t.Id, IsExternal: false, t.Note))
            .Concat(State.ExternalTransfers
                .Select(t => (t.Date, Label: $"📤 {State.FundName(t.FundId)} → {State.AccountName(t.ToAccountId ?? Guid.Empty)}", t.Amount, t.Id, IsExternal: true, t.Note)))
            .OrderByDescending(t => t.Date)
            .ToList();

    private Task DoTransfer() => Run(async () =>
    {
        if (_transferAmount <= 0 || _transferDestId == Guid.Empty || _transferDestId == _transferFromId) return;
        if (State.TransferableAccounts.Any(a => a.Id == _transferDestId))
            await State.TransferToAccount(_transferDestId, _transferFromId, _transferAmount, null, _transferDestFundId);
        else
            await State.TransferFunds(_transferFromId, _transferDestId, _transferAmount, null);
        _transferAmount = 0;
    });

    // --- Destination-fund pickers for cross-account transfers (feature 4) ---
    private IReadOnlyList<FinApp.Domain.Funds.Fund> DestFundsFor(Guid accountId) =>
        _destFunds.TryGetValue(accountId, out var funds) ? funds : [];

    private async Task EnsureDestFunds(Guid accountId)
    {
        if (accountId == Guid.Empty || _destFunds.ContainsKey(accountId)) return;
        try { _destFunds[accountId] = await State.LoadAccountFundsAsync(accountId); }
        catch { _destFunds[accountId] = []; }
        StateHasChanged();
    }

    private async Task OnInlineDestChanged()
    {
        if (!TransferDestIsAccount) { _transferDestFundId = Guid.Empty; return; }
        await EnsureDestFunds(_transferDestId);
        _transferDestFundId = DestFundsFor(_transferDestId).FirstOrDefault()?.Id ?? Guid.Empty;
    }

    private async Task OnModalDestChanged()
    {
        if (!MTransferDestIsAccount) { _mTransferDestFundId = Guid.Empty; return; }
        await EnsureDestFunds(_mTransferDestId);
        _mTransferDestFundId = DestFundsFor(_mTransferDestId).FirstOrDefault()?.Id ?? Guid.Empty;
    }

    /// <summary>Icon for a savings-activity movement row: ➡️ for a move into a budget, 🔁 for a bucket-to-bucket transfer.</summary>
    private static string MovementIcon(FinApp.Domain.Savings.SavingAllocation m) =>
        m.BudgetCategoryId is not null ? "➡️" : "🔁";

    // --- Per-fund operation popups ----------------------------------------

    private async Task OpenTransferFromFund(Guid fundId)
    {
        _mTransferFromId = fundId;
        _mTransferDestId = State.RootFunds.FirstOrDefault(f => f.Id != fundId)?.Id
            ?? State.TransferableAccounts.FirstOrDefault()?.Id ?? Guid.Empty;
        _mTransferAmount = 0;
        _mTransferDestFundId = Guid.Empty;
        _modal = Modal.Transfer;
        if (MTransferDestIsAccount) await OnModalDestChanged();
    }

    private bool MTransferDestIsAccount => State.TransferableAccounts.Any(a => a.Id == _mTransferDestId);

    /// <summary>Hard cap for the per-fund transfer popup: the fund's physical balance. Dipping into savings is warned, not blocked.</summary>
    private decimal MTransferMax => State.FundBalance(_mTransferFromId).Amount;

    private bool MTransferDipsSavings => MTransferDestIsAccount
        && _mTransferAmount > State.AvailableToTransferOutFromFund(_mTransferFromId).Amount
        && _mTransferAmount <= MTransferMax;

    private Task ConfirmTransfer() => RunModal(async () =>
    {
        if (_mTransferAmount <= 0 || _mTransferDestId == Guid.Empty || _mTransferDestId == _mTransferFromId) return;
        if (MTransferDestIsAccount)
            await State.TransferToAccount(_mTransferDestId, _mTransferFromId, _mTransferAmount, null, _mTransferDestFundId);
        else
            await State.TransferFunds(_mTransferFromId, _mTransferDestId, _mTransferAmount, null);
        CloseModal();
    });

    private void OpenDepositToFund(Guid fundId)
    {
        _depCategoryId = State.ContributionCategories.FirstOrDefault()?.Id ?? Guid.Empty;
        _depFundId = fundId;
        _depAmount = 0;
        _depDate = DateOnly.FromDateTime(DateTime.Today);
        _modal = Modal.Deposit;
    }

    private void OpenEditTransfer(Guid id)
    {
        if (State.FindFundTransfer(id) is not { } t) return;
        _editTransferId = id;
        _editTransferFromId = t.FromFundId; _editTransferToId = t.ToFundId;
        _editTransferAmount = t.Amount.Amount; _editTransferNote = t.Note;
        _modal = Modal.EditTransfer;
    }

    private Task SaveEditTransfer() => RunModal(async () =>
    {
        if (_editTransferAmount <= 0 || _editTransferFromId == _editTransferToId) return;
        await State.EditFundTransfer(_editTransferId, _editTransferFromId, _editTransferToId, _editTransferAmount, _editTransferNote);
        CloseModal();
    });

    private void OpenDeleteTransfer(Guid id) { _editTransferId = id; _modal = Modal.DeleteTransfer; }

    private Task ConfirmDeleteTransfer() => RunModal(async () =>
    {
        await State.RemoveFundTransfer(_editTransferId);
        CloseModal();
    });

    private void OpenDeleteExternalTransfer(Guid id) { _extTransferId = id; _modal = Modal.DeleteExternalTransfer; }

    private Task ConfirmDeleteExternalTransfer() => RunModal(async () =>
    {
        await State.RemoveExternalTransfer(_extTransferId);
        CloseModal();
    });

    // --- Modals -----------------------------------------------------------

    private void OpenAdd(Guid? parentId)
    {
        _addParentId = parentId; _fName = null; _fBudget = 0; _modal = Modal.AddCat;
    }

    private void OpenAddSub(Guid parentId) => OpenAdd(parentId);

    private void OpenEdit(Guid categoryId)
    {
        _modalCatId = categoryId;
        _fName = State.CategoryName(categoryId);
        var b = State.BudgetFor(categoryId);
        _fBudget = b?.Allocated.Amount ?? 0;
        _fThreshold = (b?.AlertThreshold ?? 0.80m) * 100m;
        _fNotify = b?.NotifyOnEveryExpense ?? false;
        _modal = Modal.EditCat;
    }

    private void OpenDelete(Guid categoryId) { _modalCatId = categoryId; _modal = Modal.DeleteCat; }
    private void OpenAddAccount() { _fName = null; _fCurrency = State.Currency; _modal = Modal.AddAccount; }
    private void OpenEditAccount() { _fName = State.Account.Name; _modal = Modal.EditAccount; }
    private void OpenDeleteAccount() => _modal = Modal.DeleteAccount;
    private void OpenInvite() { _inviteUsername = null; _inviteMessage = null; _modal = Modal.Invite; }
    private void CloseModal() { _modal = Modal.None; _modalError = null; }

    private Task SendInvite() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_inviteUsername)) return;
        await State.InviteToCurrentAccount(_inviteUsername!.Trim());
        _inviteMessage = $"Invitation sent to {_inviteUsername!.Trim()}.";
        _inviteUsername = null;
    });

    private Task SaveEditAccount() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        await State.RenameAccount(_fName!);
        CloseModal();
    });

    private Task ConfirmDeleteAccount() => RunModal(async () =>
    {
        await State.RemoveAccount(State.CurrentAccountId);
        CloseModal();
    });

    private Task SaveAddCat() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        var newId = await State.AddCategory(_fName!, _addParentId);
        if (_fBudget > 0)
            await State.SaveBudget(newId, _fBudget, 80, false);
        CloseModal();
    });

    private Task SaveEditCat() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        await State.RenameCategory(_modalCatId, _fName!);
        if (_fBudget > 0)
            await State.SaveBudget(_modalCatId, _fBudget, _fThreshold, _fNotify);
        CloseModal();
    });

    private Task RemoveBudget() => RunModal(async () =>
    {
        await State.RemoveBudget(_modalCatId);
        CloseModal();
    });

    private Task ConfirmDelete() => RunModal(async () =>
    {
        await State.RemoveCategory(_modalCatId);
        CloseModal();
    });

    private Task SaveAddAccount() => RunModal(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        await State.AddAccount(_fName!, string.IsNullOrWhiteSpace(_fCurrency) ? "EUR" : _fCurrency!);
        CloseModal();
    });

    private Task CreateFirstAccount() => Run(async () =>
    {
        if (string.IsNullOrWhiteSpace(_fName)) return;
        await State.AddAccount(_fName!, string.IsNullOrWhiteSpace(_fCurrency) ? "EUR" : _fCurrency!);
    });

    private static string Fmt(Money m)
    {
        var symbol = m.Currency switch { "EUR" => "€", "USD" => "$", "GBP" => "£", _ => m.Currency + " " };
        return $"{symbol}{m.Amount:N2}";
    }

    /// <summary>Indent a category name in a flat &lt;select&gt; so the tree shape reads (sub-categories under parents).</summary>
    private static string IndentLabel(string name, int depth) =>
        depth == 0 ? name : new string(' ', depth * 3) + "↳ " + name;

    private static string PctOrDash(decimal? ratio) =>
        ratio is { } r ? $"{decimal.Round(r * 100m, 0, MidpointRounding.AwayFromZero)}%" : "—";

    public void Dispose() { State.Changed -= OnChanged; Loc.Changed -= OnLocChanged; }
}
