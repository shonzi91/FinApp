    private string? _error;
    private string? _modalError;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnChanged;
        Loc.Changed += OnLocChanged;
        await State.InitializeAsync();
        ResetPickers();

        // On phones, open the Expenses tab first so adding an expense is one tap away.
        try { if (await JS.InvokeAsync<int>("finappViewportWidth") is > 0 and <= 720) ShowExpensesTab(); }
        catch { /* host without the helper (e.g. MAUI) — stay on Account */ }

        await LoadBankAsync();
        await HandleBankReturnAsync();
    }

    // --- Bank sync (Open Banking) ----------------------------------------
    /// <summary>Fetch the account's bank-sync status and any staged transactions (silent if the feature is off).</summary>
    private async Task LoadBankAsync()
    {
        if (!State.HasAccounts) return;
        _bankAccountId = State.CurrentAccountId;   // the account this status/pending belongs to
        try
        {
            _bankStatus = await State.GetBankStatus();
            if (_bankStatus.Connected)
            {
                _bankPending = await State.GetPendingBankTransactions();
                _bankMappings = (await State.GetBankMappings()).ToDictionary(m => m.MatchKey, m => (m.Kind, m.TargetId));
            }
            else { _bankPending = []; _bankMappings = new(); }
            DefaultBankPickers();
        }
        catch { _bankStatus = null; } // unreachable/unconfigured — hide the panel/tab entirely
    }

    /// <summary>Open the Bank tab, refreshing the connection for the current account (it's per-account).</summary>
    private async Task ShowBankTab()
    {
        _tab = Tab.Bank;
        await LoadBankAsync();
    }

    /// <summary>Staged transactions in the viewed period (feature 2.4), skipping €0 / informational entries.</summary>
    private List<PendingBankTransactionDto> BankRowsForPeriod() =>
        _bankPending.Where(t => t.Amount != 0 && t.Date >= State.Period.From && t.Date <= State.Period.To).ToList();

    /// <summary>After returning from the bank's consent page (/?bank=linked|error), land on the Bank tab and pull transactions.</summary>
    private async Task HandleBankReturnAsync()
    {
        var query = new Uri(Nav.Uri).Query;
        if (!query.Contains("bank=", StringComparison.Ordinal)) return;
        _tab = Tab.Bank;
        if (query.Contains("bank=linked", StringComparison.Ordinal))
        {
            await LoadBankAsync();
            if (_bankStatus?.Connected == true) await SyncBankAsync();
        }
        else
        {
            _bankError = Loc["Couldn’t link your bank. Please try again."];
        }
        Nav.NavigateTo(Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0] is { Length: > 0 } p ? p : "/", replace: true);
    }

    private void DefaultBankPickers()
    {
        var firstCat = State.CategoryOptions.FirstOrDefault().Category?.Id ?? Guid.Empty;
        var firstFund = State.RootFunds.FirstOrDefault()?.Id ?? Guid.Empty;
        _bankRowCat.Clear(); _bankRowFund.Clear(); _bankRowCredit.Clear();
        foreach (var t in _bankPending)
        {
            var mapped = MappingFor(t.Description);
            _bankRowCat[t.ExternalId] = mapped is { Kind: "category" } m && State.CategoryOptions.Any(c => c.Category.Id == m.TargetId) ? m.TargetId : firstCat;
            _bankRowFund[t.ExternalId] = firstFund;
            _bankRowCredit[t.ExternalId] = mapped is { Kind: "fund" or "contributor" } cm ? $"{cm.Kind}:{cm.TargetId}" : "";
        }
    }

    private (string Kind, Guid TargetId)? MappingFor(string description) =>
        _bankMappings.TryGetValue(BudgetingState.BankMatchKey(description), out var m) ? m : null;

    private Guid RowCat(string id) => _bankRowCat.TryGetValue(id, out var v) ? v : Guid.Empty;
    private Guid RowFund(string id) => _bankRowFund.TryGetValue(id, out var v) ? v : Guid.Empty;
    private string RowCredit(string id) => _bankRowCredit.TryGetValue(id, out var v) ? v : "";

    private async Task LinkBankAsync()
    {
        _bankBusy = true; _bankError = null;
        try
        {
            var banks = await State.GetBankInstitutions();
            if (banks.FirstOrDefault() is not { } revolut)
            {
                _bankError = Loc["No Revolut connection is available for your country yet."];
                return;
            }
            var url = await State.StartBankLink(revolut.Name, revolut.Country);
            await JS.InvokeVoidAsync("finappNavigate", url);   // full-page hop to the bank's consent page
        }
        catch (Exception ex) { _bankError = ex.Message; }
        finally { _bankBusy = false; }
    }

    private async Task SyncBankAsync()
    {
        _bankBusy = true; _bankError = null;
        try
        {
            await State.SyncBank();
            _bankPending = await State.GetPendingBankTransactions();
            DefaultBankPickers();
        }
        catch (Exception ex) { _bankError = ex.Message; }
        finally { _bankBusy = false; }
    }

    private async Task DisconnectBankAsync()
    {
        _bankBusy = true; _bankError = null;
        try
        {
            await State.DisconnectBank();
            _bankPending = [];
            await LoadBankAsync();   // refresh status → panel returns to the "Link Revolut" state
        }
        catch (Exception ex) { _bankError = ex.Message; }
        finally { _bankBusy = false; }
    }

    private async Task ConfirmBankRow(PendingBankTransactionDto tx)
    {
        var cat = RowCat(tx.ExternalId);
        var fund = RowFund(tx.ExternalId);
        if (cat == Guid.Empty || fund == Guid.Empty) { _bankError = Loc["Pick a category and fund first."]; return; }
        _bankBusy = true; _bankError = null;
        try
        {
            await State.ConfirmBankTransaction(tx.ExternalId, cat, Math.Abs(tx.Amount), fund, tx.Description, ClampToPeriod(tx.Date));
            _bankPending.RemoveAll(p => p.ExternalId == tx.ExternalId);
        }
        catch (Exception ex) { _bankError = ex.Message; }
        finally { _bankBusy = false; }
    }

    private async Task DismissBankRow(PendingBankTransactionDto tx)
    {
        _bankBusy = true; _bankError = null;
        try
        {
            await State.DismissBankTransaction(tx.ExternalId);
            _bankPending.RemoveAll(p => p.ExternalId == tx.ExternalId);
        }
        catch (Exception ex) { _bankError = ex.Message; }
        finally { _bankBusy = false; }
    }

    // --- Merchant mapping (feature 2.3) -----------------------------------
    /// <summary>Remember the current pick for this merchant so future imports pre-fill it. Debits map to the
    /// chosen category; credits map to the chosen fund/contributor (kept for when credits become entries).</summary>
    private async Task RememberMapping(PendingBankTransactionDto tx)
    {
        _bankBusy = true; _bankError = null;
        try
        {
            string kind; Guid target;
            if (tx.Amount < 0) { kind = "category"; target = RowCat(tx.ExternalId); }
            else
            {
                var (k, t) = ParseCredit(RowCredit(tx.ExternalId));
                kind = k; target = t;
            }
            if (target == Guid.Empty) { _bankError = Loc["Pick something to map to first."]; return; }
            await State.SetBankMapping(tx.Description, kind, target);
            _bankMappings[BudgetingState.BankMatchKey(tx.Description)] = (kind, target);
        }
        catch (Exception ex) { _bankError = ex.Message; }
        finally { _bankBusy = false; }
    }

    /// <summary>One toggle for the merchant rule: save the current pick, or clear an existing rule.</summary>
    private Task TogglePin(PendingBankTransactionDto tx) =>
        MappingFor(tx.Description) is null ? RememberMapping(tx) : ForgetMapping(tx);

    private async Task ForgetMapping(PendingBankTransactionDto tx)
    {
        _bankBusy = true; _bankError = null;
        try
        {
            await State.RemoveBankMapping(tx.Description);
            _bankMappings.Remove(BudgetingState.BankMatchKey(tx.Description));
        }
        catch (Exception ex) { _bankError = ex.Message; }
        finally { _bankBusy = false; }
    }

    private static (string Kind, Guid Target) ParseCredit(string v) =>
        v.Split(':') is [{ } k, { } g] && Guid.TryParse(g, out var id) ? (k, id) : ("fund", Guid.Empty);

    /// <summary>The friendly name of a saved mapping's target (for the chip), or null if none.</summary>
    private string? MappedLabel(string description)
    {
        if (MappingFor(description) is not { } m) return null;
        return m.Kind switch
        {
            "category" => State.CategoryName(m.TargetId),
            "fund" => State.FundName(m.TargetId),
            "contributor" => State.MemberName(m.TargetId),
            _ => null,
        };
    }

    /// <summary>Open the Spending tab focused on today's expenses (clamped into the current period).</summary>
    private void ShowExpensesTab()
    {
        _tab = Tab.Budgets;
        _calendar = false;
