                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveFund" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Add"]</button>
                    </div>
                    break;

                case Modal.EditFund:
                    <h3>@State.FundIcon(_modalFundId) @Loc["Edit"] @State.FundName(_modalFundId)</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_fName" /></label>
                    @iconPicker
                    <label>@Loc["Note (optional)"] <input type="text" @bind="_fundNote" /></label>
                    <label>@Loc["Opening balance this period"] <input type="text" inputmode="text" @bind:get="_openingAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)" @bind:set="v => _openingAmount = EvalSum(v)" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveFund" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteFund:
                    <h3>@Loc["Remove"] @State.FundName(_modalFundId)?</h3>
                    @if (State.FundRemovalBlocker(_modalFundId) is {} fundBlocker)
