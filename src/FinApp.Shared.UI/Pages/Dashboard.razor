    private void ResetPickers()
    {
        if (!State.IsReady || !State.HasAccounts) return;
        // Keep the focused day across saves (feature 6) — only re-clamp it into the current period's range.
        if (_dayView is { } dv) _dayView = ClampToPeriod(dv);
        _categoryId = State.AllCategories.FirstOrDefault()?.Id ?? Guid.Empty;
