@page "/"
@implements IDisposable
@inject BudgetingState State
@inject Localizer Loc
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (_busy)
{
    <div class="saving-pill"><Spinner Text="@Loc["Saving…"]" /></div>
}

@if (!State.IsReady)
{
    <div class="loading"><Spinner Block="true" Text="@Loc["Loading…"]" /></div>
}
else if (!State.HasAccounts)
{
    <div class="firstrun">
        <div class="firstrun-mascot"><TandemLogo /></div>
        <h1>@Loc["Welcome to TandemTab"]</h1>
        <p class="firstrun-lead">@Loc["Let’s feather your nest. Create your first account to get started (e.g. Personal, Shared, Family)."]</p>
        <InvitationsPanel />
        @if (_error is not null)
        {
            <div class="alert warn-bg"><span>@_error</span><button class="alert-x" title="@Loc["Dismiss"]" @onclick="() => _error = null">×</button></div>
        }
        <div class="firstrun-form">
            <label>@Loc["Account name"] <input type="text" placeholder="Personal" @bind="_fName" /></label>
            <label>@Loc["Currency"] <input type="text" maxlength="3" @bind="_fCurrency" /></label>
            <label>@Loc["Savings target (%)"] <input type="number" min="0" max="100" @bind="_fSavingsTarget" /></label>
            <button @onclick="CreateFirstAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Create account"]</button>
        </div>
        <small class="hint">@Loc["It starts with a few starter categories and the current month’s period — you can change everything."]</small>
    </div>
}
else
{
<div class="dash @(_busy ? "is-busy" : "")">
    <header class="dash-head">
        <div class="head-main">
            <div class="acct-bar">
                <div class="acct-picker">
                    <select class="acct-select" value="@State.CurrentAccountId" @onchange="OnAccountChange">
                        @foreach (var a in State.Accounts)
                        {
                            <option value="@a.Id">@a.Name</option>
                        }
                    </select>
                </div>
                <span class="acct-ops">
                    <button class="link" title="@Loc["Add a new account"]" @onclick="OpenAddAccount">➕</button>
                    <span class="acct-menu">
                        <button class="link" title="@Loc["Account actions"]" @onclick="() => _acctMenuOpen = !_acctMenuOpen">⚙️</button>
                        @if (_acctMenuOpen)
                        {
                            <div class="acct-menu-backdrop" @onclick="() => _acctMenuOpen = false"></div>
                            <div class="acct-menu-pop">
                                @if (State.IsOwnerOfCurrent)
                                {
                                    <button @onclick="() => RunAcct(OpenEditAccount)">✏️ @Loc["Rename account"]</button>
                                }
                                <button @onclick="MenuExport">📊 @Loc["Export to Excel"]</button>
                                @if (State.IsOwnerOfCurrent)
                                {
                                    <button class="danger" @onclick="() => RunAcct(OpenDeleteAccount)">🗑️ @Loc["Delete account"]</button>
                                }
                                else
                                {
                                    <span class="acct-menu-note">@Loc["You were invited to this account"]</span>
                                }
                            </div>
                        }
                    </span>
                </span>
            </div>
            <div class="period-nav">
                <button class="nav @(State.CanGoPrev ? "" : "nav-hidden")" title="@Loc["Previous period"]" @onclick="State.GoPrev" disabled="@(!State.CanGoPrev)">‹</button>
                <div class="period-row">
                    <button class="period period-btn" title="@Loc["Edit period dates"]" @onclick="OpenEditPeriod">@State.Period.From.ToString("dd MMM") – @State.Period.To.ToString("dd MMM yyyy")</button>
                    <span class="period-ops">
                        @if (State.IsLatestPeriod && State.PeriodCount > 1)
                        {
                            <button class="exp-edit" title="@Loc["Remove this period and reopen the previous one"]" @onclick="OpenRemovePeriod">🗑️</button>
                        }
                        @if (State.IsLatestPeriod)
                        {
                            <button class="exp-edit" title="@Loc["Start next month"]" @onclick="OpenNextPeriod">⏭️</button>
                        }
                    </span>
                </div>
                <button class="nav @(State.CanGoNext ? "" : "nav-hidden")" title="@Loc["Next period"]" @onclick="State.GoNext" disabled="@(!State.CanGoNext)">›</button>
            </div>
        </div>
        <div class="head-right">
            <span class="status">@Loc[State.IsPeriodOpen ? "Active" : "Closed"]</span>
            <div class="balances">
                <span class="bal bal-current">
                    <span class="bal-label">@Loc[State.IsPeriodOpen ? "Current" : "Closed on"]</span>
                    <strong>@Fmt(State.ClosingBalance)</strong>
                    @if (State.IsPeriodOpen)
                    {
                        <span class="bal-free @(State.IsOverAllocated ? "warn-text" : "")">@Fmt(State.FreeToAllocate) @Loc["free"]</span>
                    }
                </span>
            </div>
        </div>
    </header>

    <InvitationsPanel />

    @if (_error is not null)
    {
        <div class="alert warn-bg"><strong>@Loc["Couldn’t do that."]</strong> <span>@_error</span><button class="alert-x" title="@Loc["Dismiss"]" @onclick="() => _error = null">×</button></div>
    }

    <nav class="tabs">
        <button class="tab @(_tab == Tab.Overview ? "active" : "")" @onclick="() => _tab = Tab.Overview">@Loc["Home"]</button>
        <button class="tab @(_tab == Tab.Budgets ? "active" : "")" @onclick="ShowExpensesTab">@Loc["Spending"]</button>
        <button class="tab @(_tab == Tab.Savings ? "active" : "")" @onclick="() => _tab = Tab.Savings">@Loc["Savings"]</button>
        <button class="tab @(_tab == Tab.Account ? "active" : "")" @onclick="() => _tab = Tab.Account">@Loc["Money"]</button>
        @if (_bankStatus?.Enabled == true)
        {
            <button class="tab @(_tab == Tab.Bank ? "active" : "")" @onclick="ShowBankTab">@Loc["Bank"]</button>
        }
    </nav>

    @{
        RenderFragment<Signal> signalCard = s =>
        @<div class="insight">
            <div class="insight-icon @(s.Kind switch { SignalKind.Good => "icon-good", SignalKind.Info => "icon-info", _ => "icon-warn" })">@(s.Kind switch { SignalKind.Good => "✓", SignalKind.Info => "ℹ", _ => "⚠️" })</div>
            <div class="insight-body">
                <div class="insight-title">@s.Title</div>
                <div class="insight-desc">@s.Desc</div>
            </div>
            <div class="insight-delta @(s.Dir switch { DeltaDir.Up => "delta-up", DeltaDir.Down => "delta-down", _ => "delta-flat" })">@s.Delta</div>
        </div>;

        // Shared emoji picker for every add/edit modal (categories, funds, buckets, contributions).
        // Reads/writes the shared _fName/_fIcon fields; the first "auto" chip clears to a name-based guess.
        RenderFragment iconPicker =
        @<div>
            <label class="icon-label">@Loc["Icon"]</label>
            <div class="icon-grid">
                <button type="button" class="icon-opt @(_fIcon is null ? "sel" : "")" title="@Loc["Auto (from name)"]" @onclick="() => _fIcon = null">@(string.IsNullOrEmpty(_fName) ? "🏷️" : CategoryIcons.Guess(_fName))</button>
                @foreach (var ic in CategoryIcons.Palette)
                {
                    <button type="button" class="icon-opt @(_fIcon == ic ? "sel" : "")" @onclick="() => _fIcon = ic">@ic</button>
                }
            </div>
        </div>;
    }

    <div class="tab-content">
        <div class="tabpanel" hidden="@(_tab != Tab.Overview)">
            @{ var ov = _insights.Build(State.Account, State.PeriodNumber - 1, Fmt, Loc.T); }
            <section class="cards cards-3">
                <div class="card savings">
                    <span class="card-label">@Loc["Saved this period"]</span>
                    <span class="card-value">@Fmt(State.SavingsThisPeriod)</span>
                    <span class="card-sub">@PctOrDash(State.PeriodSavingsRate) @Loc["of contributions"]</span>
                </div>
                <div class="card"><span class="card-label">@Loc["Spent"]</span><span class="card-value">@Fmt(State.TotalSpent)</span></div>
                @{ var ovBand = ov.Band switch { HealthBand.Healthy => "score-ok", HealthBand.Average => "score-warn", _ => "score-bad" }; }
                <button class="card card-score" @onclick="ToggleHomeInsights">
                    <span class="card-label">@Loc["Health score"]</span>
                    <span class="card-value @ovBand">@(ov.HasData ? ov.Score.ToString() : "—")</span>
                    <span class="card-sub">@(ov.HasData ? ov.Verdict : "") ›</span>
                </button>
            </section>

            @if (!ov.HasData)
            {
                <section class="panel insight-empty">
                    <p>📊 @Loc["Log some income or expenses to see your account overview here."]</p>
                </section>
            }
            else
            {
                var warnings = ov.Signals.Where(s => s.Kind == SignalKind.Warn).ToList();
                @if (warnings.Count > 0)
                {
                    <h2 class="insight-h">@Loc["Needs your attention"]</h2>
                    <div class="insight-list">
                        @foreach (var s in warnings)
                        {
                            @signalCard(s)
                        }
                    </div>
                }
                else
                {
                    <section class="panel all-clear"><p>✅ @Loc["All clear — no warnings this period. Nice work."]</p></section>
                }

                var overspent = State.CategoryOptions.Where(c => State.HasBudget(c.Category.Id) && State.Coverage(c.Category.Id).IsOverBudget).ToList();
                @if (overspent.Count > 0)
                {
                    <h2 class="insight-h">@Loc["Overspent budgets"]</h2>
                    <div class="ring-grid">
                        @foreach (var (cat, _) in overspent)
                        {
                            var cov = State.Coverage(cat.Id);
                            var catId = cat.Id;
                            <div class="ring-card ring-card-lg">
                                <ProgressRing Percent="@((double)(cov.Percent ?? 0))" Class="over">
                                    <button class="ring-ico-big" title="@Loc["Manage category"]" @onclick="() => OpenCategoryDetail(catId)">@State.CategoryIcon(catId)</button>
                                    <button class="ring-name" title="@Loc["Manage category"]" @onclick="() => OpenCategoryDetail(catId)">@cat.Name</button>
                                </ProgressRing>
                                <div class="ring-label over-text"><span>@Fmt(cov.Spent) / @Fmt(cov.Allocated)</span></div>
                            </div>
                        }
                    </div>
                }

                @if (ov.QuickWins.Count > 0)
                {
                    <h2 class="insight-h">@Loc["Quick wins"]</h2>
                    <div class="win-list">
                        @{ var qn = 0; }
                        @foreach (var w in ov.QuickWins)
                        {
                            qn++;
                            <div class="win"><div class="win-bullet">@qn</div><div class="win-text">@w.Text</div></div>
                        }
                    </div>
                }

                @if (ov.Breakdown.Count > 0)
                {
                    <h2 class="insight-h">@Loc["Top spending"]</h2>
                    <section class="panel breakdown-card">
                        @foreach (var c in ov.Breakdown.Take(5))
                        {
                            var arrow = c.Dir switch { DeltaDir.Up => "▲", DeltaDir.Down => "▼", _ => "" };
                            var acls = c.Dir == DeltaDir.Up ? "up" : c.Dir == DeltaDir.Down ? "down" : "";
                            <div class="breakdown-row">
                                <div class="breakdown-cat">
                                    <span class="cat-dot" style="background:@c.ColorHex"></span>
                                    <span class="cat-ico">@c.Icon</span>
                                    <span class="breakdown-name">@c.Name</span>
                                </div>
                                <div class="breakdown-bar-wrap">
                                    <div class="breakdown-bar-bg"></div>
                                    <div class="breakdown-bar-fill" style="background:@c.ColorHex; width:@((double)c.BarFraction * 100)%"></div>
                                </div>
                                <div class="breakdown-amount">@Fmt(c.Amount) <span class="bd-arrow @acls">@arrow</span></div>
                            </div>
                        }
                    </section>
                }

                <button class="home-more-toggle" @onclick="ToggleHomeInsights">
                    <span>📈 @Loc["Trends, savings rate & score"]</span>
                    <span class="home-more-chevron">@(_homeInsightsOpen ? "▲" : "▼")</span>
                </button>
                @if (_homeInsightsOpen)
                {
                    var band = ov.Band switch { HealthBand.Healthy => "ok", HealthBand.Average => "warn", _ => "bad" };
                    <section id="score-detail" class="panel score-detail">
                        <div class="score-verdict score-@band">@ov.Verdict</div>
                        <p class="score-line">@ov.Summary</p>
                        <div class="score-bar-wrap">
                            <div class="score-bar-track">
                                <div class="score-bar-needle" style="left:@(Math.Clamp(ov.Score, 2, 98))%"></div>
                            </div>
                            <div class="score-bar-labels">
                                <span>@Loc["At risk"]</span><span>@Loc["Average"]</span><span>@Loc["Healthy"]</span>
                            </div>
                        </div>
                    </section>

                    <h2 class="insight-h">@Loc["Savings rate"]</h2>
                    <section class="panel savings-rate-card">
                        <div class="savings-rate-head">
                            <span class="savings-pct">@PctOrDash(ov.SavingsRate)</span>
                            <span class="savings-target">@Loc["Target:"] <span>@PctText(ov.SavingsTarget)</span></span>
                        </div>
                        @{
                            var rateW = Math.Clamp((double)(ov.SavingsRate ?? 0m) * 100, 0, 100);
                            var goalW = Math.Clamp((double)ov.SavingsTarget * 100, 0, 100);
                        }
                        <div class="savings-track">
                            <div class="savings-fill" style="width:@rateW%"></div>
                            <div class="savings-goal-line" style="left:@goalW%"></div>
                        </div>
                        <div class="savings-footer">
                            <span>0%</span><span class="goal-label">@Loc["Goal"] @PctText(ov.SavingsTarget)</span><span>100%</span>
                        </div>
                        <div class="savings-critique">💡 @ov.SavingsCritique</div>
                    </section>

                    @if (ov.Trend.Count > 1)
                    {
                        <h2 class="insight-h">@Loc["Spending trend"]</h2>
                        <section class="panel trend-card">
                            <div class="trend-head">
                                <span>@Loc["Outgoings"] · @Loc["avg"] @Fmt(ov.TrendAverage)</span>
                                <span class="trend-dir @(ov.TrendUp ? "up" : "down")">@(ov.TrendUp ? "↑" : "↓") @(ov.TrendUp ? Loc["above average"] : Loc["below average"])</span>
                            </div>
                            <div class="trend-plot">
                                <div class="trend-avg" style="bottom:@((Math.Clamp((double)ov.TrendAvgFraction, 0, 1) * 72).ToString(System.Globalization.CultureInfo.InvariantCulture))px"></div>
                                @foreach (var t in ov.Trend)
                                {
                                    <div class="trend-bar @(t.IsCurrent ? "current" : "")" style="height:@(Math.Max(3.0, (double)t.BarFraction * 72).ToString(System.Globalization.CultureInfo.InvariantCulture))px" title="@t.Label: @Fmt(t.Outgoings)"></div>
                                }
                            </div>
                            <div class="trend-labels">
                                @foreach (var t in ov.Trend)
                                {
                                    <span class="@(t.IsCurrent ? "cur" : "")">@t.Label</span>
                                }
                            </div>
                            <div class="trend-note">@ov.TrendNote</div>
                        </section>
                    }
                }
            }
        </div>
        <div class="tabpanel" hidden="@(_tab != Tab.Account)">
            <section class="panel people-panel">
                <div class="panel-head">
                    <h2>@Loc["People"]</h2>
                    <button class="link" title="@Loc["Invite a contributor"]" @onclick="OpenInvite">➕ @Loc["Invite"]</button>
                </div>
                <div class="people-row">
                    @foreach (var m in State.RealUsers)
                    {
                        var mid = m.UserId;
                        <span class="person">
                            <Avatar Name="@m.DisplayName" Picture="@State.MemberAvatar(mid)" Size="26" /> @m.DisplayName
                            @if (mid == State.MyUserId) { <span class="person-tag">@Loc["you"]</span> }
                            else if (mid == State.CurrentOwnerId) { <span class="person-tag">@Loc["owner"]</span> }
                            @if (State.IsOwnerOfCurrent && mid != State.MyUserId)
                            {
                                <button class="person-x" title="@Loc["Remove from account"]" @onclick="() => OpenRemoveMember(mid, m.DisplayName)">×</button>
                            }
                        </span>
                    }
                </div>
                <div class="people-actions">
                    <button class="link danger" @onclick="OpenLeaveAccount">🚪 @Loc["Leave account"]</button>
                </div>
            </section>

            @if (State.Deficit.Amount > 0)
            {
                <div class="alert warn-bg">
                    <strong>🪶 @Loc["Ruffled feathers — overspent by"] @Fmt(State.Deficit).</strong>
                    <span>@Loc["Expenses ate into your savings earmark. This will need to be covered next period (from a savings bucket or fresh contributions)."]</span>
                </div>
            }

            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Where your money is"]</h2>
                    <span class="head-actions">
                        <button class="link" title="@Loc["Add a fund"]" @onclick="OpenAddFund">➕</button>
                    </span>
                </div>
                <ul class="list">
                    @foreach (var f in State.RootFunds)
                    {
                        var fid = f.Id;
                        <li class="row-menu-host">
                            <span class="row-lead">
                                <span class="fund-name"><span class="cat-ico">@State.FundIcon(fid)</span> @f.Name</span>
                                @if (State.FundNote(fid) is { Length: > 0 } note)
                                {
                                    <span class="row-note">· @note</span>
                                }
                            </span>
                            <span class="row-ops">
                                <span class="amt">@Fmt(State.FundBalance(fid))</span>
                                <button class="exp-edit" title="@Loc["Actions"]" @onclick="() => ToggleRowMenu(fid)">⋯</button>
                            </span>
                            @if (_rowMenuId == fid)
                            {
                                <div class="row-menu-backdrop" @onclick="() => _rowMenuId = Guid.Empty"></div>
                                <div class="row-menu">
                                    <button @onclick="() => RowAct(() => OpenEditFund(fid))">✏️ @Loc["Edit"]</button>
                                    @if (State.IsPeriodOpen)
                                    {
                                        @if (CanTransfer)
                                        {
                                            <button @onclick="() => RowAct(() => OpenTransferFromFund(fid))">🔁 @Loc["Transfer"]</button>
                                        }
                                        <button @onclick="() => RowAct(() => OpenDepositToFund(fid))">➕ @Loc["Deposit"]</button>
                                    }
                                    <button class="danger" @onclick="() => RowAct(() => OpenDeleteFund(fid))">🗑️ @Loc["Remove"]</button>
                                </div>
                            }
                        </li>
                    }
                    @if (!State.RootFunds.Any())
                    {
                        <li><em>@Loc["No funds yet — add where your money lives."]</em></li>
                    }
                </ul>
            </section>

            @if (CanTransfer || MergedTransfers().Count > 0)
            {
                var transfers = MergedTransfers();
                <button class="home-more-toggle" @onclick="() => _moveOpen = !_moveOpen">
                    <span>🔁 @Loc["Move money"]</span>
                    <span class="home-more-chevron">@(_moveOpen ? "▲" : "▼")</span>
                </button>
                <section class="panel" hidden="@(!_moveOpen)">
                    @if (CanTransfer)
                    {
                        <div class="form transfer-form">
                            <select @bind="_transferFromId">
                                @foreach (var f in State.RootFunds)
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                            <span class="arrow">→</span>
                            <select @bind="_transferDestId" @bind:after="OnInlineDestChanged">
                                <optgroup label="@Loc["Funds"]">
                                    @foreach (var f in State.RootFunds.Where(f => f.Id != _transferFromId))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </optgroup>
                                @if (State.TransferableAccounts.Any())
                                {
                                    <optgroup label="@Loc["Other accounts"]">
                                        @foreach (var a in State.TransferableAccounts)
                                        {
                                            <option value="@a.Id">📤 @a.Name</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            @if (TransferDestIsAccount && DestFundsFor(_transferDestId).Count > 0)
                            {
                                <select @bind="_transferDestFundId" title="@Loc["Destination fund"]">
                                    @foreach (var f in DestFundsFor(_transferDestId))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </select>
                            }
                            <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_transferAmount" />
                            <button title="@Loc["Transfer money"]" @onclick="DoTransfer" disabled="@(_transferAmount <= 0 || _transferDestId == Guid.Empty || _transferDestId == _transferFromId || _transferAmount > InlineTransferMax)">🔁</button>
                        </div>
                        @if (TransferDestIsAccount)
                        {
                            <small class="hint @(InlineTransferDipsSavings ? "warn-text" : "")">@Loc["Sending to another account leaves this one as an outflow."] @Loc["In this fund:"] <strong>@Fmt(State.FundBalance(_transferFromId))</strong>. @(InlineTransferDipsSavings ? Loc["⚠ This dips into money earmarked for savings."] : "")</small>
                        }
                        else
                        {
                            <small class="hint">@Loc["Move money between your funds — the total is unchanged, only where it sits."] @Loc["Available in this fund:"] <strong>@Fmt(State.FundBalance(_transferFromId))</strong></small>
                        }
                    }
                    @if (transfers.Any())
                    {
                        <ul class="list transfer-log">
                            @foreach (var t in transfers)
                            {
                                <li>
                                    <span>@t.Date.ToString("dd MMM") · @t.Label@(string.IsNullOrEmpty(t.Note) ? "" : $" · {t.Note}")</span>
                                    <span class="row-actions">
                                        <span class="amt">@Fmt(t.Amount)</span>
                                        @if (State.IsPeriodOpen && !t.IsExternal)
                                        {
                                            <button class="exp-edit" title="@Loc["Edit transfer"]" @onclick="() => OpenEditTransfer(t.Id)">✏️</button>
                                            <button class="exp-edit" title="@Loc["Remove transfer"]" @onclick="() => OpenDeleteTransfer(t.Id)">🗑️</button>
                                        }
                                        else if (State.IsPeriodOpen && t.IsExternal)
                                        {
                                            <button class="exp-edit" title="@Loc["Remove this transfer (does not reverse the deposit in the other account)"]" @onclick="() => OpenDeleteExternalTransfer(t.Id)">🗑️</button>
                                        }
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }

            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Income"]</h2>
                    @if (State.IsPeriodOpen)
                    {
                        <span class="head-actions">
                            <button class="link" title="@Loc["Manage categories"]" @onclick="OpenManageContribCats">🏷️</button>
                            <button class="link" title="@Loc["Add a deposit"]" @onclick="OpenDeposit">➕ @Loc["Deposit"]</button>
                        </span>
                    }
                </div>

                <ul class="list list-even">
                    @foreach (var c in State.ContributionsThisPeriod)
                    {
                        var cid = c.Id;
                        <li class="row-menu-host">
                            <span class="row-main">@c.Date.ToString("dd MMM") · <Avatar Name="@State.MemberName(c.MemberId)" Picture="@State.MemberAvatar(c.MemberId)" Size="20" /> @State.MemberName(c.MemberId)@(State.IsRealUser(c.MemberId) ? "" : $" ({Loc["imported"]})") · <span class="cat-ico">@State.ContributionCategoryIcon(c.CategoryId)</span> @State.ContributionCategoryName(c.CategoryId) · @Loc["to"] <span class="cat-ico">@State.FundIcon(c.FundId)</span> @State.FundName(c.FundId)</span>
                            <span class="amt">@Fmt(c.Paid)</span>
                            <span class="row-actions">
                                @if (State.IsPeriodOpen && State.CanHandleContribution(c))
                                {
                                    <button class="exp-edit" title="@Loc["Actions"]" @onclick="() => ToggleRowMenu(cid)">⋯</button>
                                }
                            </span>
                            @if (_rowMenuId == cid)
                            {
                                <div class="row-menu-backdrop" @onclick="() => _rowMenuId = Guid.Empty"></div>
                                <div class="row-menu">
                                    <button @onclick="() => RowAct(() => OpenEditDeposit(cid))">✏️ @Loc["Edit"]</button>
                                    <button class="danger" @onclick="() => RowAct(() => OpenDeleteDeposit(cid))">🗑️ @Loc["Remove"]</button>
                                </div>
                            }
                        </li>
                    }
                    @if (!State.ContributionsThisPeriod.Any())
                    {
                        <li><em>@Loc["Nothing in the nest yet — add a deposit."]</em></li>
                    }
                </ul>
            </section>

        </div>
        <div class="tabpanel" hidden="@(_tab != Tab.Budgets)">
            @if (State.IsPeriodOpen)
            {
                <button class="big-add" @onclick="OpenAddExpenseTab">🧾 @Loc["Add expense"]</button>
            }
            <section class="panel">
                <div class="spending-head">
                    <span class="insight-h">@Loc["This month's budgets"]</span>
                    <span class="spending-sub">@Fmt(State.TotalSpent) @Loc["of"] @Fmt(State.TotalBudgeted) @Loc["spent"]</span>
                </div>
                @{
                    // Top-level categories only — sub-categories roll up into their parent's ring.
                    var budgeted = State.CategoryOptions.Where(c => c.Depth == 0 && State.HasBudget(c.Category.Id)).ToList();
                    var unbudgeted = State.CategoryOptions
                        .Where(c => c.Depth == 0
                                    && !State.HasBudget(c.Category.Id)
                                    && State.SpentInCategory(c.Category.Id).Amount > 0
                                    && !State.ChildrenOf(c.Category.Id).Any(ch => State.HasBudget(ch.Id)))
                        .ToList();
                }
                <div class="ring-grid">
                    @foreach (var (cat, _) in budgeted)
                    {
                        var cov = State.Coverage(cat.Id);
                        var cls = cov.IsOverBudget ? "over" : cov.ThresholdReached ? "warn" : "ok";
                        var catId = cat.Id;
                        <div class="ring-card ring-card-lg">
                            @if (State.IsPeriodOpen)
                            {
                                <button class="ring-expense" title="@Loc["Add expense"]" @onclick="() => OpenAddExpense(catId)">🧾</button>
                            }
                            <ProgressRing Percent="@((double)(cov.Percent ?? 0))" Class="@cls">
                                <button class="ring-ico-big" title="@Loc["Manage category"]" @onclick="() => OpenCategoryDetail(catId)">@State.CategoryIcon(catId)</button>
                                <button class="ring-name" title="@Loc["Manage category"]" @onclick="() => OpenCategoryDetail(catId)">@cat.Name</button>
                            </ProgressRing>
                            <div class="ring-label"><span>@Fmt(cov.Spent) / @Fmt(cov.Allocated)</span></div>
                        </div>
                    }
                    @foreach (var (cat, _) in unbudgeted)
                    {
                        var catId = cat.Id;
                        <div class="ring-card ring-card-lg">
                            @if (State.IsPeriodOpen)
                            {
                                <button class="ring-expense" title="@Loc["Add expense"]" @onclick="() => OpenAddExpense(catId)">🧾</button>
                            }
                            <ProgressRing Percent="0" Class="mint" Dashed="true">
                                <button class="ring-ico-big" title="@Loc["Manage category"]" @onclick="() => OpenCategoryDetail(catId)">@State.CategoryIcon(catId)</button>
                                <button class="ring-name" title="@Loc["Manage category"]" @onclick="() => OpenCategoryDetail(catId)">@cat.Name</button>
                            </ProgressRing>
                            <div class="ring-label"><span class="amt">@Fmt(State.SpentInCategory(catId))</span> <span class="ring-muted">@Loc["no budget"]</span></div>
                        </div>
                    }
                    <div class="ring-card ring-card-lg">
                        <button class="ring-plus" title="@Loc["Add category"]" @onclick="() => OpenAdd(null)">+</button>
                        <div class="ring-label"><span class="ring-muted">@Loc["Add category"]</span></div>
                    </div>
                </div>
            </section>

            <section class="panel">
                <div class="panel-head">
                    @if (_calendar)
                    {
                        <h2>@State.Period.From.ToString("MMMM yyyy")</h2>
                    }
                    else if (_dayView is { } dv)
                    {
                        <span class="day-nav">
                            <button class="exp-edit" title="@Loc["Previous day"]" @onclick="PrevDay" disabled="@(dv <= State.Period.From)">◀</button>
                            <input type="date" @bind:get="dv" @bind:set="GoToDay" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" />
                            <button class="exp-edit" title="@Loc["Next day"]" @onclick="NextDay" disabled="@(dv >= State.Period.To)">▶</button>
                        </span>
                    }
                    else
                    {
                        <h2>@Loc["All expenses"]</h2>
                    }
                    <span class="view-toggle">
                        <button class="view-btn @(_calendar ? "" : "active")" title="@Loc["List"]" @onclick="ShowDayList">☰</button>
                        <button class="view-btn @(_calendar ? "active" : "")" title="@Loc["Calendar"]" @onclick="ShowCalendarView">📅</button>
                    </span>
                </div>
                @{
                    RenderFragment<FinApp.Domain.Budgeting.Expense> row = e =>
                        @<li>
                            <span class="row-main">
                                <span class="cat-ico">@State.CategoryIcon(e.CategoryId)</span> @State.CategoryName(e.CategoryId) <span class="exp-arrow">⟵</span> <span class="cat-ico">@State.FundIcon(e.FundId)</span> @State.FundName(e.FundId)@(e.IsFromSavings ? " · 💰saving" : "")@(string.IsNullOrEmpty(e.Note) ? "" : $" · {e.Note}")
                                @if (e.IsSettlementSource)
                                {
                                    <span class="settle-tag" title="@Loc["Settled onto another account"]">🤝 @Fmt(e.SettledMoney) → @State.AccountName(e.SettledToAccountId!.Value)</span>
                                }
                                else if (e.IsSettlementDestination)
                                {
                                    <span class="settle-tag" title="@Loc["Settled from another account"]">↩ @Loc["from"] @State.AccountName(e.SettledFromAccountId!.Value)</span>
                                }
                            </span>
                            <span class="amt">@Fmt(e.Amount)</span>
                            <span class="row-actions">
                                @if (State.IsPeriodOpen)
                                {
                                    @if (e.OnBehalfOfOtherAccount)
                                    {
                                        <button class="exp-edit" title="@Loc["Settle onto another account"]" @onclick="() => OpenSettleExpense(e.Id)">🤝</button>
                                    }
                                    <button class="exp-edit" title="@Loc["Edit expense"]" @onclick="() => OpenEditExpense(e.Id)">✏️</button>
                                    <button class="exp-edit" title="@Loc["Remove expense"]" @onclick="() => OpenDeleteExpense(e.Id)">🗑️</button>
                                }
                            </span>
                        </li>;
                    var shown = _dayView is { } dvf
                        ? State.AllExpenses.Where(e => e.Date == dvf).ToList()
                        : State.AllExpenses.ToList();
                    var byDay = State.AllExpenses.GroupBy(e => e.Date)
                        .ToDictionary(g => g.Key, g => (Count: g.Count(), Total: g.Aggregate(0m, (s, e) => s + e.Amount.Amount)));
                    var calToday = DateOnly.FromDateTime(DateTime.Today);
                }
                @if (_calendar)
                {
                    <div class="cal-dow">
                        @foreach (var dow in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                        {
                            <span>@dow</span>
                        }
                    </div>
                    <div class="cal-grid">
                        @foreach (var d in CalendarDays())
                        {
                            var inRange = d >= State.Period.From && d <= State.Period.To;
                            byDay.TryGetValue(d, out var info);
                            var cls = "cal-cell"
                                + (inRange ? "" : " cal-out")
                                + (d == calToday ? " cal-today" : "")
                                + (_dayView == d ? " cal-sel" : "");
                            var day = d;
                            <div class="@cls" @onclick="() => OpenDayFromCalendar(day)">
                                <span class="cal-top">
                                    <span class="cal-num">@d.Day</span>
                                    @if (inRange && State.IsPeriodOpen)
                                    {
                                        <button class="cal-add" title="@Loc["Add expense"]" @onclick:stopPropagation="true" @onclick="() => OpenAddExpenseOn(day)">🧾</button>
                                    }
                                </span>
                                @if (inRange && info.Count > 0)
                                {
                                    <span class="cal-total">@Fmt(State.Money(info.Total))</span>
                                }
                            </div>
                        }
                    </div>
                }
                else if (!shown.Any())
                {
                    <ul class="list"><li><em>@Loc["Nothing’s perched here yet — add your first expense."]</em></li></ul>
                }
                else if (_dayView is not null)
                {
                    <ul class="list list-even">@foreach (var e in shown) { @row(e) }</ul>
                }
                else
                {
                    @foreach (var grp in shown.GroupBy(e => e.Date).OrderByDescending(g => g.Key))
                    {
                        <button class="date-sep" @onclick="() => GoToDay(grp.Key)">@grp.Key.ToString("dddd, dd MMM yyyy")</button>
                        <ul class="list list-even">@foreach (var e in grp) { @row(e) }</ul>
                    }
                }
            </section>
        </div>
        <div class="tabpanel" hidden="@(_tab != Tab.Savings)">
            <section class="cards cards-2">
                <div class="card savings">
                    <span class="card-label">@Loc["Total saved"]</span>
                    <span class="card-value">@Fmt(State.SavingsAccumulated)</span>
                    <span class="card-sub">@PctOrDash(State.AccountSavingsRate) @Loc["all periods"]</span>
                </div>
                <div class="card savings">
                    <span class="card-label">@Loc["Saved this period"]</span>
                    <span class="card-value">@Fmt(State.SavingsThisPeriod)</span>
                    <span class="card-sub">@PctOrDash(State.PeriodSavingsRate) @Loc["of contributions"]</span>
                </div>
            </section>
            <section class="panel">
                <div class="ring-grid">
                    @foreach (var (bucket, total) in State.SavingBuckets)
                    {
                        var bucketId = bucket.Id;
                        var g = bucket.HasGoal ? State.SavingGoal(bucketId) : (SavingGoalProgress?)null;
                        var pct = (double)(g?.Percent ?? 0);
                        var cls = g is null ? "mint" : g.ThresholdReached && !g.GoalReached ? "warn" : "ok";
                        <div class="ring-card ring-card-lg">
                            <ProgressRing Percent="@(g is null ? 0 : pct)" Class="@cls" Dashed="@(g is null)">
                                <button class="ring-ico-big" title="@Loc["Edit"]" @onclick="() => OpenEditBucket(bucketId)">@State.SavingBucketIcon(bucketId)</button>
                                <button class="ring-name" title="@Loc["Edit"]" @onclick="() => OpenEditBucket(bucketId)">@bucket.Name</button>
                                @if (g is not null && g.GoalReached)
                                {
                                    <span class="ring-done">✓</span>
                                }
                            </ProgressRing>
                            @if (State.IsPeriodOpen)
                            {
                                <div class="ring-actions">
                                    <button title="@Loc["Add to savings"]" @onclick="() => OpenAddSaving(bucketId)">💰</button>
                                    <button title="@Loc["Budget savings"]" @onclick="() => OpenBudgetSaving(bucketId)">➡️</button>
                                    <button title="@Loc["Spend savings"]" @onclick="() => OpenSpendSaving(bucketId)">💸</button>
                                </div>
                            }
                            <div class="ring-label">
                                @if (g is null) { <span class="amt save">@Fmt(total)</span> <span class="ring-muted">@Loc["saved"]</span> }
                                else { <span class="amt save">@Fmt(total)</span> <span class="ring-muted">/ @Fmt(g.Goal!.Value)</span> }
                            </div>
                        </div>
                    }
                    <div class="ring-card ring-card-lg">
                        <button class="ring-plus" title="@Loc["Add a savings bucket"]" @onclick="OpenAddBucket">+</button>
                        <div class="ring-label"><span class="ring-muted">@Loc["Add bucket"]</span></div>
                    </div>
                </div>
            </section>

            @if (State.SavingDepositsThisPeriod.Any() || State.SavingMovementsThisPeriod.Any())
            {
                <section class="panel">
                    <h2>@Loc["Savings activity"]</h2>
                    <ul class="list">
                        @foreach (var d in State.SavingDepositsThisPeriod)
                        {
                            <li>
                                <span class="row-lead">
                                    @if (State.IsPeriodOpen)
                                    {
                                        <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => OpenEditSavingDeposit(d.Id)">✏️</button>
                                        <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteSavingDeposit(d.Id)">🗑️</button>
                                    }
                                    <span>@d.Date.ToString("dd MMM") · 💰 @State.SavingBucketName(d.SavingCategoryId)</span>
                                </span>
                                <span class="amt save">@Fmt(d.Amount)</span>
                            </li>
                        }
                        @foreach (var m in State.SavingMovementsThisPeriod)
                        {
                            <li>
                                <span class="row-lead">
                                    @if (State.IsPeriodOpen)
                                    {
                                        <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => OpenEditSavingMovement(m.Id)">✏️</button>
                                        <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteSavingMovement(m.Id)">🗑️</button>
                                    }
                                    <span>@m.Date.ToString("dd MMM") · @MovementIcon(m) @State.SavingMovementTarget(m)</span>
                                </span>
                                <span class="amt save">@Fmt(State.Money(-m.Amount.Amount))</span>
                            </li>
                        }
                    </ul>
                </section>
            }
        </div>
        <div class="tabpanel" hidden="@(_tab != Tab.Bank)">
            @if (_bankStatus?.Enabled == true)
            {
                <section class="panel bank-panel">
                    <div class="panel-head">
                        <h2>@Loc["Bank sync"] · @State.Account.Name</h2>
                        @if (_bankStatus.Connected && State.IsPeriodOpen)
                        {
                            <button class="link" title="@Loc["Fetch new transactions"]" @onclick="SyncBankAsync" disabled="@_bankBusy">🔄 @Loc["Refresh"]</button>
                        }
                    </div>

                    @if (!_bankStatus.Connected)
                    {
                        <p class="hint">@Loc["Link your Revolut account to pull transactions in automatically."] @Loc["Each account links its own bank."]</p>
                        <button class="primary" @onclick="LinkBankAsync" disabled="@_bankBusy">🔗 @Loc["Link Revolut"]</button>
                    }
                    else
                    {
                        <p class="bank-conn">
                            <span>✅ @_bankStatus.InstitutionName</span>
                            @if (_bankStatus.LastSyncedAt is { } synced)
                            {
                                <span class="row-note">· @Loc["last synced"] @synced.LocalDateTime.ToString("dd MMM HH:mm")</span>
                            }
                            <button class="link danger bank-disconnect" @onclick="DisconnectBankAsync" disabled="@_bankBusy">@Loc["Disconnect"]</button>
                        </p>
                        @if (_bankStatus.ConsentExpiresAt is { } exp && exp <= DateTimeOffset.UtcNow)
                        {
                            <div class="alert warn-bg">
                                <span>@Loc["Your bank consent has expired (banks require re-approval every 90 days)."]</span>
                                <button class="link" @onclick="LinkBankAsync" disabled="@_bankBusy">@Loc["Reconnect"]</button>
                            </div>
                        }

                        var bankRows = BankRowsForPeriod();
                        RenderFragment<PendingBankTransactionDto> BankTxRow = t =>
                            @<li class="bank-tx">
                                @{
                                    var id = t.ExternalId;
                                    var isDebit = t.Amount < 0;
                                    var mappedLabel = MappedLabel(t.Description);
                                    var pinTitle = mappedLabel is not null
                                        ? string.Format(Loc["Auto-fills {0} — click to forget"], mappedLabel)
                                        : Loc["Always use this pick for this merchant"];
                                }
                                <div class="bank-tx-top">
                                    <span class="bank-tx-desc" title="@t.Description">@t.Description</span>
                                    <span class="amt @(isDebit ? "" : "credit")">@(isDebit ? "−" : "+")@Fmt(new Money(Math.Abs(t.Amount), State.Currency))</span>
                                </div>
                                <div class="bank-tx-row">
                                    <span class="bank-tx-date">@t.Date.ToString("dd MMM")</span>
                                    @if (isDebit)
                                    {
                                        <select class="bank-sel" value="@RowCat(id)" @onchange="e => _bankRowCat[id] = Guid.Parse(e.Value?.ToString() ?? Guid.Empty.ToString())">
                                            @foreach (var (cat, depth) in State.CategoryOptions)
                                            {
                                                <option value="@cat.Id">@CatOption(cat.Id, cat.Name, depth)</option>
                                            }
                                        </select>
                                        <select class="bank-sel" value="@RowFund(id)" @onchange="e => _bankRowFund[id] = Guid.Parse(e.Value?.ToString() ?? Guid.Empty.ToString())">
                                            @foreach (var f in State.RootFunds)
                                            {
                                                <option value="@f.Id">@f.Name</option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="bank-sel" value="@RowCredit(id)" @onchange="e => _bankRowCredit[id] = e.Value?.ToString() ?? string.Empty">
                                            <option value="">@Loc["Map to… (optional)"]</option>
                                            <optgroup label="@Loc["Funds"]">
                                                @foreach (var f in State.RootFunds)
                                                {
                                                    <option value="fund:@f.Id">@f.Name</option>
                                                }
                                            </optgroup>
                                            <optgroup label="@Loc["People"]">
                                                @foreach (var m in State.RealUsers)
                                                {
                                                    <option value="contributor:@m.UserId">@m.DisplayName</option>
                                                }
                                            </optgroup>
                                        </select>
                                    }
                                    <span class="bank-tx-icons">
                                        <button class="icon-btn pin @(mappedLabel is not null ? "on" : "")" title="@pinTitle" @onclick="() => TogglePin(t)" disabled="@_bankBusy">📌</button>
                                        @if (isDebit)
                                        {
                                            <button class="icon-btn ok" title="@Loc["Add expense"]" @onclick="() => ConfirmBankRow(t)" disabled="@_bankBusy">✓</button>
                                        }
                                        <button class="icon-btn x" title="@Loc["Dismiss"]" @onclick="() => DismissBankRow(t)" disabled="@_bankBusy">✕</button>
                                    </span>
                                </div>
                            </li>;
                        @if (!State.IsPeriodOpen)
                        {
                            <p class="hint">@Loc["Reopen the period to import transactions."]</p>
                        }
                        else if (bankRows.Count == 0)
                        {
                            <p class="hint">@Loc["No transactions waiting for this period. Hit Refresh to check for new ones."]</p>
                        }
                        else
                        {
                            var debits = bankRows.Where(r => r.Amount < 0).ToList();
                            var credits = bankRows.Where(r => r.Amount > 0).ToList();

                            @if (debits.Count > 0)
                            {
                                <h3 class="bank-group-h">🧾 @Loc["Expenses"] <span class="bank-group-count">@debits.Count</span></h3>
                                <ul class="list bank-pending">
                                    @foreach (var t in debits) { @BankTxRow(t) }
                                </ul>
                            }
                            @if (credits.Count > 0)
                            {
                                <h3 class="bank-group-h">💰 @Loc["Money in"] <span class="bank-group-count">@credits.Count</span></h3>
                                <ul class="list bank-pending">
                                    @foreach (var t in credits) { @BankTxRow(t) }
                                </ul>
                            }
                        }
                    }
                    @if (_bankError is not null)
                    {
                        <div class="alert warn-bg"><span>@_bankError</span><button class="alert-x" title="@Loc["Dismiss"]" @onclick="() => _bankError = null">×</button></div>
                    }
                </section>
            }
        </div>
    </div>
</div>

@if (_modal != Modal.None)
{
    <div class="modal-backdrop">
        <div class="modal">
            @if (_modalError is not null)
            {
                <div class="modal-error">@_modalError</div>
            }
            @switch (_modal)
            {
                case Modal.AddCat:
                    <h3>@Loc["Add category"] @(_addParentId is {} p ? $"under {State.CategoryName(p)}" : "(top level)")</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_fName" /></label>
                    @iconPicker
                    <label>@Loc["Budget for this period (optional)"] <input type="number" step="0.01" min="0" @bind="_fBudget" /></label>
                    <small class="hint">@Loc["Available to budget:"] <strong>@Fmt(State.MaxBudgetFor(Guid.Empty))</strong></small>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveAddCat" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Add"]</button>
                    </div>
                    break;

                case Modal.EditCat:
                    <div class="modal-head">
                        <h3>@State.CategoryIcon(_modalCatId) @Loc["Edit"] @State.CategoryName(_modalCatId)</h3>
                        <span class="modal-head-actions">
                            <button class="exp-edit" title="@Loc["Delete"]" @onclick="EditDeleteSelf">🗑️</button>
                        </span>
                    </div>
                    <label>@Loc["Name"] <input type="text" @bind="_fName" /></label>
                    @iconPicker
                    <label>@Loc["Budget amount"] <input type="number" step="0.01" min="0" @bind="_fBudget" /></label>
                    <small class="hint">@Loc["Available to budget:"] <strong>@Fmt(State.MaxBudgetFor(_modalCatId))</strong></small>
                    <label>@Loc["Alert at %"] <input type="number" step="1" min="0" max="100" @bind="_fThreshold" /></label>
                    <label class="check"><input type="checkbox" @bind="_fNotify" /> @Loc["Notify on every expense"]</label>
                    var subs = State.ChildrenOf(_modalCatId).ToList();
                    <div class="detail-sub-head">
                        <h4 class="detail-sub">@Loc["Sub-categories"]</h4>
                        <button class="lbl-add" title="@Loc["Sub-category"]" @onclick="EditAddSub">+</button>
                    </div>
                    @if (subs.Count > 0)
                    {
                        <ul class="list">
                            @foreach (var sub in subs)
                            {
                                var subId = sub.Id;
                                <li>
                                    <span class="row-main"><span class="cat-ico">@State.CategoryIcon(subId)</span> @sub.Name</span>
                                    <span class="row-actions">
                                        <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => EditEditSub(subId)">✏️</button>
                                        <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => EditDeleteSub(subId)">🗑️</button>
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    @if (_editCatVendors.Count > 0)
                    {
                        <h4 class="detail-sub">@Loc["Auto-categorized merchants"]</h4>
                        <small class="hint">@Loc["Imported transactions from these are filed here automatically. Unmapping only stops future auto-filing."]</small>
                        <ul class="list">
                            @foreach (var v in _editCatVendors)
                            {
                                var vendor = v;
                                <li>
                                    <span class="row-main">🔖 @vendor</span>
                                    <span class="row-actions">
                                        <button class="exp-edit" title="@Loc["Unmap"]" @onclick="() => UnmapVendorFromCat(vendor)" disabled="@_bankBusy">✕</button>
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    <div class="modal-actions inline-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditCat" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteCat:
                    <h3>@Loc["Delete"] @State.CategoryName(_modalCatId)?</h3>
                    @if (State.CategoryRemovalBlocker(_modalCatId) is {} blocker)
                    {
                        <p class="hint">@Loc["Can’t delete —"] @blocker. @Loc["Remove those first."]</p>
                        <div class="modal-actions"><button class="ghost" @onclick="Back">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        <p class="hint">@Loc["This removes the category permanently."]</p>
                        <div class="modal-actions">
                            <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                            <button class="danger-btn" @onclick="ConfirmDelete">@Loc["Delete"]</button>
                        </div>
                    }
                    break;

                case Modal.CategoryDetail:
                    <div class="modal-head">
                        <h3>@State.CategoryIcon(_modalCatId) @State.CategoryName(_modalCatId)</h3>
                        <span class="modal-head-actions">
                            <button class="exp-edit" title="@Loc["Edit / budget"]" @onclick="DetailEdit">✏️</button>
                            <button class="exp-edit" title="@Loc["Delete"]" @onclick="DetailDelete">🗑️</button>
                        </span>
                    </div>
                    @if (State.BudgetFor(_modalCatId) is { } cb)
                    {
                        <p class="hint">@Fmt(State.Coverage(_modalCatId).Spent) @Loc["spent of"] @Fmt(cb.Allocated) @Loc["budgeted"].</p>
                    }
                    else
                    {
                        <p class="hint">@Loc["No budget set for this category."]</p>
                    }
                    <h4 class="detail-sub">@Loc["Expenses"]</h4>
                    <ul class="list">
                        @foreach (var e in State.ExpensesFor(_modalCatId))
                        {
                            <li>
                                <span class="row-lead">
                                    @if (State.IsPeriodOpen)
                                    {
                                        <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => DetailEditExpense(e.Id)">✏️</button>
                                        <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => DetailDeleteExpense(e.Id)">🗑️</button>
                                    }
                                    <span>@e.Date.ToString("dd MMM") · <span class="cat-ico">@State.FundIcon(e.FundId)</span> @State.FundName(e.FundId)@(string.IsNullOrEmpty(e.Note) ? "" : $" · {e.Note}")</span>
                                </span>
                                <span class="amt">@Fmt(e.Amount)</span>
                            </li>
                        }
                        @if (!State.ExpensesFor(_modalCatId).Any())
                        {
                            <li><em>@Loc["No expenses in this category yet."]</em></li>
                        }
                    </ul>
                    <div class="modal-actions inline-actions">
                        <button class="ghost" @onclick="Back">@Loc["Close"]</button>
                    </div>
                    break;

                case Modal.AddAccount:
                    <h3>@Loc["New account"]</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_fName" /></label>
                    <label>@Loc["Currency"] <input type="text" maxlength="3" @bind="_fCurrency" /></label>
                    <label>@Loc["Savings target (%)"] <input type="number" min="0" max="100" @bind="_fSavingsTarget" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveAddAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Create"]</button>
                    </div>
                    break;

                case Modal.EditAccount:
                    <h3>@Loc["Edit account"]</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_fName" /></label>
                    <label>@Loc["Savings target (%)"] <input type="number" min="0" max="100" @bind="_fSavingsTarget" /></label>
                    <p class="hint">@Loc["Your monthly savings goal — drives the Insights score."] @Loc["Currency"] (@State.Currency) @Loc["can't be changed once an account exists."]</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteAccount:
                    <h3>@Loc["Delete"] @State.Account.Name?</h3>
                    <p class="hint">@Loc["This permanently deletes the account and"] <strong>@Loc["all its periods, budgets, expenses and savings"]</strong>. @Loc["This can't be undone."]</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteAccount">@Loc["Delete account"]</button>
                    </div>
                    break;

                case Modal.RemoveMember:
                    <h3>@Loc["Remove"] @_removeMemberName?</h3>
                    <p class="hint">@string.Format(Loc["{0} will lose access to this account. Their recorded contributions and expenses stay."], _removeMemberName)</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmRemoveMember">@Loc["Remove from account"]</button>
                    </div>
                    break;

                case Modal.LeaveAccount:
                    <h3>@Loc["Leave"] @State.Account.Name?</h3>
                    @if (State.RealUsers.Count <= 1)
                    {
                        <p class="hint">@Loc["You're the only person here, so the account will be archived for 30 days. You can restore it from your profile before then; after that it's deleted."]</p>
                    }
                    else if (State.CurrentOwnerId == State.MyUserId)
                    {
                        <p class="hint">@Loc["You own this account, so hand it to another member before you go."]</p>
                        <label>@Loc["New owner"]
                            <select @bind="_leaveNewOwnerId">
                                <option value="@Guid.Empty">@Loc["Choose a member…"]</option>
                                @foreach (var m in State.OtherMembers)
                                {
                                    <option value="@m.UserId">@m.DisplayName</option>
                                }
                            </select>
                        </label>
                    }
                    else
                    {
                        <p class="hint">@Loc["You'll lose access to this account. Your recorded contributions and expenses stay for the others."]</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmLeaveAccount"
                                disabled="@(State.RealUsers.Count > 1 && State.CurrentOwnerId == State.MyUserId && _leaveNewOwnerId == Guid.Empty)">
                            @(State.RealUsers.Count <= 1 ? Loc["Archive account"] : Loc["Leave account"])
                        </button>
                    </div>
                    break;

                case Modal.Invite:
                    <h3>@Loc["Invite to"] @State.Account.Name</h3>
                    <p class="hint">@Loc["Enter the username of an existing FinApp user. They'll get a prompt to accept; once they do, they can edit everything except deleting the account."]</p>
                    <label>@Loc["Username"] <input type="text" @bind="_inviteUsername" @bind:event="oninput" /></label>
                    @if (_inviteMessage is not null)
                    {
                        <div class="alert">@_inviteMessage</div>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Close"]</button>
                        <button @onclick="SendInvite" disabled="@(string.IsNullOrWhiteSpace(_inviteUsername))">Send invite</button>
                    </div>
                    break;

                case Modal.AddExpense:
                    <h3>@Loc["Add expense"]</h3>
                    <label><span class="lbl-row">@Loc["Category"] <button type="button" class="lbl-add" title="@Loc["Add category"]" @onclick="ExpenseAddCategory">+</button></span>
                        <select @bind="_categoryId">
                            @foreach (var (cat, depth) in State.CategoryOptions)
                            {
                                <option value="@cat.Id">@CatOption(cat.Id, cat.Name, depth)</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_amount" /></label>
                    <label>@Loc["Date"] <input type="date" @bind="_expenseDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" /></label>
                    <label><span class="lbl-row">@Loc["Fund"] <button type="button" class="lbl-add" title="@Loc["New fund"]" @onclick="ExpenseAddFund">+</button></span>
                        <select @bind="_fundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Note (optional)"] <input type="text" @bind="_note" /></label>
                    @if (State.TransferableAccounts.Any())
                    {
                        <label class="check"><input type="checkbox" @bind="_onBehalfOther" /> @Loc["On behalf of another account (settle later)"]</label>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="AddExpenseFromModal" disabled="@(_amount <= 0)">@Loc["Add"]</button>
                    </div>
                    break;

                case Modal.RemovePeriod:
                    <h3>@Loc["Remove this period?"]</h3>
                    <p class="hint">@Loc["This deletes period"] @State.PeriodNumber (@State.Period.From.ToString("dd MMM") – @State.Period.To.ToString("dd MMM yyyy")) @Loc["and everything in it, then re-opens the previous period as active."] @Loc["This can't be undone."]</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmRemovePeriod">@Loc["Remove period"]</button>
                    </div>
                    break;

                case Modal.NextPeriod:
                    <h3>@Loc["Start next month"]</h3>
                    <p class="hint">@Loc["Enter what each fund really holds now (previous closing balance:"] <strong>@Fmt(State.Period.ExpectedClosingBalance)</strong>). @Loc["These become the new period's opening balances — that money carries over and is fully available to budget or save."]</p>
                    @foreach (var f in State.RootFunds)
                    {
                        <label>@f.Name <input type="text" inputmode="text" @bind:get="RealOpeningText(f.Id)" @bind:set="v => SetRealOpeningText(f.Id, v)" /></label>
                    }
                    <label class="check"><input type="checkbox" @bind="_copyBudgets" /> Copy this period’s budgets forward</label>
                    @if (_copyBudgets)
                    {
                        <label class="check"><input type="checkbox" @bind="_adjustBudgets" /> @Loc["Adjust budgets to this period’s spending"]</label>
                        <small class="hint">@Loc["Each budget moves halfway toward what was actually spent, rounded up to the nearest 10."]</small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="ConfirmNextPeriod">@Loc["Start next month"] →</button>
                    </div>
                    break;

                case Modal.EditExpense:
                    <h3>@Loc["Edit expense"]</h3>
                    <label>@Loc["Category"]
                        <select @bind="_categoryId">
                            @foreach (var (cat, depth) in State.CategoryOptions)
                            {
                                <option value="@cat.Id">@CatOption(cat.Id, cat.Name, depth)</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_amount" /></label>
                    <label>@Loc["Date"] <input type="date" @bind="_expenseDate" /></label>
                    <label>@Loc["Fund"]
                        <select @bind="_fundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Note (optional)"] <input type="text" @bind="_note" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditExpense" disabled="@(_amount <= 0)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteExpense:
                    <h3>@Loc["Remove this expense?"]</h3>
                    @if (State.FindExpense(_editExpenseId) is { } ex)
                    {
                        <p class="hint">@ex.Date.ToString("dd MMM") · @State.CategoryName(ex.CategoryId) · @Fmt(ex.Amount)@(ex.IsFromSavings ? " — the savings drawdown will be restored." : "")</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteExpense">@Loc["Remove"]</button>
                    </div>
                    break;

                case Modal.SettleExpense:
                    <h3>@Loc["Settle onto another account"]</h3>
                    @if (State.FindExpense(_settleExpenseId) is { } se)
                    {
                        <p class="hint">@se.Date.ToString("dd MMM") · @State.CategoryName(se.CategoryId) · @Loc["Original:"] @Fmt(se.OriginalAmount)</p>
                    }
                    @if (!State.TransferableAccounts.Any())
                    {
                        <p class="hint">@Loc["You have no other same-currency account to settle onto."]</p>
                        <div class="modal-actions"><button class="ghost" @onclick="Back">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        <label>@Loc["Account"]
                            <select @bind="_settleDestId" @bind:after="OnSettleDestChanged">
                                @foreach (var a in State.TransferableAccounts)
                                {
                                    <option value="@a.Id">@a.Name</option>
                                }
                            </select>
                        </label>
                        <label>@Loc["Destination fund"]
                            <select @bind="_settleDestFundId">
                                @foreach (var f in DestFundsFor(_settleDestId))
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                        </label>
                        <label>@Loc["Category"]
                            <select @bind="_settleDestCatId">
                                @foreach (var c in DestCatsFor(_settleDestId))
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        </label>
                        <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_settleAmount" /></label>
                        <label>@Loc["Note (optional)"] <input type="text" @bind="_settleNote" /></label>
                        <small class="hint">@Loc["Records this amount as an expense on the chosen account (in that fund and category) and reduces this expense by the same amount."]</small>
                        <div class="modal-actions">
                            @if (_settleIsEdit)
                            {
                                <button class="ghost danger" @onclick="UnsettleFromModal">@Loc["Unsettle"]</button>
                            }
                            <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                            <button @onclick="ConfirmSettleExpense" disabled="@(_settleAmount <= 0 || _settleDestId == Guid.Empty)">🤝 @(_settleIsEdit ? Loc["Save"] : Loc["Settle"])</button>
                        </div>
                    }
                    break;

                case Modal.AddBucket:
                case Modal.EditBucket:
                    <h3>@(_modal == Modal.AddBucket ? Loc["New savings bucket"] : $"{Loc["Edit"]} {State.FindSavingBucket(_modalBucketId)?.Name}")</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_fName" /></label>
                    @iconPicker
                    <label>@Loc["Goal amount (optional)"] <input type="number" step="0.01" min="0" @bind="_goalAmount" /></label>
                    <label>@Loc["Alert at %"] <input type="number" step="1" min="0" max="100" @bind="_fThreshold" /></label>
                    <label class="check"><input type="checkbox" @bind="_fNotify" /> @Loc["Notify on milestone"]</label>
                    @if (State.CanSetInitialSavings)
                    {
                        <label>@Loc["Already saved (starting balance)"] <input type="number" step="0.01" min="0" @bind="_initialSavings" /></label>
                        <small class="hint">@Loc["Money you already had in this bucket before using FinApp. It counts toward the balance and goal, but not toward your savings rate."]</small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveBucket" disabled="@(string.IsNullOrWhiteSpace(_fName))">@(_modal == Modal.AddBucket ? "Add" : "Save")</button>
                    </div>
                    break;

                case Modal.Transfer:
                    <h3>@Loc["Transfer from"] @State.FundName(_mTransferFromId)</h3>
                    <label>@Loc["To"]
                        <select @bind="_mTransferDestId" @bind:after="OnModalDestChanged">
                            <optgroup label="@Loc["Funds"]">
                                @foreach (var f in State.RootFunds.Where(f => f.Id != _mTransferFromId))
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </optgroup>
                            @if (State.TransferableAccounts.Any())
                            {
                                <optgroup label="@Loc["Other accounts"]">
                                    @foreach (var a in State.TransferableAccounts)
                                    {
                                        <option value="@a.Id">📤 @a.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </label>
                    @if (MTransferDestIsAccount && DestFundsFor(_mTransferDestId).Count > 0)
                    {
                        <label>@Loc["Destination fund"]
                            <select @bind="_mTransferDestFundId">
                                @foreach (var f in DestFundsFor(_mTransferDestId))
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                        </label>
                    }
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_mTransferAmount" /></label>
                    @if (MTransferDestIsAccount)
                    {
                        <small class="hint @(MTransferDipsSavings ? "warn-text" : "")">@Loc["In this fund:"] <strong>@Fmt(State.FundBalance(_mTransferFromId))</strong>. @(MTransferDipsSavings ? Loc["⚠ This dips into money earmarked for savings."] : "")</small>
                    }
                    else
                    {
                        <small class="hint">@Loc["Available in this fund:"] <strong>@Fmt(State.FundBalance(_mTransferFromId))</strong></small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="ConfirmTransfer" disabled="@(_mTransferAmount <= 0 || _mTransferDestId == Guid.Empty || _mTransferDestId == _mTransferFromId || _mTransferAmount > MTransferMax)">🔁 @Loc["Transfer money"]</button>
                    </div>
                    break;

                case Modal.Deposit:
                    <h3>@Loc["Add a deposit"]</h3>
                    <label><span class="lbl-row">@Loc["Category"] <button type="button" class="lbl-add" title="@Loc["New contribution category"]" @onclick="DepositAddCategory">+</button></span>
                        <select @bind="_depCategoryId">
                            @foreach (var cc in State.ContributionCategories)
                            {
                                <option value="@cc.Id">@cc.Name</option>
                            }
                        </select>
                    </label>
                    <label><span class="lbl-row">@Loc["Fund"] <button type="button" class="lbl-add" title="@Loc["New fund"]" @onclick="DepositAddFund">+</button></span>
                        <select @bind="_depFundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_depAmount" /></label>
                    <label>@Loc["Date"] <input type="date" @bind="_depDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="RecordDeposit" disabled="@(_depAmount <= 0)">@Loc["Deposit"]</button>
                    </div>
                    break;

                case Modal.ManageContribCats:
                    <h3>@Loc["Contribution categories"]</h3>
                    <ul class="list">
                        @foreach (var cc in State.ContributionCategories)
                        {
                            <li>
                                <span class="row-lead">
                                    <button class="exp-edit" title="@Loc["Rename"]" @onclick="() => OpenEditContribCat(cc.Id)">✏️</button>
                                    <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteContribCat(cc.Id)">🗑️</button>
                                    <span><span class="cat-ico">@State.ContributionCategoryIcon(cc.Id)</span> @cc.Name</span>
                                </span>
                            </li>
                        }
                    </ul>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Close"]</button>
                        <button @onclick="OpenAddContribCat">➕ @Loc["Add category"]</button>
                    </div>
                    break;

                case Modal.AddSaving:
                    <h3>@Loc["Add to savings"] — @State.SavingBucketName(_savingBucketId)</h3>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_savingAmount" /></label>
                    <small class="hint">@Loc["Available to save:"] <strong>@Fmt(State.MaxAdditionalSavings)</strong> (@Loc["your cash that isn't already set aside for savings"]).</small>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="AllocateSaving" disabled="@(_savingAmount <= 0)">💰 @Loc["Add"]</button>
                    </div>
                    break;

                case Modal.BudgetSaving:
                    <h3>@Loc["Budget savings"] — @State.SavingBucketName(_spendBucketId)</h3>
                    <label>@Loc["Destination"]
                        <select @bind="_spendDestId">
                            <optgroup label="@Loc["Budgets"]">
                                @foreach (var (cat, depth) in State.CategoryOptions)
                                {
                                    <option value="@cat.Id">@CatOption(cat.Id, cat.Name, depth)</option>
                                }
                            </optgroup>
                            @if (State.SavingBuckets.Count > 1)
                            {
                                <optgroup label="@Loc["Savings buckets"]">
                                    @foreach (var (bucket, _) in State.SavingBuckets)
                                    {
                                        @if (bucket.Id != _spendBucketId)
                                        {
                                            <option value="@bucket.Id">@bucket.Name</option>
                                        }
                                    }
                                </optgroup>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_spendAmount" /></label>
                    <small class="hint">@Loc["A budget matures the saving into this month's plan; another bucket just shifts it across. The source bucket drops either way."]</small>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="MoveSaving" disabled="@(_spendAmount <= 0 || _spendDestId == Guid.Empty || _spendDestId == _spendBucketId)">➡️ @Loc["Move"]</button>
                    </div>
                    break;

                case Modal.SpendSaving:
                    <h3>@Loc["Spend savings"] — @State.SavingBucketName(_spendExpBucketId)</h3>
                    <label>@Loc["Category"]
                        <select @bind="_spendExpCategoryId">
                            @foreach (var (cat, depth) in State.CategoryOptions)
                            {
                                <option value="@cat.Id">@CatOption(cat.Id, cat.Name, depth)</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_spendExpAmount" /></label>
                    <small class="hint">@Loc["Records a real expense paid straight from this bucket (dated today)."]</small>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SpendBucketAsExpense" disabled="@(_spendExpAmount <= 0 || _spendExpCategoryId == Guid.Empty)">💸 @Loc["Spend"]</button>
                    </div>
                    break;

                case Modal.EditDeposit:
                    <h3>@Loc["Edit deposit"]</h3>
                    <label>@Loc["Category"]
                        <select @bind="_editContribCategoryId">
                            @foreach (var cc in State.ContributionCategories)
                            {
                                <option value="@cc.Id">@cc.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Fund"]
                        <select @bind="_editContribFundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_editContribAmount" /></label>
                    <label>@Loc["Date"] <input type="date" @bind="_editContribDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditDeposit" disabled="@(_editContribAmount <= 0)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteDeposit:
                    <h3>@Loc["Delete deposit?"]</h3>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteDeposit">@Loc["Delete"]</button>
                    </div>
                    break;

                case Modal.ContribCat:
                    <h3>@(_contribCatId == Guid.Empty ? Loc["New contribution category"] : Loc["Rename category"])</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_contribCatName" /></label>
                    <label class="icon-label">@Loc["Icon"]</label>
                    <div class="icon-grid">
                        <button type="button" class="icon-opt @(_fIcon is null ? "sel" : "")" title="@Loc["Auto (from name)"]" @onclick="() => _fIcon = null">@(string.IsNullOrEmpty(_contribCatName) ? "🏷️" : CategoryIcons.Guess(_contribCatName))</button>
                        @foreach (var ic in CategoryIcons.Palette)
                        {
                            <button type="button" class="icon-opt @(_fIcon == ic ? "sel" : "")" @onclick="() => _fIcon = ic">@ic</button>
                        }
                    </div>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveContribCat" disabled="@(string.IsNullOrWhiteSpace(_contribCatName))">@(_contribCatId == Guid.Empty ? Loc["Add"] : Loc["Save"])</button>
                    </div>
                    break;

                case Modal.DeleteContribCat:
                    <h3>@Loc["Remove category?"]</h3>
                    @if (State.ContributionCategoryRemovalBlocker(_contribCatId) is { } ccBlocker)
                    {
                        <p class="hint">@Loc["Can’t remove —"] @ccBlocker.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="Back">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        <p class="hint">@Loc["This removes the category permanently."]</p>
                        <div class="modal-actions">
                            <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                            <button class="danger-btn" @onclick="ConfirmDeleteContribCat">@Loc["Remove"]</button>
                        </div>
                    }
                    break;

                case Modal.EditSavingDeposit:
                    <h3>@Loc["Edit savings deposit —"] @State.SavingBucketName(_savingDepositBucketId)</h3>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_savingDepositAmount" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditSavingDeposit" disabled="@(_savingDepositAmount <= 0)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteSavingDeposit:
                    <h3>@Loc["Remove this savings deposit?"]</h3>
                    @if (State.FindSavingDeposit(_savingDepositId) is { } sd)
                    {
                        <p class="hint">@sd.Date.ToString("dd MMM") · @State.SavingBucketName(sd.SavingCategoryId) · @Fmt(sd.Amount)</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="Back">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteSavingDeposit">@Loc["Remove"]</button>
                    </div>
