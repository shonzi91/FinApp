@page "/"
@implements IDisposable
@inject BudgetingState State
@inject Localizer Loc
@inject IJSRuntime JS

@if (_busy)
{
    <div class="saving-pill">Saving…</div>
}

@if (!State.IsReady)
{
    <p class="loading">Loading…</p>
}
else if (!State.HasAccounts)
{
    <div class="firstrun">
        <div class="firstrun-mascot"><BudgieLogo /></div>
        <h1>@Loc["Welcome to Budgiely"]</h1>
        <p class="firstrun-lead">@Loc["Let’s feather your nest. Create your first account to get started (e.g. Personal, Shared, Family)."]</p>
        <InvitationsPanel />
        @if (_error is not null)
        {
            <div class="alert warn-bg"><span>@_error</span><button class="alert-x" title="@Loc["Dismiss"]" @onclick="() => _error = null">×</button></div>
        }
        <div class="firstrun-form">
            <label>@Loc["Account name"] <input type="text" placeholder="Personal" @bind="_fName" /></label>
            <label>@Loc["Currency"] <input type="text" maxlength="3" @bind="_fCurrency" /></label>
            <button @onclick="CreateFirstAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Create account"]</button>
        </div>
        <small class="hint">@Loc["It starts with a few starter categories and the current month’s period — you can change everything."]</small>
    </div>
}
else
{
<div class="dash @(_busy ? "is-busy" : "")">
    <header class="dash-head">
        <div class="head-main">
            <div class="acct-bar">
                <div class="acct-picker">
                    <select class="acct-select" value="@State.CurrentAccountId" @onchange="OnAccountChange">
                        @foreach (var a in State.Accounts)
                        {
                            <option value="@a.Id">@a.Name</option>
                        }
                    </select>
                </div>
                <span class="acct-ops">
                    @if (State.IsOwnerOfCurrent)
                    {
                        <button class="link" title="Rename account" @onclick="OpenEditAccount">✏️</button>
                    }
                    <button class="link" title="Add a new account" @onclick="OpenAddAccount">➕</button>
                    <button class="link" title="Invite a contributor" @onclick="OpenInvite">👥</button>
                    @if (State.IsOwnerOfCurrent)
                    {
                        <button class="link" title="Delete account" @onclick="OpenDeleteAccount">🗑️</button>
                    }
                    else
                    {
                        <span class="chip" title="You were invited to this account">shared</span>
                    }
                </span>
            </div>
            <div class="period-nav">
                <button class="nav" title="Previous period" @onclick="State.GoPrev" disabled="@(!State.CanGoPrev)">◀</button>
                <div class="period-row">
                    <span class="period">@State.Period.From.ToString("dd MMM") – @State.Period.To.ToString("dd MMM yyyy") (@State.PeriodNumber/@State.PeriodCount)</span>
                    <span class="period-ops">
                        <button class="exp-edit" title="Edit period dates" @onclick="OpenEditPeriod">📅</button>
                        @if (State.IsLatestPeriod && State.PeriodCount > 1)
                        {
                            <button class="exp-edit" title="Remove this period and reopen the previous one" @onclick="OpenRemovePeriod">🗑️</button>
                        }
                        @if (State.IsLatestPeriod)
                        {
                            <button class="exp-edit" title="Start next month" @onclick="OpenNextPeriod">⏭️</button>
                        }
                    </span>
                </div>
                <button class="nav" title="Next period" @onclick="State.GoNext" disabled="@(!State.CanGoNext)">▶</button>
            </div>
        </div>
        <div class="head-right">
            <span class="status">@Loc[State.IsPeriodOpen ? "Active" : "Closed"]</span>
            <div class="balances">
                <span class="bal" title="Sum of the period's opening fund values"><span class="bal-label">@Loc["Opening"]</span> <strong>@Fmt(State.OpeningBalance)</strong></span>
            </div>
        </div>
    </header>

    <InvitationsPanel />

    @if (_error is not null)
    {
        <div class="alert warn-bg"><strong>@Loc["Couldn’t do that."]</strong> <span>@_error</span><button class="alert-x" title="@Loc["Dismiss"]" @onclick="() => _error = null">×</button></div>
    }

    <nav class="tabs">
        <button class="tab @(_tab == Tab.Account ? "active" : "")" @onclick="() => _tab = Tab.Account">@Loc["Account"]</button>
        <button class="tab @(_tab == Tab.Budgets ? "active" : "")" @onclick="() => _tab = Tab.Budgets">@Loc["Budgets"]</button>
        <button class="tab @(_tab == Tab.Expenses ? "active" : "")" @onclick="ShowExpensesTab">@Loc["Expenses"]</button>
        <button class="tab @(_tab == Tab.Savings ? "active" : "")" @onclick="() => _tab = Tab.Savings">@Loc["Savings"]</button>
    </nav>

    @switch (_tab)
    {
        case Tab.Account:
            <section class="cards">
                <div class="card">
                    <span class="card-label">@Loc[State.IsPeriodOpen ? "Current" : "Closed on"]</span>
                    <span class="card-value">@Fmt(State.ClosingBalance)</span>
                    <span class="card-sub @(State.IsOverAllocated ? "warn-text" : "")">@Fmt(State.FreeToAllocate) @Loc["free to allocate"]</span>
                </div>
                <div class="card"><span class="card-label">@Loc["Spent"]</span><span class="card-value">@Fmt(State.TotalSpent)</span></div>
                <div class="card"><span class="card-label">@Loc["Budgeted"]</span><span class="card-value">@Fmt(State.TotalBudgeted)</span></div>
                <div class="card savings">
                    <span class="card-label">@Loc["Saved this period"]</span>
                    <span class="card-value">@Fmt(State.SavingsThisPeriod)</span>
                    @if (State.HasDeficit)
                    {
                        <span class="card-sub warn-text">@Fmt(State.Deficit) @Loc["not backed by cash"]</span>
                    }
                    else
                    {
                        <span class="card-sub">@PctOrDash(State.PeriodSavingsRate) @Loc["of contributions"]</span>
                    }
                </div>
            </section>

            @if (State.Deficit.Amount > 0)
            {
                <div class="alert warn-bg">
                    <strong>🪶 @Loc["Ruffled feathers — overspent by"] @Fmt(State.Deficit).</strong>
                    <span>@Loc["Expenses ate into your savings earmark. This will need to be covered next period (from a savings bucket or fresh contributions)."]</span>
                </div>
            }

            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Funds"]</h2>
                    <span class="head-actions">
                        <button class="link" title="Add a fund" @onclick="OpenAddFund">➕</button>
                    </span>
                </div>
                <ul class="list">
                    @foreach (var f in State.RootFunds)
                    {
                        <li>
                            <span class="row-lead">
                                <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => OpenEditFund(f.Id)">✏️</button>
                                <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteFund(f.Id)">🗑️</button>
                                <span class="fund-name">@f.Name</span>
                                @if (State.FundNote(f.Id) is { Length: > 0 } note)
                                {
                                    <span class="row-note">· @note</span>
                                }
                            </span>
                            <span class="row-ops">
                                <span class="amt">@Fmt(State.FundBalance(f.Id))</span>
                                @if (State.IsPeriodOpen)
                                {
                                    @if (CanTransfer)
                                    {
                                        <button class="exp-edit" title="@Loc["Transfer from this fund"]" @onclick="() => OpenTransferFromFund(f.Id)">🔁</button>
                                    }
                                    <button class="exp-edit" title="@Loc["Deposit to this fund"]" @onclick="() => OpenDepositToFund(f.Id)">➕</button>
                                }
                            </span>
                        </li>
                    }
                    @if (!State.RootFunds.Any())
                    {
                        <li><em>@Loc["No funds yet — add where your money lives."]</em></li>
                    }
                </ul>
            </section>

            @if (CanTransfer || MergedTransfers().Count > 0)
            {
                var transfers = MergedTransfers();
                <section class="panel">
                    <h2>@Loc["Transfer money"]</h2>
                    @if (CanTransfer)
                    {
                        <div class="form transfer-form">
                            <select @bind="_transferFromId">
                                @foreach (var f in State.RootFunds)
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                            <span class="arrow">→</span>
                            <select @bind="_transferDestId" @bind:after="OnInlineDestChanged">
                                <optgroup label="@Loc["Funds"]">
                                    @foreach (var f in State.RootFunds.Where(f => f.Id != _transferFromId))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </optgroup>
                                @if (State.TransferableAccounts.Any())
                                {
                                    <optgroup label="@Loc["Other accounts"]">
                                        @foreach (var a in State.TransferableAccounts)
                                        {
                                            <option value="@a.Id">📤 @a.Name</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            @if (TransferDestIsAccount && DestFundsFor(_transferDestId).Count > 0)
                            {
                                <select @bind="_transferDestFundId" title="@Loc["Destination fund"]">
                                    @foreach (var f in DestFundsFor(_transferDestId))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </select>
                            }
                            <input type="number" step="0.01" min="0" placeholder="@Loc["Amount"]" @bind="_transferAmount" />
                            <button title="@Loc["Transfer money"]" @onclick="DoTransfer" disabled="@(_transferAmount <= 0 || _transferDestId == Guid.Empty || _transferDestId == _transferFromId || _transferAmount > InlineTransferMax)">🔁</button>
                        </div>
                        @if (TransferDestIsAccount)
                        {
                            <small class="hint @(InlineTransferDipsSavings ? "warn-text" : "")">@Loc["Sending to another account leaves this one as an outflow."] @Loc["In this fund:"] <strong>@Fmt(State.FundBalance(_transferFromId))</strong>. @(InlineTransferDipsSavings ? Loc["⚠ This dips into money earmarked for savings."] : "")</small>
                        }
                        else
                        {
                            <small class="hint">@Loc["Move money between your funds — the total is unchanged, only where it sits."] @Loc["Available in this fund:"] <strong>@Fmt(State.FundBalance(_transferFromId))</strong></small>
                        }
                    }
                    @if (transfers.Any())
                    {
                        <ul class="list transfer-log">
                            @foreach (var t in transfers)
                            {
                                <li>
                                    <span>@t.Date.ToString("dd MMM") · @t.Label@(string.IsNullOrEmpty(t.Note) ? "" : $" · {t.Note}")</span>
                                    <span class="row-actions">
                                        <span class="amt">@Fmt(t.Amount)</span>
                                        @if (State.IsPeriodOpen && !t.IsExternal)
                                        {
                                            <button class="exp-edit" title="Edit transfer" @onclick="() => OpenEditTransfer(t.Id)">✏️</button>
                                            <button class="exp-edit" title="Remove transfer" @onclick="() => OpenDeleteTransfer(t.Id)">🗑️</button>
                                        }
                                        else if (State.IsPeriodOpen && t.IsExternal)
                                        {
                                            <button class="exp-edit" title="Remove this transfer (does not reverse the deposit in the other account)" @onclick="() => OpenDeleteExternalTransfer(t.Id)">🗑️</button>
                                        }
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }

            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Contributions"]</h2>
                    @if (State.IsPeriodOpen)
                    {
                        <span class="head-actions">
                            <button class="link" title="@Loc["Manage categories"]" @onclick="OpenManageContribCats">🏷️</button>
                            <button class="link" title="@Loc["Add a deposit"]" @onclick="OpenDeposit">➕ @Loc["Deposit"]</button>
                        </span>
                    }
                </div>

                <ul class="list">
                    @foreach (var c in State.ContributionsThisPeriod)
                    {
                        <li>
                            <span class="row-lead">
                                @if (State.IsPeriodOpen && State.CanHandleContribution(c))
                                {
                                    <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => OpenEditDeposit(c.Id)">✏️</button>
                                    <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteDeposit(c.Id)">🗑️</button>
                                }
                                <span>@c.Date.ToString("dd MMM") · @State.MemberName(c.MemberId) · @State.ContributionCategoryName(c.CategoryId) · @State.FundName(c.FundId)</span>
                            </span>
                            <span class="amt">@Fmt(c.Paid)</span>
                        </li>
                    }
                    @if (!State.ContributionsThisPeriod.Any())
                    {
                        <li><em>@Loc["Nothing in the nest yet — add a deposit."]</em></li>
                    }
                </ul>
            </section>

            break;

        case Tab.Budgets:
            <section class="cards cards-2">
                <div class="card"><span class="card-label">@Loc["Budgeted"]</span><span class="card-value">@Fmt(State.TotalBudgeted)</span></div>
                <div class="card"><span class="card-label">@Loc["Spent"]</span><span class="card-value">@Fmt(State.TotalSpent)</span></div>
            </section>
            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Budgets"]</h2>
                    <span>
                        <button class="link" title="Add a top-level category" @onclick="() => OpenAdd(null)">➕</button>
                    </span>
                </div>

                <div class="tree">
                    @foreach (var root in State.RootCategories)
                    {
                        <BudgetTreeNode Node="root" Depth="0" OnEdit="OpenEdit" OnAddSub="OpenAddSub" OnDelete="OpenDelete" OnAddExpense="OpenAddExpense" OnEditExpense="OpenEditExpense" OnDeleteExpense="OpenDeleteExpense" />
                    }
                </div>
            </section>
            break;

        case Tab.Expenses:
            <section class="cards cards-2">
                <div class="card"><span class="card-label">@Loc["Budgeted"]</span><span class="card-value">@Fmt(State.TotalBudgeted)</span></div>
                <div class="card"><span class="card-label">@Loc["Spent"]</span><span class="card-value">@Fmt(State.TotalSpent)</span></div>
            </section>
            @if (State.IsPeriodOpen)
            {
                <button class="big-add" @onclick="OpenAddExpenseTab">🧾 @Loc["Add expense"]</button>
            }

            <section class="panel">
                <div class="panel-head">
                    <h2>@(_dayView is { } dh ? dh.ToString("dd MMM yyyy") : Loc["All expenses"])</h2>
                    @if (_dayView is { } dv)
                    {
                        <span class="day-nav">
                            <button class="exp-edit" title="@Loc["Previous day"]" @onclick="PrevDay" disabled="@(dv <= State.Period.From)">◀</button>
                            <input type="date" @bind:get="dv" @bind:set="GoToDay" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" />
                            <button class="exp-edit" title="@Loc["Next day"]" @onclick="NextDay" disabled="@(dv >= State.Period.To)">▶</button>
                            <button class="link" @onclick="() => _dayView = null">@Loc["All days"]</button>
                        </span>
                    }
                </div>
                @{
                    RenderFragment<FinApp.Domain.Budgeting.Expense> row = e =>
                        @<li>
                            <span>
                                @State.CategoryName(e.CategoryId) · @State.FundName(e.FundId)@(e.IsFromSavings ? " · 💰saving" : "")@(string.IsNullOrEmpty(e.Note) ? "" : $" · {e.Note}")
                                @if (e.IsSettlementSource)
                                {
                                    <span class="settle-tag" title="@Loc["Settled onto another account"]">🤝 @Fmt(e.SettledMoney) → @State.AccountName(e.SettledToAccountId!.Value)</span>
                                }
                                else if (e.IsSettlementDestination)
                                {
                                    <span class="settle-tag" title="@Loc["Settled from another account"]">↩ @Loc["from"] @State.AccountName(e.SettledFromAccountId!.Value)</span>
                                }
                            </span>
                            <span class="row-actions">
                                <span class="amt">@Fmt(e.Amount)</span>
                                @if (State.IsPeriodOpen)
                                {
                                    @if (e.OnBehalfOfOtherAccount)
                                    {
                                        <button class="exp-edit" title="@Loc["Settle onto another account"]" @onclick="() => OpenSettleExpense(e.Id)">🤝</button>
                                    }
                                    <button class="exp-edit" title="Edit expense" @onclick="() => OpenEditExpense(e.Id)">✏️</button>
                                    <button class="exp-edit" title="Remove expense" @onclick="() => OpenDeleteExpense(e.Id)">🗑️</button>
                                }
                            </span>
                        </li>;
                    var shown = _dayView is { } dvf
                        ? State.AllExpenses.Where(e => e.Date == dvf).ToList()
                        : State.AllExpenses.ToList();
                }
                @if (!shown.Any())
                {
                    <ul class="list"><li><em>@Loc["Nothing’s perched here yet — add your first expense."]</em></li></ul>
                }
                else if (_dayView is not null)
                {
                    <ul class="list">@foreach (var e in shown) { @row(e) }</ul>
                }
                else
                {
                    @foreach (var grp in shown.GroupBy(e => e.Date).OrderByDescending(g => g.Key))
                    {
                        <button class="date-sep" @onclick="() => GoToDay(grp.Key)">@grp.Key.ToString("dddd, dd MMM yyyy")</button>
                        <ul class="list">@foreach (var e in grp) { @row(e) }</ul>
                    }
                }
            </section>
            break;

        case Tab.Savings:
            <section class="cards cards-2">
                <div class="card savings">
                    <span class="card-label">@Loc["Total saved"]</span>
                    <span class="card-value">@Fmt(State.SavingsAccumulated)</span>
                    <span class="card-sub">@PctOrDash(State.AccountSavingsRate) @Loc["all periods"]</span>
                </div>
                <div class="card savings">
                    <span class="card-label">@Loc["Saved this period"]</span>
                    <span class="card-value">@Fmt(State.SavingsThisPeriod)</span>
                    <span class="card-sub">@PctOrDash(State.PeriodSavingsRate) @Loc["of contributions"]</span>
                </div>
            </section>
            <section class="panel">
                <div class="panel-head">
                    <h2>@Loc["Savings buckets"]</h2>
                    <button class="link" title="Add a savings bucket" @onclick="OpenAddBucket">➕</button>
                </div>
                <ul class="bucket-list">
                    @foreach (var (bucket, total) in State.SavingBuckets)
                    {
                        <li class="bucket">
                            <div class="bucket-head">
                                <span class="row-lead">
                                    <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => OpenEditBucket(bucket.Id)">✏️</button>
                                    <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteBucket(bucket.Id)">🗑️</button>
                                    <span class="bucket-name">@bucket.Name</span>
                                </span>
                                <span class="bucket-actions">
                                    <span class="amt save">@Fmt(total)</span>
                                    @if (State.IsPeriodOpen)
                                    {
                                        <button class="exp-edit" title="@Loc["Add to savings"]" @onclick="() => OpenAddSaving(bucket.Id)">💰</button>
                                        <button class="exp-edit" title="@Loc["Budget savings"]" @onclick="() => OpenBudgetSaving(bucket.Id)">➡️</button>
                                        <button class="exp-edit" title="@Loc["Spend savings"]" @onclick="() => OpenSpendSaving(bucket.Id)">💸</button>
                                    }
                                </span>
                            </div>
                            @if (bucket.HasGoal)
                            {
                                var g = State.SavingGoal(bucket.Id);
                                var pct = g.Percent ?? 0;
                                var cls = g.GoalReached ? "ok" : g.ThresholdReached ? "warn" : "ok";
                                <div class="bucket-goal">
                                    <span class="tree-bar"><span class="tree-fill @cls" style="width:@(Math.Min(pct,100))%"></span></span>
                                    <span class="bucket-goal-pct">@pct% of @Fmt(g.Goal!.Value)@(g.GoalReached ? " ✓" : "")</span>
                                </div>
                            }
                        </li>
                    }
                    @if (!State.SavingBuckets.Any())
                    {
                        <li><em>@Loc["Your nest is empty — start a savings bucket and watch it grow."]</em></li>
                    }
                </ul>
            </section>

            @if (State.SavingDepositsThisPeriod.Any() || State.SavingMovementsThisPeriod.Any())
            {
                <section class="panel">
                    <h2>@Loc["Savings activity"]</h2>
                    <ul class="list">
                        @foreach (var d in State.SavingDepositsThisPeriod)
                        {
                            <li>
                                <span class="row-lead">
                                    @if (State.IsPeriodOpen)
                                    {
                                        <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => OpenEditSavingDeposit(d.Id)">✏️</button>
                                        <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteSavingDeposit(d.Id)">🗑️</button>
                                    }
                                    <span>@d.Date.ToString("dd MMM") · 💰 @State.SavingBucketName(d.SavingCategoryId)</span>
                                </span>
                                <span class="amt save">@Fmt(d.Amount)</span>
                            </li>
                        }
                        @foreach (var m in State.SavingMovementsThisPeriod)
                        {
                            <li>
                                <span class="row-lead">
                                    @if (State.IsPeriodOpen)
                                    {
                                        <button class="exp-edit" title="@Loc["Edit"]" @onclick="() => OpenEditSavingMovement(m.Id)">✏️</button>
                                        <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteSavingMovement(m.Id)">🗑️</button>
                                    }
                                    <span>@m.Date.ToString("dd MMM") · @MovementIcon(m) @State.SavingMovementTarget(m)</span>
                                </span>
                                <span class="amt save">@Fmt(State.Money(-m.Amount.Amount))</span>
                            </li>
                        }
                    </ul>
                </section>
            }
            break;
    }
</div>

@if (_modal != Modal.None)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation="true">
            @if (_modalError is not null)
            {
                <div class="modal-error">@_modalError</div>
            }
            @switch (_modal)
            {
                case Modal.AddCat:
                    <h3>@Loc["Add category"] @(_addParentId is {} p ? $"under {State.CategoryName(p)}" : "(top level)")</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <label>Budget for this period (optional) <input type="number" step="0.01" min="0" @bind="_fBudget" /></label>
                    <small class="hint @(State.IsOverAllocated ? "warn-text" : "")"><strong>@Fmt(State.FreeToAllocate)</strong> @Loc["free to allocate"]. @(State.IsOverAllocated ? Loc["Over-allocated — allowed, just a heads-up."] : "")</small>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveAddCat" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Add"]</button>
                    </div>
                    break;

                case Modal.EditCat:
                    <h3>@Loc["Edit"] @State.CategoryName(_modalCatId)</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <label>Budget amount <input type="number" step="0.01" min="0" @bind="_fBudget" /></label>
                    <small class="hint @(State.IsOverAllocated ? "warn-text" : "")"><strong>@Fmt(State.FreeToAllocate)</strong> @Loc["free to allocate"]. @(State.IsOverAllocated ? Loc["Over-allocated — allowed, just a heads-up."] : "")</small>
                    <label>Alert at % <input type="number" step="1" min="0" max="100" @bind="_fThreshold" /></label>
                    <label class="check"><input type="checkbox" @bind="_fNotify" /> Notify on every expense</label>
                    <div class="modal-actions">
                        @if (State.BudgetFor(_modalCatId) is not null)
                        {
                            <button class="ghost danger" @onclick="RemoveBudget">Remove budget</button>
                        }
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditCat" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteCat:
                    <h3>@Loc["Delete"] @State.CategoryName(_modalCatId)?</h3>
                    @if (State.CategoryRemovalBlocker(_modalCatId) is {} blocker)
                    {
                        <p class="hint">Can’t delete — @blocker. Remove those first.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        <p class="hint">This removes the category permanently.</p>
                        <div class="modal-actions">
                            <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                            <button class="danger-btn" @onclick="ConfirmDelete">@Loc["Delete"]</button>
                        </div>
                    }
                    break;

                case Modal.AddAccount:
                    <h3>@Loc["New account"]</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <label>Currency <input type="text" maxlength="3" @bind="_fCurrency" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveAddAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Create"]</button>
                    </div>
                    break;

                case Modal.EditAccount:
                    <h3>@Loc["Rename account"]</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <p class="hint">Currency (@State.Currency) can't be changed once an account exists.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditAccount" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteAccount:
                    <h3>@Loc["Delete"] @State.Account.Name?</h3>
                    <p class="hint">This permanently deletes the account and <strong>all its periods, budgets, expenses and savings</strong>. This can't be undone.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteAccount">Delete account</button>
                    </div>
                    break;

                case Modal.Invite:
                    <h3>@Loc["Invite to"] @State.Account.Name</h3>
                    <p class="hint">Enter the username of an existing FinApp user. They'll get a prompt to accept; once they do, they can edit everything except deleting the account.</p>
                    <label>Username <input type="text" @bind="_inviteUsername" @bind:event="oninput" /></label>
                    @if (_inviteMessage is not null)
                    {
                        <div class="alert">@_inviteMessage</div>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Close"]</button>
                        <button @onclick="SendInvite" disabled="@(string.IsNullOrWhiteSpace(_inviteUsername))">Send invite</button>
                    </div>
                    break;

                case Modal.AddExpense:
                    <h3>@Loc["Add expense"]</h3>
                    <label>@Loc["Category"]
                        <select @bind="_categoryId">
                            @foreach (var (cat, depth) in State.CategoryOptions)
                            {
                                <option value="@cat.Id">@IndentLabel(cat.Name, depth)</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_amount" /></label>
                    <label>@Loc["Date"] <input type="date" @bind="_expenseDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" /></label>
                    <label>@Loc["Fund"]
                        <select @bind="_fundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>Note (optional) <input type="text" @bind="_note" /></label>
                    @if (State.TransferableAccounts.Any())
                    {
                        <label class="check"><input type="checkbox" @bind="_onBehalfOther" /> @Loc["On behalf of another account (settle later)"]</label>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="AddExpenseFromModal" disabled="@(_amount <= 0)">@Loc["Add"]</button>
                    </div>
                    break;

                case Modal.RemovePeriod:
                    <h3>@Loc["Remove this period?"]</h3>
                    <p class="hint">This deletes period @State.PeriodNumber (@State.Period.From.ToString("dd MMM") – @State.Period.To.ToString("dd MMM yyyy")) and everything in it, then re-opens the previous period as active. This can't be undone.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmRemovePeriod">Remove period</button>
                    </div>
                    break;

                case Modal.NextPeriod:
                    <h3>@Loc["Start next month"]</h3>
                    <p class="hint">Enter what each fund really holds now (previous closing balance: <strong>@Fmt(State.Period.ExpectedClosingBalance)</strong>). These become the new period's opening balances — that money carries over and is fully available to budget or save.</p>
                    @foreach (var f in State.RootFunds)
                    {
                        <label>@f.Name <input type="number" step="0.01" @bind:get="GetRealOpening(f.Id)" @bind:set="v => SetRealOpening(f.Id, v)" /></label>
                    }
                    <label class="check"><input type="checkbox" @bind="_copyBudgets" /> Copy this period’s budgets forward</label>
                    @if (_copyBudgets)
                    {
                        <label class="check"><input type="checkbox" @bind="_adjustBudgets" /> @Loc["Adjust budgets to this period’s spending"]</label>
                        <small class="hint">@Loc["Each budget moves halfway toward what was actually spent, rounded up to the nearest 10."]</small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="ConfirmNextPeriod">Start next month →</button>
                    </div>
                    break;

                case Modal.EditExpense:
                    <h3>@Loc["Edit expense"]</h3>
                    <label>Category
                        <select @bind="_categoryId">
                            @foreach (var (cat, depth) in State.CategoryOptions)
                            {
                                <option value="@cat.Id">@IndentLabel(cat.Name, depth)</option>
                            }
                        </select>
                    </label>
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_amount" /></label>
                    <label>Date <input type="date" @bind="_expenseDate" /></label>
                    <label>Fund
                        <select @bind="_fundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>Note (optional) <input type="text" @bind="_note" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditExpense" disabled="@(_amount <= 0)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteExpense:
                    <h3>@Loc["Remove this expense?"]</h3>
                    @if (State.FindExpense(_editExpenseId) is { } ex)
                    {
                        <p class="hint">@ex.Date.ToString("dd MMM") · @State.CategoryName(ex.CategoryId) · @Fmt(ex.Amount)@(ex.IsFromSavings ? " — the savings drawdown will be restored." : "")</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteExpense">@Loc["Remove"]</button>
                    </div>
                    break;

                case Modal.SettleExpense:
                    <h3>@Loc["Settle onto another account"]</h3>
                    @if (State.FindExpense(_settleExpenseId) is { } se)
                    {
                        <p class="hint">@se.Date.ToString("dd MMM") · @State.CategoryName(se.CategoryId) · @Loc["Original:"] @Fmt(se.OriginalAmount)</p>
                    }
                    @if (!State.TransferableAccounts.Any())
                    {
                        <p class="hint">@Loc["You have no other same-currency account to settle onto."]</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        <label>@Loc["Account"]
                            <select @bind="_settleDestId" @bind:after="OnSettleDestChanged">
                                @foreach (var a in State.TransferableAccounts)
                                {
                                    <option value="@a.Id">@a.Name</option>
                                }
                            </select>
                        </label>
                        <label>@Loc["Destination fund"]
                            <select @bind="_settleDestFundId">
                                @foreach (var f in DestFundsFor(_settleDestId))
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                        </label>
                        <label>@Loc["Category"]
                            <select @bind="_settleDestCatId">
                                @foreach (var c in DestCatsFor(_settleDestId))
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        </label>
                        <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_settleAmount" /></label>
                        <label>Note (optional) <input type="text" @bind="_settleNote" /></label>
                        <small class="hint">@Loc["Records this amount as an expense on the chosen account (in that fund and category) and reduces this expense by the same amount."]</small>
                        <div class="modal-actions">
                            @if (_settleIsEdit)
                            {
                                <button class="ghost danger" @onclick="UnsettleFromModal">@Loc["Unsettle"]</button>
                            }
                            <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                            <button @onclick="ConfirmSettleExpense" disabled="@(_settleAmount <= 0 || _settleDestId == Guid.Empty)">🤝 @(_settleIsEdit ? Loc["Save"] : Loc["Settle"])</button>
                        </div>
                    }
                    break;

                case Modal.AddBucket:
                case Modal.EditBucket:
                    <h3>@(_modal == Modal.AddBucket ? "New savings bucket" : $"Edit {State.FindSavingBucket(_modalBucketId)?.Name}")</h3>
                    <label>Name <input type="text" @bind="_fName" /></label>
                    <label>Goal amount (optional) <input type="number" step="0.01" min="0" @bind="_goalAmount" /></label>
                    <label>Alert at % <input type="number" step="1" min="0" max="100" @bind="_fThreshold" /></label>
                    <label class="check"><input type="checkbox" @bind="_fNotify" /> Notify on milestone</label>
                    @if (State.CanSetInitialSavings)
                    {
                        <label>Already saved (starting balance) <input type="number" step="0.01" min="0" @bind="_initialSavings" /></label>
                        <small class="hint">Money you already had in this bucket before using FinApp. It counts toward the balance and goal, but not toward your savings rate.</small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveBucket" disabled="@(string.IsNullOrWhiteSpace(_fName))">@(_modal == Modal.AddBucket ? "Add" : "Save")</button>
                    </div>
                    break;

                case Modal.Transfer:
                    <h3>@Loc["Transfer from"] @State.FundName(_mTransferFromId)</h3>
                    <label>@Loc["To"]
                        <select @bind="_mTransferDestId" @bind:after="OnModalDestChanged">
                            <optgroup label="@Loc["Funds"]">
                                @foreach (var f in State.RootFunds.Where(f => f.Id != _mTransferFromId))
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </optgroup>
                            @if (State.TransferableAccounts.Any())
                            {
                                <optgroup label="@Loc["Other accounts"]">
                                    @foreach (var a in State.TransferableAccounts)
                                    {
                                        <option value="@a.Id">📤 @a.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </label>
                    @if (MTransferDestIsAccount && DestFundsFor(_mTransferDestId).Count > 0)
                    {
                        <label>@Loc["Destination fund"]
                            <select @bind="_mTransferDestFundId">
                                @foreach (var f in DestFundsFor(_mTransferDestId))
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                        </label>
                    }
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_mTransferAmount" /></label>
                    @if (MTransferDestIsAccount)
                    {
                        <small class="hint @(MTransferDipsSavings ? "warn-text" : "")">@Loc["In this fund:"] <strong>@Fmt(State.FundBalance(_mTransferFromId))</strong>. @(MTransferDipsSavings ? Loc["⚠ This dips into money earmarked for savings."] : "")</small>
                    }
                    else
                    {
                        <small class="hint">@Loc["Available in this fund:"] <strong>@Fmt(State.FundBalance(_mTransferFromId))</strong></small>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="ConfirmTransfer" disabled="@(_mTransferAmount <= 0 || _mTransferDestId == Guid.Empty || _mTransferDestId == _mTransferFromId || _mTransferAmount > MTransferMax)">🔁 @Loc["Transfer money"]</button>
                    </div>
                    break;

                case Modal.Deposit:
                    <h3>@Loc["Add a deposit"]</h3>
                    <label>@Loc["Category"]
                        <select @bind="_depCategoryId">
                            @foreach (var cc in State.ContributionCategories)
                            {
                                <option value="@cc.Id">@cc.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Fund"]
                        <select @bind="_depFundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_depAmount" /></label>
                    <label>@Loc["Date"] <input type="date" @bind="_depDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="RecordDeposit" disabled="@(_depAmount <= 0)">@Loc["Deposit"]</button>
                    </div>
                    break;

                case Modal.ManageContribCats:
                    <h3>@Loc["Contribution categories"]</h3>
                    <ul class="list">
                        @foreach (var cc in State.ContributionCategories)
                        {
                            <li>
                                <span class="row-lead">
                                    <button class="exp-edit" title="@Loc["Rename"]" @onclick="() => OpenEditContribCat(cc.Id)">✏️</button>
                                    <button class="exp-edit" title="@Loc["Remove"]" @onclick="() => OpenDeleteContribCat(cc.Id)">🗑️</button>
                                    <span>@cc.Name</span>
                                </span>
                            </li>
                        }
                    </ul>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Close"]</button>
                        <button @onclick="OpenAddContribCat">➕ @Loc["Add category"]</button>
                    </div>
                    break;

                case Modal.AddSaving:
                    <h3>@Loc["Add to savings"] — @State.SavingBucketName(_savingBucketId)</h3>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_savingAmount" /></label>
                    <small class="hint">@Loc["Available to save:"] <strong>@Fmt(State.MaxAdditionalSavings)</strong> (@Loc["your cash that isn't already set aside for savings"]).</small>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="AllocateSaving" disabled="@(_savingAmount <= 0)">💰 @Loc["Add"]</button>
                    </div>
                    break;

                case Modal.BudgetSaving:
                    <h3>@Loc["Budget savings"] — @State.SavingBucketName(_spendBucketId)</h3>
                    <label>@Loc["Destination"]
                        <select @bind="_spendDestId">
                            <optgroup label="@Loc["Budgets"]">
                                @foreach (var (cat, depth) in State.CategoryOptions)
                                {
                                    <option value="@cat.Id">@IndentLabel(cat.Name, depth)</option>
                                }
                            </optgroup>
                            @if (State.SavingBuckets.Count > 1)
                            {
                                <optgroup label="@Loc["Savings buckets"]">
                                    @foreach (var (bucket, _) in State.SavingBuckets)
                                    {
                                        @if (bucket.Id != _spendBucketId)
                                        {
                                            <option value="@bucket.Id">@bucket.Name</option>
                                        }
                                    }
                                </optgroup>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_spendAmount" /></label>
                    <small class="hint">@Loc["A budget matures the saving into this month's plan; another bucket just shifts it across. The source bucket drops either way."]</small>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="MoveSaving" disabled="@(_spendAmount <= 0 || _spendDestId == Guid.Empty || _spendDestId == _spendBucketId)">➡️ @Loc["Move"]</button>
                    </div>
                    break;

                case Modal.SpendSaving:
                    <h3>@Loc["Spend savings"] — @State.SavingBucketName(_spendExpBucketId)</h3>
                    <label>@Loc["Category"]
                        <select @bind="_spendExpCategoryId">
                            @foreach (var (cat, depth) in State.CategoryOptions)
                            {
                                <option value="@cat.Id">@IndentLabel(cat.Name, depth)</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_spendExpAmount" /></label>
                    <small class="hint">@Loc["Records a real expense paid straight from this bucket (dated today)."]</small>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SpendBucketAsExpense" disabled="@(_spendExpAmount <= 0 || _spendExpCategoryId == Guid.Empty)">💸 @Loc["Spend"]</button>
                    </div>
                    break;

                case Modal.EditDeposit:
                    <h3>@Loc["Edit deposit"]</h3>
                    <label>@Loc["Category"]
                        <select @bind="_editContribCategoryId">
                            @foreach (var cc in State.ContributionCategories)
                            {
                                <option value="@cc.Id">@cc.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Fund"]
                        <select @bind="_editContribFundId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>@Loc["Amount"] <input type="number" step="0.01" min="0" @bind="_editContribAmount" /></label>
                    <label>@Loc["Date"] <input type="date" @bind="_editContribDate" min="@State.Period.From.ToString("yyyy-MM-dd")" max="@State.Period.To.ToString("yyyy-MM-dd")" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditDeposit" disabled="@(_editContribAmount <= 0)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteDeposit:
                    <h3>@Loc["Delete deposit?"]</h3>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteDeposit">@Loc["Delete"]</button>
                    </div>
                    break;

                case Modal.ContribCat:
                    <h3>@(_contribCatId == Guid.Empty ? Loc["New contribution category"] : Loc["Rename category"])</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_contribCatName" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveContribCat" disabled="@(string.IsNullOrWhiteSpace(_contribCatName))">@(_contribCatId == Guid.Empty ? Loc["Add"] : Loc["Save"])</button>
                    </div>
                    break;

                case Modal.DeleteContribCat:
                    <h3>@Loc["Remove category?"]</h3>
                    @if (State.ContributionCategoryRemovalBlocker(_contribCatId) is { } ccBlocker)
                    {
                        <p class="hint">Can’t remove — @ccBlocker.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        <p class="hint">@Loc["This removes the category permanently."]</p>
                        <div class="modal-actions">
                            <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                            <button class="danger-btn" @onclick="ConfirmDeleteContribCat">@Loc["Remove"]</button>
                        </div>
                    }
                    break;

                case Modal.EditSavingDeposit:
                    <h3>Edit savings deposit — @State.SavingBucketName(_savingDepositBucketId)</h3>
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_savingDepositAmount" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditSavingDeposit" disabled="@(_savingDepositAmount <= 0)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteSavingDeposit:
                    <h3>@Loc["Remove this savings deposit?"]</h3>
                    @if (State.FindSavingDeposit(_savingDepositId) is { } sd)
                    {
                        <p class="hint">@sd.Date.ToString("dd MMM") · @State.SavingBucketName(sd.SavingCategoryId) · @Fmt(sd.Amount)</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteSavingDeposit">@Loc["Remove"]</button>
                    </div>
                    break;

                case Modal.DeleteBucket:
                    <h3>@Loc["Remove"] @State.FindSavingBucket(_modalBucketId)?.Name?</h3>
                    @if (State.SavingBucketRemovalBlocker(_modalBucketId) is {} bucketBlocker)
                    {
                        <p class="hint">Can’t remove — @bucketBlocker. Spend or move its savings first.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        <p class="hint">This removes the empty bucket permanently.</p>
                        <div class="modal-actions">
                            <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                            <button class="danger-btn" @onclick="ConfirmDeleteBucket">@Loc["Remove"]</button>
                        </div>
                    }
                    break;

                case Modal.AddFund:
                    <h3>@Loc["New fund"]</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_fName" /></label>
                    <label>@Loc["Note (optional)"] <input type="text" @bind="_fundNote" /></label>
                    <label>@Loc["Opening balance this period (optional)"] <input type="number" step="0.01" min="0" @bind="_openingAmount" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveFund" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Add"]</button>
                    </div>
                    break;

                case Modal.EditFund:
                    <h3>@Loc["Edit"] @State.FundName(_modalFundId)</h3>
                    <label>@Loc["Name"] <input type="text" @bind="_fName" /></label>
                    <label>@Loc["Note (optional)"] <input type="text" @bind="_fundNote" /></label>
                    <label>@Loc["Opening balance this period"] <input type="number" step="0.01" min="0" @bind="_openingAmount" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveFund" disabled="@(string.IsNullOrWhiteSpace(_fName))">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteFund:
                    <h3>@Loc["Remove"] @State.FundName(_modalFundId)?</h3>
                    @if (State.FundRemovalBlocker(_modalFundId) is {} fundBlocker)
                    {
                        <p class="hint">Can’t remove — @fundBlocker.</p>
                        <div class="modal-actions"><button class="ghost" @onclick="CloseModal">@Loc["Close"]</button></div>
                    }
                    else
                    {
                        @if (State.FundHasOpeningBalance(_modalFundId))
                        {
                            <p class="hint">This fund has an opening balance. Move it to another fund, or remove it as-is (the balance is dropped).</p>
                            <label>Move balance to
                                <select @bind="_moveBalanceToId">
                                    <option value="@Guid.Empty">— don't move —</option>
                                    @foreach (var f in State.RootFunds.Where(f => f.Id != _modalFundId))
                                    {
                                        <option value="@f.Id">@f.Name</option>
                                    }
                                </select>
                            </label>
                        }
                        else
                        {
                            <p class="hint">This removes the fund permanently.</p>
                        }
                        <div class="modal-actions">
                            <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                            <button class="danger-btn" @onclick="ConfirmDeleteFund">@Loc["Remove"]</button>
                        </div>
                    }
                    break;

                case Modal.EditTransfer:
                    <h3>@Loc["Edit transfer"]</h3>
                    <label>From
                        <select @bind="_editTransferFromId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>To
                        <select @bind="_editTransferToId">
                            @foreach (var f in State.RootFunds)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_editTransferAmount" /></label>
                    <label>Note (optional) <input type="text" @bind="_editTransferNote" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditTransfer" disabled="@(_editTransferAmount <= 0 || _editTransferFromId == _editTransferToId)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteTransfer:
                    <h3>@Loc["Remove this transfer?"]</h3>
                    @if (State.FindFundTransfer(_editTransferId) is { } tr)
                    {
                        <p class="hint">@tr.Date.ToString("dd MMM") · @State.FundName(tr.FromFundId) → @State.FundName(tr.ToFundId) · @Fmt(tr.Amount)</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteTransfer">@Loc["Remove"]</button>
                    </div>
                    break;

                case Modal.EditPeriod:
                    <h3>@Loc["Edit period dates"]</h3>
                    <label>From <input type="date" @bind="_periodFrom" /></label>
                    <label>To <input type="date" @bind="_periodTo" /></label>
                    <p class="hint">Later periods shift to stay contiguous, keeping their own lengths.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditPeriod" disabled="@(_periodTo < _periodFrom)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.EditSavingMovement:
                    <h3>@Loc["Edit savings movement"]</h3>
                    @if (State.FindSavingMovement(_savingMovementId) is { } mv)
                    {
                        <p class="hint">@State.SavingMovementTarget(mv)</p>
                    }
                    <label>Amount <input type="number" step="0.01" min="0" @bind="_savingMovementAmount" /></label>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button @onclick="SaveEditSavingMovement" disabled="@(_savingMovementAmount <= 0)">@Loc["Save"]</button>
                    </div>
                    break;

                case Modal.DeleteSavingMovement:
                    <h3>Undo this savings movement?</h3>
                    @if (State.FindSavingMovement(_savingMovementId) is { } mvd)
                    {
                        <p class="hint">@mvd.Date.ToString("dd MMM") · @State.SavingMovementTarget(mvd) · @Fmt(State.Money(-mvd.Amount.Amount)). @(mvd.BudgetCategoryId is not null ? "The funded budget is reduced by this amount." : "Both buckets are restored.")</p>
                    }
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteSavingMovement">Undo</button>
                    </div>
                    break;

                case Modal.DeleteExternalTransfer:
                    <h3>@Loc["Remove this outgoing transfer?"]</h3>
                    @if (State.FindExternalTransfer(_extTransferId) is { } et)
                    {
                        <p class="hint">@et.Date.ToString("dd MMM") · @State.FundName(et.FundId) → @State.AccountName(et.ToAccountId ?? Guid.Empty) · @Fmt(et.Amount)</p>
                    }
                    <p class="hint warn-text">This only removes the outflow on this side. It does not reverse the deposit already recorded in the other account.</p>
                    <div class="modal-actions">
                        <button class="ghost" @onclick="CloseModal">@Loc["Cancel"]</button>
                        <button class="danger-btn" @onclick="ConfirmDeleteExternalTransfer">@Loc["Remove"]</button>
                    </div>
                    break;
            }
        </div>
    </div>
}
}

