@* Small round avatar: the person's server-stored picture if available, else a colored initial.
   The picture (a data-URL) is passed in by the caller (from the user's profile or an account's member
   avatars). No storage/JS here — it's a pure presentational component. *@
<span class="av" style="width:@(Size)px;height:@(Size)px;font-size:@(Size * 0.42)px;@(HasImage ? "" : $"background:{Color};")" title="@Name">
    @if (HasImage)
    {
        <img src="@Picture" alt="" />
    }
    else
    {
        @Initial
    }
</span>

@code {
    [Parameter] public string? Name { get; set; }

    /// <summary>The avatar image as a data-URL, or null to show the colored initial.</summary>
    [Parameter] public string? Picture { get; set; }

    [Parameter] public int Size { get; set; } = 24;

    private bool HasImage => !string.IsNullOrEmpty(Picture);
    private string Initial => (Name ?? "?").Trim() is { Length: > 0 } n ? n[..1].ToUpperInvariant() : "?";

    // Stable hue from the name so each person keeps the same colour.
    private string Color
    {
        get
        {
            var s = Name ?? "";
            var h = 0;
            foreach (var c in s) h = (h * 31 + c) % 360;
            return $"hsl({h}, 55%, 62%)";
        }
    }
}
