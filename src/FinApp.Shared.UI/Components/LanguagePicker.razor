@inject Localizer Loc
@implements IDisposable

@* Icon-only language switcher: a 🌐 globe button opens a dropdown of language names.
   Flag emoji are avoided on purpose — they render as bare letters ("GB"/"BG") on Windows. *@
<div class="langpick">
    <button class="langpick-btn" title="@Loc["Language"]" @onclick="Toggle"><span class="langpick-flag">@Loc.CultureFlag</span></button>
    @if (_open)
    {
        <div class="langpick-backdrop" @onclick="Close"></div>
        <div class="langpick-menu">
            @foreach (var (code, name, flag) in Localizer.Languages)
            {
                <button class="langpick-item @(Loc.Culture == code ? "sel" : "")" @onclick="() => Pick(code)">
                    <span class="langpick-flag">@flag</span>
                    <span class="langpick-name">@name</span>
                    @if (Loc.Culture == code)
                    {
                        <span class="langpick-check">✓</span>
                    }
                </button>
            }
        </div>
    }
</div>

@code {
    private bool _open;

    private void Toggle() => _open = !_open;
    private void Close() => _open = false;

    private async Task Pick(string code)
    {
        _open = false;
        await Loc.SetCultureAsync(code);
    }

    protected override void OnInitialized() => Loc.Changed += OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.Changed -= OnChanged;
}
