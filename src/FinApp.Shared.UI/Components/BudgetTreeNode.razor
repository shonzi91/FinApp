@inject BudgetingState State

<div class="tree-row @(Depth > 0 ? "tree-child" : "")">
    <span class="tree-lead" style="padding-left:@(Depth * 20)px">
        @if (Depth > 0)
        {
            <span class="tree-twig">↳</span>
        }
        <span class="tree-actions">
            <button title="Edit budget / rename" @onclick="() => OnEdit.InvokeAsync(Node.Id)">✏️</button>
            <button title="Add sub-category" @onclick="() => OnAddSub.InvokeAsync(Node.Id)">➕</button>
            <button title="Delete category" @onclick="() => OnDelete.InvokeAsync(Node.Id)">🗑️</button>
        </span>
        <span class="tree-name @(Depth > 0 ? "tree-name-child" : "")">@Node.Name</span>
    </span>

    @if (State.BudgetFor(Node.Id) is not null)
    {
        var cov = State.Coverage(Node.Id);
        var pct = cov.Percent ?? 0;
        var cls = cov.IsOverBudget ? "over" : cov.ThresholdReached ? "warn" : "ok";
        <span class="tree-amt">@Fmt(cov.Spent) / @Fmt(cov.Allocated)</span>
        <span class="tree-exp">
            @if (State.IsPeriodOpen)
            {
                <button title="Add expense in this category" @onclick="() => OnAddExpense.InvokeAsync(Node.Id)">🧾</button>
            }
        </span>
        <span class="tree-bar"><span class="tree-fill @cls" style="width:@(Math.Min(pct,100))%"></span></span>
        <span class="tree-pct @cls">@pct%</span>
    }
    else
    {
        <span class="tree-amt tree-nobudget">no budget</span>
        <span class="tree-exp">
            @if (State.IsPeriodOpen)
            {
                <button title="Add expense in this category" @onclick="() => OnAddExpense.InvokeAsync(Node.Id)">🧾</button>
            }
        </span>
    }
</div>

@{
    var expenses = State.ExpensesFor(Node.Id);
}
@if (expenses.Count > 0)
{
    <button class="exp-toggle" style="margin-left:@(16 + Depth * 20)px" @onclick="() => _expanded = !_expanded">
        @(_expanded ? "▾" : "▸") @expenses.Count @(expenses.Count == 1 ? "expense" : "expenses")
    </button>
}
@if (expenses.Count > 0 && _expanded)
{
    <ul class="tree-expenses" style="padding-left:@(16 + Depth * 20)px">
        @foreach (var e in expenses)
        {
            <li>
                <span class="exp-left">
                    @if (State.IsPeriodOpen)
                    {
                        <button class="exp-edit" title="Edit expense" @onclick="() => OnEditExpense.InvokeAsync(e.Id)">✏️</button>
                        <button class="exp-edit" title="Remove expense" @onclick="() => OnDeleteExpense.InvokeAsync(e.Id)">🗑️</button>
                    }
                    <span class="exp-meta">@e.Date.ToString("dd MMM") · @State.FundName(e.FundId) 🏦@(e.IsFromSavings ? " · 💰saving" : "")@(string.IsNullOrEmpty(e.Note) ? "" : $" · {e.Note}")</span>
                </span>
                <span class="exp-amt">@Fmt(e.Amount)</span>
            </li>
        }
    </ul>
}

@foreach (var child in State.ChildrenOf(Node.Id))
{
    <BudgetTreeNode Node="child" Depth="Depth + 1" OnEdit="OnEdit" OnAddSub="OnAddSub" OnDelete="OnDelete" OnAddExpense="OnAddExpense" OnEditExpense="OnEditExpense" OnDeleteExpense="OnDeleteExpense" />
}

@code {
    [Parameter, EditorRequired] public Category Node { get; set; } = default!;
    [Parameter] public int Depth { get; set; }
    [Parameter] public EventCallback<Guid> OnEdit { get; set; }
    [Parameter] public EventCallback<Guid> OnAddSub { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }
    [Parameter] public EventCallback<Guid> OnAddExpense { get; set; }
    [Parameter] public EventCallback<Guid> OnEditExpense { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteExpense { get; set; }

    private bool _expanded;

    private string Fmt(Money m)
    {
        var symbol = m.Currency switch { "EUR" => "€", "USD" => "$", "GBP" => "£", _ => m.Currency + " " };
        return $"{symbol}{m.Amount:N2}";
    }
}
