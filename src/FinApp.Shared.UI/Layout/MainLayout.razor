@inherits LayoutComponentBase
@implements IDisposable
@inject AuthState Auth
@inject BudgetingState State
@inject Localizer Loc
@inject FinAppApiClient Api
@inject IJSRuntime JS

<div class="app-shell">
    @if (Auth.IsAuthenticated)
    {
        <header class="app-bar">
            <span class="brand"><span class="brand-logo"><TandemLogo /></span><span class="brand-word">Tandem<span class="brand-tab">Tab</span></span></span>
            <span class="appbar-user">
                <LanguagePicker />
                <span class="appbar-id">
                    <button class="avatar" title="@Loc["Profile settings"]" @onclick="OpenProfile">
                        @if (Auth.CurrentUser?.Avatar is { } pic)
                        {
                            <img src="@pic" alt="" />
                        }
                        else
                        {
                            <span>@Initial</span>
                        }
                    </button>
                    <button class="user" title="@Loc["Profile settings"]" @onclick="OpenProfile">@Loc["Hello,"] @Auth.CurrentUser!.Username</button>
                </span>
                <button class="link" @onclick="SignOut">@Loc["Sign out"]</button>
            </span>
        </header>
    }
    <main class="app-body">
        @if (!_restored)
        {
            <div class="loading"><Spinner Block="true" Text="@Loc["Loading…"]" /></div>
        }
        else if (!Auth.IsAuthenticated)
        {
            <AuthPanel />
        }
        else if (_loginConsent == false)
        {
            <div class="consent-gate">
                <div class="consent-card">
                    <h2>@Loc["Before you start"]</h2>
                    <p>@Loc["To use TandemTab, please review and accept our terms."]</p>
                    <p class="consent-links">
                        <a href="@PrivacyUrl" target="_blank" rel="noopener">@Loc["Privacy"]</a> ·
                        <a href="@TermsUrl" target="_blank" rel="noopener">@Loc["Terms"]</a>
                    </p>
                    <label class="check"><input type="checkbox" @bind="_consentChecked" /> @Loc["I have read and accept the Terms of Service and Privacy Policy."]</label>
                    <button class="primary" @onclick="AcceptLoginConsent" disabled="@(!_consentChecked || _consentBusy)">@Loc["Accept & continue"]</button>
                </div>
            </div>
        }
        else
        {
            @Body
        }
    </main>

    @if (_restored)
    {
        <footer class="app-legal">
            <a href="@PrivacyUrl" target="_blank" rel="noopener">@Loc["Privacy"]</a>
            <span>·</span>
            <a href="@TermsUrl" target="_blank" rel="noopener">@Loc["Terms"]</a>
        </footer>
    }

    @if (_profileOpen)
    {
        <div class="pm-backdrop">
            <div class="pm">
                <h3>@Loc["Profile settings"]</h3>
                <p class="pm-who">@Auth.CurrentUser!.Username@(SameUsernameAndEmail ? "" : $" · {Auth.CurrentUser!.Email}")</p>
                <h4>@Loc["Appearance"]</h4>
                <label class="pm-theme-row">
                    <span>@Loc["Dark theme"]</span>
                    <span class="switch @(_dark ? "on" : "")">
                        <input type="checkbox" checked="@_dark" @onchange="ToggleTheme" />
                        <span class="switch-track"><span class="switch-thumb"></span></span>
                    </span>
                </label>
                <h4>@Loc["Profile picture"]</h4>
                <div class="pm-avatar-row">
                    <span class="pm-avatar">
                        @if (Auth.CurrentUser?.Avatar is { } pic)
                        {
                            <img src="@pic" alt="" />
                        }
                        else
                        {
                            <span>@Initial</span>
                        }
                    </span>
                    <button class="ghost" @onclick="PickAvatar" disabled="@_avatarBusy">@Loc["Upload"]</button>
                    @if (Auth.CurrentUser?.Avatar is not null)
                    {
                        <button class="ghost danger" @onclick="RemoveAvatar" disabled="@_avatarBusy">@Loc["Remove"]</button>
                    }
                </div>
                @if (_avatarError is not null)
                {
                    <div class="pm-msg pm-error">@_avatarError</div>
                }
                @if (Auth.CurrentUser!.IsExternal)
                {
                    <h4>@Loc["Sign-in"]</h4>
                    <p class="pm-hint">@string.Format(Loc["You sign in with {0} — there's no password to manage."], ProviderName)</p>
                }
                else
                {
                    <h4>@Loc["Change password"]</h4>
                    @if (_pwdError is not null)
                    {
                        <div class="pm-msg pm-error">@_pwdError</div>
                    }
                    @if (_pwdOk)
                    {
                        <div class="pm-msg pm-ok">@Loc["Password changed."]</div>
                    }
                    <label>@Loc["Current password"] <input type="password" @bind="_curPwd" /></label>
                    <label>@Loc["New password"] <input type="password" @bind="_newPwd" /></label>
                    <label>@Loc["Confirm new password"] <input type="password" @bind="_confirmPwd" /></label>
                }
                @if (_archived.Count > 0)
                {
                    <h4>@Loc["Archived accounts"]</h4>
                    <p class="pm-hint">@Loc["Archived accounts are deleted after 30 days. Restore one to bring it back."]</p>
                    <ul class="pm-archived">
                        @foreach (var a in _archived)
                        {
                            var aid = a.Id;
                            <li>
                                <span class="pm-arch-name">@a.Name <span class="pm-hint">· @DaysLeft(a.PurgeAt)</span></span>
                                <button class="ghost" @onclick="() => Reactivate(aid)" disabled="@_archiveBusy">@Loc["Restore"]</button>
                            </li>
                        }
                    </ul>
                }
                <div class="pm-actions">
                    <button class="ghost" @onclick="CloseProfile">@Loc["Close"]</button>
                    @if (!Auth.CurrentUser!.IsExternal)
                    {
                        <button @onclick="ChangePassword" disabled="@(_pwdBusy || _curPwd.Length == 0 || _newPwd.Length < 8)">@Loc["Change password"]</button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _restored;
    private bool _avatarBusy;
    private bool _dark;
    private string? _avatarError;
    private string Initial => (Auth.CurrentUser?.Username ?? "?").Trim() is { Length: > 0 } u ? u[..1].ToUpperInvariant() : "?";

    // Hide the redundant email when it's identical to the username (common for external sign-ups).
    private bool SameUsernameAndEmail =>
        string.Equals(Auth.CurrentUser?.Username, Auth.CurrentUser?.Email, StringComparison.OrdinalIgnoreCase);
    // "google" -> "Google" for the sign-in note.
    private string ProviderName => Auth.CurrentUser?.Provider is { Length: > 0 } p ? char.ToUpperInvariant(p[0]) + p[1..] : "";

    // Static legal pages in wwwroot; serve the Bulgarian variant when the UI is in Bulgarian.
    private string PrivacyUrl => Loc.Culture == "bg" ? "/privacy.bg.html" : "/privacy.html";
    private string TermsUrl => Loc.Culture == "bg" ? "/terms.bg.html" : "/terms.html";

    private bool _profileOpen, _pwdBusy, _pwdOk, _archiveBusy;
    private string _curPwd = "", _newPwd = "", _confirmPwd = "";
    private string? _pwdError;
    private List<ArchivedAccountDto> _archived = [];

    private async Task OpenProfile()
    {
        _profileOpen = true; _curPwd = _newPwd = _confirmPwd = ""; _pwdError = null; _pwdOk = false;
        try { _archived = await State.GetArchivedAccounts(); } catch { _archived = []; }
        StateHasChanged();
    }
    private void CloseProfile() => _profileOpen = false;

    private async Task Reactivate(Guid accountId)
    {
        _archiveBusy = true;
        try
        {
            await State.ReactivateAccount(accountId);
            _archived = _archived.Where(a => a.Id != accountId).ToList();
        }
        catch { /* surfaced elsewhere */ }
        finally { _archiveBusy = false; }
    }

    /// <summary>"5 days left" style copy for the purge deadline.</summary>
    private string DaysLeft(DateTimeOffset purgeAt)
    {
        var days = Math.Max(0, (int)Math.Ceiling((purgeAt - DateTimeOffset.UtcNow).TotalDays));
        return string.Format(Loc["{0} days left"], days);
    }

    private async Task ChangePassword()
    {
        _pwdError = null; _pwdOk = false;
        if (_newPwd != _confirmPwd) { _pwdError = Loc["The new passwords don’t match."]; return; }
        if (_newPwd.Length < 8) { _pwdError = Loc["Password must be at least 8 characters."]; return; }
        _pwdBusy = true;
        try
        {
            await Api.ChangePasswordAsync(_curPwd, _newPwd);
            _pwdOk = true; _curPwd = _newPwd = _confirmPwd = "";
        }
        catch (ApiException ex) { _pwdError = ex.Message; }
        catch { _pwdError = Loc["Couldn’t reach the server. Check your connection and try again."]; }
        finally { _pwdBusy = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        Auth.Changed += OnChanged;
        Loc.Changed += OnChanged;
        await Loc.InitializeAsync();
        // An external (Google/Facebook) sign-in redirects back with the token in the URL fragment.
        string? externalToken = null;
        try { externalToken = await JS.InvokeAsync<string?>("finappTakeAuthToken"); } catch { /* host without the helper */ }
        var signedIn = false;
        if (!string.IsNullOrEmpty(externalToken))
        {
            try { signedIn = await Auth.SignInWithTokenAsync(externalToken); } catch { /* fall through */ }
        }
        if (!signedIn)
        {
            try { await Auth.TryRestoreAsync(); }
            catch { /* server unreachable on startup — fall through to the sign-in screen */ }
        }
        _restored = true;
        try { _dark = (await JS.InvokeAsync<string>("finappGetTheme")) == "dark"; } catch { /* host without the helper */ }
        await LoadLoginConsentAsync();
    }

    private void OnChanged() { _ = LoadLoginConsentAsync(); InvokeAsync(StateHasChanged); }

    // --- Consent (accept the terms once at login) -------------------------
    private bool? _loginConsent;   // null = unknown/not-signed-in, true/false = active?
    private bool _consentChecked, _consentBusy;

    private async Task LoadLoginConsentAsync()
    {
        if (!Auth.IsAuthenticated) { _loginConsent = null; return; }
        if (_loginConsent is not null) return;   // already known this session
        try { _loginConsent = (await Api.GetConsentAsync("login")).Active; }
        catch { _loginConsent = true; }   // consent endpoint unreachable — don't lock the user out
        await InvokeAsync(StateHasChanged);
    }

    private async Task AcceptLoginConsent()
    {
        _consentBusy = true;
        try { await Api.RecordConsentAsync("login", null, true); _loginConsent = true; }
        catch { /* surface via retry */ }
        finally { _consentBusy = false; }
    }

    private async Task ToggleTheme(ChangeEventArgs e)
    {
        _dark = e.Value is true;
        try { await JS.InvokeVoidAsync("finappSetTheme", _dark ? "dark" : "light"); } catch { /* ignore */ }
    }

    // --- Profile picture (stored on the server, per user; syncs across devices) ---

    private async Task PickAvatar()
    {
        _avatarError = null;
        try
        {
            var dataUrl = await JS.InvokeAsync<string?>("finappPickImage");
            if (string.IsNullOrEmpty(dataUrl)) return;
            _avatarBusy = true;
            await Api.UpdateAvatarAsync(dataUrl);
            Auth.SetAvatar(dataUrl);
            State.InvalidateMemberAvatars();
        }
        catch (ApiException ex) { _avatarError = ex.Message; }
        catch { _avatarError = Loc["Couldn’t reach the server. Check your connection and try again."]; }
        finally { _avatarBusy = false; }
    }

    private async Task RemoveAvatar()
    {
        _avatarError = null;
        _avatarBusy = true;
        try
        {
            await Api.UpdateAvatarAsync(null);
            Auth.SetAvatar(null);
            State.InvalidateMemberAvatars();
        }
        catch (ApiException ex) { _avatarError = ex.Message; }
        catch { _avatarError = Loc["Couldn’t reach the server. Check your connection and try again."]; }
        finally { _avatarBusy = false; }
    }

    private async Task SignOut()
    {
        await State.ResetAsync();
        await Auth.SignOutAsync();
    }

    public void Dispose()
    {
        Auth.Changed -= OnChanged;
        Loc.Changed -= OnChanged;
    }
}
