@inherits LayoutComponentBase
@implements IDisposable
@inject AuthState Auth
@inject BudgetingState State
@inject Localizer Loc
@inject FinAppApiClient Api
@inject IJSRuntime JS

<div class="app-shell">
    @if (Auth.IsAuthenticated)
    {
        <header class="app-bar">
            <span class="brand"><span class="brand-logo"><TandemLogo /></span> TandemTab</span>
            <span class="appbar-user">
                <LanguagePicker />
                <button class="avatar" title="@Loc["Profile settings"]" @onclick="OpenProfile">
                    @if (_avatar is not null)
                    {
                        <img src="@_avatar" alt="" />
                    }
                    else
                    {
                        <span>@Initial</span>
                    }
                </button>
                <button class="user" title="@Loc["Profile settings"]" @onclick="OpenProfile">@Loc["Hello,"] @Auth.CurrentUser!.Username</button>
                <button class="link" @onclick="SignOut">@Loc["Sign out"]</button>
            </span>
        </header>
    }
    <main class="app-body">
        @if (!_restored)
        {
            <p class="loading">@Loc["Loading…"]</p>
        }
        else if (!Auth.IsAuthenticated)
        {
            <AuthPanel />
        }
        else
        {
            @Body
        }
    </main>

    @if (_profileOpen)
    {
        <div class="pm-backdrop">
            <div class="pm">
                <h3>@Loc["Profile settings"]</h3>
                <p class="pm-who">@Auth.CurrentUser!.Username · @Auth.CurrentUser!.Email</p>
                <h4>@Loc["Profile picture"]</h4>
                <div class="pm-avatar-row">
                    <span class="pm-avatar">
                        @if (_avatar is not null)
                        {
                            <img src="@_avatar" alt="" />
                        }
                        else
                        {
                            <span>@Initial</span>
                        }
                    </span>
                    <button class="ghost" @onclick="PickAvatar">@Loc["Upload"]</button>
                    @if (_avatar is not null)
                    {
                        <button class="ghost danger" @onclick="RemoveAvatar">@Loc["Remove"]</button>
                    }
                </div>
                <p class="pm-hint">@Loc["Stored on this device only."]</p>
                <h4>@Loc["Change password"]</h4>
                @if (_pwdError is not null)
                {
                    <div class="pm-msg pm-error">@_pwdError</div>
                }
                @if (_pwdOk)
                {
                    <div class="pm-msg pm-ok">@Loc["Password changed."]</div>
                }
                <label>@Loc["Current password"] <input type="password" @bind="_curPwd" /></label>
                <label>@Loc["New password"] <input type="password" @bind="_newPwd" /></label>
                <label>@Loc["Confirm new password"] <input type="password" @bind="_confirmPwd" /></label>
                <div class="pm-actions">
                    <button class="ghost" @onclick="CloseProfile">@Loc["Close"]</button>
                    <button @onclick="ChangePassword" disabled="@(_pwdBusy || _curPwd.Length == 0 || _newPwd.Length < 8)">@Loc["Change password"]</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _restored;
    private string? _avatar;
    private string Initial => (Auth.CurrentUser?.Username ?? "?").Trim() is { Length: > 0 } u ? u[..1].ToUpperInvariant() : "?";

    private bool _profileOpen, _pwdBusy, _pwdOk;
    private string _curPwd = "", _newPwd = "", _confirmPwd = "";
    private string? _pwdError;

    private void OpenProfile() { _profileOpen = true; _curPwd = _newPwd = _confirmPwd = ""; _pwdError = null; _pwdOk = false; }
    private void CloseProfile() => _profileOpen = false;

    private async Task ChangePassword()
    {
        _pwdError = null; _pwdOk = false;
        if (_newPwd != _confirmPwd) { _pwdError = Loc["The new passwords don’t match."]; return; }
        if (_newPwd.Length < 8) { _pwdError = Loc["Password must be at least 8 characters."]; return; }
        _pwdBusy = true;
        try
        {
            await Api.ChangePasswordAsync(_curPwd, _newPwd);
            _pwdOk = true; _curPwd = _newPwd = _confirmPwd = "";
        }
        catch (ApiException ex) { _pwdError = ex.Message; }
        catch { _pwdError = Loc["Couldn’t reach the server. Check your connection and try again."]; }
        finally { _pwdBusy = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        Auth.Changed += OnChanged;
        Loc.Changed += OnChanged;
        await Loc.InitializeAsync();
        try { await Auth.TryRestoreAsync(); }
        catch { /* server unreachable on startup — fall through to the sign-in screen */ }
        _restored = true;
        await EnsureAvatarAsync();
    }

    private string? _avatarFor;

    /// <summary>(Re)load the avatar when the signed-in user changes.</summary>
    private async Task EnsureAvatarAsync()
    {
        var user = Auth.CurrentUser?.Username;
        if (user == _avatarFor) return;
        _avatarFor = user;
        await LoadAvatarAsync();
        StateHasChanged();
    }

    private void OnChanged()
    {
        InvokeAsync(StateHasChanged);
        InvokeAsync(EnsureAvatarAsync);
    }

    // --- Profile picture (stored client-side in localStorage, per user; never leaves the device) ---

    private string AvatarKey => $"finapp-avatar:{Auth.CurrentUser?.Username}";

    private async Task LoadAvatarAsync()
    {
        if (!Auth.IsAuthenticated) { _avatar = null; return; }
        try { _avatar = await JS.InvokeAsync<string?>("localStorage.getItem", AvatarKey); }
        catch { _avatar = null; }
    }

    private async Task PickAvatar()
    {
        try
        {
            var dataUrl = await JS.InvokeAsync<string?>("finappPickImage");
            if (string.IsNullOrEmpty(dataUrl)) return;
            _avatar = dataUrl;
            await JS.InvokeVoidAsync("localStorage.setItem", AvatarKey, dataUrl);
        }
        catch { /* user cancelled or storage unavailable */ }
    }

    private async Task RemoveAvatar()
    {
        _avatar = null;
        try { await JS.InvokeVoidAsync("localStorage.removeItem", AvatarKey); }
        catch { /* ignore */ }
    }

    private async Task SignOut()
    {
        await State.ResetAsync();
        await Auth.SignOutAsync();
    }

    public void Dispose()
    {
        Auth.Changed -= OnChanged;
        Loc.Changed -= OnChanged;
    }
}
