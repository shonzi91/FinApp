<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Skip the publish-time Emscripten native relink. It's only a size optimization but is slow
         (and needs python/emcc); disabling it keeps CI fast and the build self-contained. -->
    <WasmBuildNative>false</WasmBuildNative>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="9.0.6" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="9.0.6" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\FinApp.Shared.UI\FinApp.Shared.UI.csproj" />
    <ProjectReference Include="..\FinApp.Contracts\FinApp.Contracts.csproj" />
  </ItemGroup>

</Project>
