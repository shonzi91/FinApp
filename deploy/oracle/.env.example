# Copy to .env and fill in. (.env is gitignored — never commit real secrets.)

# Your public hostname pointing at the VM's public IP (e.g. a free DuckDNS subdomain).
DOMAIN=finapp.duckdns.org

# JWT signing secret — must be >= 32 chars and kept secret.
# Generate one:  openssl rand -base64 48
JWT_KEY=replace-me-with-a-long-random-secret
